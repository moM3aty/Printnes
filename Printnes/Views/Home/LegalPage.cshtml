@model string
@{
    ViewData["Title"] = ViewBag.PageTitle;
    Layout = "_Layout";
}

<div class="container py-5">
    <nav class="breadcrumb" style="margin-bottom: 20px;">
        <a href="/">الرئيسية</a> &gt;
        <span>@ViewBag.PageTitle</span>
    </nav>

    <div style="background: #fff; padding: 40px; border-radius: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; max-width: 900px; margin: 0 auto;">

        <div style="text-align: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px dashed #e2e8f0;">
            <div style="width: 60px; height: 60px; background: #eff6ff; color: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; margin: 0 auto 15px;">
                <i class="fas fa-file-contract"></i>
            </div>
            <h1 style="font-size: 28px; font-weight: 900; color: var(--navy); margin: 0;">@ViewBag.PageTitle</h1>
        </div>

        <div style="color: var(--text-main); font-size: 16px; line-height: 2; font-weight: 600;">
            @if (!string.IsNullOrWhiteSpace(Model))
            {
                @Html.Raw(Model.Replace("\n", "<br>"))
            }
            else
            {
                <div style="text-align: center; color: #94a3b8; padding: 30px 0;">
                    <i class="fas fa-pen-nib" style="font-size: 40px; margin-bottom: 15px; opacity: 0.5;"></i>
                    <p>جاري تحديث المحتوى من قبل الإدارة...</p>
                </div>
            }
        </div>

    </div>
</div>