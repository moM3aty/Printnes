<!-- الملف: Views/Home/Index.cshtml -->
@model IEnumerable<Printnes.Models.Product>
@using Printnes.Data
@using Microsoft.EntityFrameworkCore
@using Printnes.Helpers
@inject ApplicationDbContext DbContext

@{
    ViewData["Title"] = "الصفحة الرئيسية";
    var siteSettings = SiteSettingsManager.LoadSettings();
    string waNumber = siteSettings.WhatsappNumber?.Replace("+", "") ?? "";
    var activeBanners = ViewBag.ActiveBanners as List<Printnes.Models.Banner>;
    var mainCategories = ViewBag.MainCategories as List<Printnes.Models.Category>;
}

<style>
    /* ====================== */
    /* ستوديو التصميم الاحترافي - الأنماط المتقدمة */
    /* ====================== */

    .studio-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.85);
        backdrop-filter: blur(20px);
        z-index: 99999;
        display: none;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .studio-overlay.open {
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 1;
    }

    .studio-container {
        width: 96%;
        max-width: 1400px;
        height: 92vh;
        background: #0f172a;
        border-radius: 24px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(249,115,22,0.2);
        box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 100px rgba(249,115,22,0.05);
        transform: scale(0.9) translateY(40px);
        transition: all 0.5s cubic-bezier(0.175,0.885,0.32,1.275);
    }

    .studio-overlay.open .studio-container {
        transform: scale(1) translateY(0);
    }

    /* الهيدر */
    .studio-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        background: rgba(15,23,42,0.95);
        border-bottom: 1px solid rgba(249,115,22,0.15);
        flex-shrink: 0;
    }

    .studio-logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .studio-logo-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: linear-gradient(135deg,#f97316,#ea580c);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
    }

    .studio-logo h3 {
        color: #fff;
        font-size: 18px;
        font-weight: 900;
        margin: 0;
    }

    .studio-logo span {
        color: #64748b;
        font-size: 12px;
    }

    .studio-header-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .s-btn {
        padding: 8px 18px;
        border-radius: 10px;
        border: none;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
    }

    .s-btn-ghost {
        background: rgba(255,255,255,0.05);
        color: #94a3b8;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .s-btn-ghost:hover {
        background: rgba(255,255,255,0.1);
        color: #fff;
    }

    .s-btn-close {
        background: rgba(239,68,68,0.1);
        color: #f87171;
        border: 1px solid rgba(239,68,68,0.2);
    }

    .s-btn-close:hover {
        background: rgba(239,68,68,0.2);
    }

    .s-btn-primary {
        background: linear-gradient(135deg,#f97316,#ea580c);
        color: #fff;
        box-shadow: 0 4px 15px rgba(249,115,22,0.3);
    }

    .s-btn-wa {
        background: linear-gradient(135deg,#25d366,#128c7e);
        color: #fff;
        box-shadow: 0 3px 12px rgba(37,211,102,.2);
    }

    .s-btn-dl {
        background: rgba(99,102,241,.1);
        color: #818cf8;
        border: 1px solid rgba(99,102,241,.2);
    }

    /* الجسم */
    .studio-body {
        display: flex;
        flex: 1;
        overflow: hidden;
    }

    /* لوحة المنتجات اليسرى */
    .studio-products-panel {
        width: 80px;
        background: rgba(15,23,42,0.9);
        border-left: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 16px 0;
        gap: 6px;
        flex-shrink: 0;
    }

    .pt-btn {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        border: 2px solid transparent;
        background: rgba(255,255,255,0.03);
        color: #64748b;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 18px;
    }

    .pt-btn span {
        font-size: 8px;
        font-weight: 700;
    }

    .pt-btn:hover {
        background: rgba(249,115,22,0.08);
        color: #f97316;
        border-color: rgba(249,115,22,0.2);
    }

    .pt-btn.active {
        background: rgba(249,115,22,0.12);
        color: #f97316;
        border-color: #f97316;
    }

    /* منطقة المعاينة الوسطى */
    .studio-viewport {
        flex: 1;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .vp-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 20px;
        background: rgba(15,23,42,0.6);
        border-bottom: 1px solid rgba(255,255,255,0.04);
        flex-shrink: 0;
    }

    .vm-modes { display: flex; gap: 4px; }
    .vm-btn {
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.06);
        background: transparent;
        color: #64748b;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .vm-btn:hover { background: rgba(255,255,255,0.05); color: #e2e8f0; }
    .vm-btn.active { background: rgba(249,115,22,0.12); color: #f97316; border-color: rgba(249,115,22,0.3); }

    .vp-info { color: #475569; font-size: 11px; display: flex; gap: 16px; }
    .vp-info span i { margin-left: 4px; color: #f97316; }

    #studio-canvas-3d {
        flex: 1;
        width: 100%;
        cursor: grab;
    }
    #studio-canvas-3d:active { cursor: grabbing; }

    /* محرر 2D (يظهر فوق الـ 3D) */
    .ed-2d-wrap {
        position: absolute;
        top: 42px; left: 0; right: 0; bottom: 0;
        display: none;
        align-items: center;
        justify-content: center;
        background: repeating-conic-gradient(rgba(255,255,255,0.02) 0% 25%, transparent 0% 50%) 0 0 / 20px 20px;
        padding: 20px;
    }
    .ed-2d-wrap.active { display: flex; }
    #editor-canvas-2d { border: 2px dashed rgba(249,115,22,0.3); border-radius: 8px; cursor: crosshair; box-shadow: 0 0 40px rgba(0,0,0,0.3); }

    /* لوحة الأدوات اليمنى */
    .studio-tools-panel {
        width: 320px;
        background: rgba(15,23,42,0.95);
        border-right: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        overflow: hidden;
    }

    .t-tabs { display: flex; border-bottom: 1px solid rgba(255,255,255,0.06); padding: 0 8px; flex-shrink: 0; }
    .t-tab {
        flex: 1; padding: 12px 4px; text-align: center; border: none; background: transparent; color: #475569; font-size: 10px; font-weight: 700; cursor: pointer; transition: all 0.3s; border-bottom: 2px solid transparent; display: flex; flex-direction: column; align-items: center; gap: 4px;
    }
    .t-tab i { font-size: 16px; }
    .t-tab:hover { color: #94a3b8; background: rgba(255,255,255,0.02); }
    .t-tab.active { color: #f97316; border-bottom-color: #f97316; }

    .t-content { flex: 1; overflow-y: auto; padding: 16px; }
    .t-content::-webkit-scrollbar { width: 4px; }
    .t-content::-webkit-scrollbar-track { background: transparent; }
    .t-content::-webkit-scrollbar-thumb { background: rgba(249,115,22,0.3); border-radius: 4px; }

    .t-sec { display: none; animation: slideUp 0.3s ease; }
    .t-sec.active { display: block; }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .t-grp { margin-bottom: 20px; }
    .t-lbl { font-size: 11px; color: #94a3b8; font-weight: 700; margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 0.5px; }

    .t-inp {
        width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.04); color: #e2e8f0; font-size: 13px; font-weight: 600; transition: all 0.3s; box-sizing: border-box;
    }
    .t-inp:focus { outline: none; border-color: rgba(249,115,22,0.5); background: rgba(249,115,22,0.05); box-shadow: 0 0 0 3px rgba(249,115,22,0.1); }

    .t-row { display: flex; gap: 8px; }
    .t-row > * { flex: 1; }

    .c-grid { display: grid; grid-template-columns: repeat(6,1fr); gap: 6px; }
    .c-sw { width: 100%; aspect-ratio: 1; border-radius: 10px; border: 2px solid transparent; cursor: pointer; transition: all 0.3s; }
    .c-sw:hover { transform: scale(1.15); z-index: 2; }
    .c-sw.act { border-color: #fff; box-shadow: 0 0 0 2px #f97316; transform: scale(1.1); }

    .t-btn {
        width: 100%; padding: 10px; border-radius: 10px; border: 1px dashed rgba(255,255,255,0.1); background: rgba(255,255,255,0.02); color: #94a3b8; font-size: 12px; font-weight: 700; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .t-btn:hover { background: rgba(249,115,22,0.08); color: #f97316; border-color: rgba(249,115,22,0.3); }

    .el-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); margin-bottom: 8px; transition: all 0.3s; cursor: pointer; }
    .el-item:hover { background: rgba(249,115,22,0.06); border-color: rgba(249,115,22,0.2); }
    .el-item.sel { background: rgba(249,115,22,0.1); border-color: #f97316; }
    .el-info { flex: 1; }
    .el-info span { display: block; color: #e2e8f0; font-size: 13px; font-weight: 600; }
    .el-info small { color: #64748b; font-size: 11px; }

    .del-el { width: 28px; height: 28px; border-radius: 8px; border: none; background: rgba(239,68,68,0.1); color: #f87171; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 11px; transition: all 0.3s; }
    .del-el:hover { background: rgba(239,68,68,0.2); }

    .dim-grp label { display: block; font-size: 11px; color: #94a3b8; font-weight: 700; margin-bottom: 4px; }
    .dim-grp input { width: 100%; padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.04); color: #e2e8f0; font-size: 13px; font-weight: 600; }
    .dim-grp input:focus { outline: none; border-color: rgba(249,115,22,0.5); }

    .studio-error { color: #f87171; font-size: 11px; text-align: center; margin-top: 8px; display: none; font-weight: 700; padding: 8px; border-radius: 8px; background: rgba(239,68,68,0.08); }

    .studio-loader { position: absolute; inset: 0; background: #080d18; display: flex; align-items: center; justify-content: center; z-index: 100; transition: opacity .5s; }
    .studio-loader.hidden { opacity: 0; pointer-events: none; }
    .studio-spinner { width: 44px; height: 44px; border: 3px solid rgba(249,115,22,.12); border-top-color: #f97316; border-radius: 50%; animation: spin .7s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .studio-toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px); background: rgba(15,23,42,0.95); border: 1px solid rgba(249,115,22,0.3); color: #e2e8f0; padding: 12px 24px; border-radius: 12px; font-size: 13px; font-weight: 700; z-index: 999999; transition: transform 0.4s cubic-bezier(0.175,0.885,0.32,1.275); display: flex; align-items: center; gap: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
    .studio-toast.show { transform: translateX(-50%) translateY(0); }

    /* بانر الرئيسية */
    .studio-banner { background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%); border-radius: 24px; padding: 0; display: flex; overflow: hidden; box-shadow: 0 20px 60px rgba(15, 23, 42, 0.4), 0 0 0 1px rgba(255,255,255,0.05); position: relative; min-height: 220px; }
    .studio-banner::before { content: ''; position: absolute; top: -50%; right: -20%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(56, 189, 248, 0.12) 0%, transparent 70%); pointer-events: none; }
    .studio-banner-content { flex: 1; padding: 40px; display: flex; flex-direction: column; justify-content: center; position: relative; z-index: 2; }
    .studio-banner h2 { font-size: 30px; font-weight: 900; margin: 0 0 12px 0; color: #f1f5f9; line-height: 1.3; }
    .studio-banner h2 span { background: linear-gradient(135deg, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .studio-btn-open { display: inline-flex; align-items: center; gap: 10px; background: linear-gradient(135deg, #38bdf8, #0284c7); color: #fff; border: none; padding: 14px 32px; font-size: 15px; border-radius: 12px; font-weight: 800; cursor: pointer; box-shadow: 0 8px 24px rgba(56, 189, 248, 0.3); transition: 0.3s; width: fit-content; }
    .studio-btn-open:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(56, 189, 248, 0.4); }
    .studio-banner-visual { width: 340px; position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; }
    .studio-visual-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; transform: rotate(3deg) translateX(-20px); }
    .studio-visual-item { width: 120px; height: 120px; border-radius: 16px; overflow: hidden; border: 2px solid rgba(255,255,255,0.08); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
    .studio-visual-item img { width: 100%; height: 100%; object-fit: cover; }
    .studio-visual-item.wide { grid-column: span 2; width: 100%; height: 80px; }

    @@media(max-width:900px) {
        .studio-body { flex-direction: column; }
        .studio-products-panel { width: 100%; flex-direction: row; height: 60px; padding: 0 10px; border-left: none; border-bottom: 1px solid rgba(255,255,255,0.06); overflow-x: auto; }
        .studio-tools-panel { width: 100%; height: 45%; border-right: none; border-top: 1px solid rgba(255,255,255,0.06); }
        .studio-viewport { height: 55%; }
        .studio-banner { flex-direction: column; padding: 0; }
        .studio-banner-content { padding: 30px 25px 20px; }
        .studio-banner-visual { width: 100%; padding: 0 25px 25px; }
        .studio-visual-grid { transform: none; }
    }
</style>

<main class="container">
    <!-- البانرات المتحركة -->
    <section class="hero-slider-wrapper">
        <div class="swiper hero-swiper">
            <div class="swiper-wrapper">
                @if (activeBanners != null && activeBanners.Any())
                {
                    foreach (var banner in activeBanners)
                    {
                        <div class="swiper-slide"><a href="@(string.IsNullOrEmpty(banner.LinkUrl) ? "#" : banner.LinkUrl)"><img src="@banner.ImageUrl" alt="@banner.Title" class="full-banner-img"></a></div>
                    }
                }
            </div>
            <div class="swiper-button-next"></div><div class="swiper-button-prev"></div><div class="swiper-pagination"></div>
        </div>
    </section>

    <!-- الأقسام الرئيسية -->
    <section class="main-categories">
        <div class="section-title-box"><h2>الأقسام الرئيسية</h2><p>حرك القائمة لليسار لعرض جميع الأقسام</p></div>
        <div class="categories-scroll">
            <div class="cat-card" onclick="location.href='/Packages'"><div class="circle-img"><img src="https://cdn.salla.sa/form-builder/PD53rr1LUNb19Hj3je9ULKSfhYUGg0o3TOBdz1T7.png" alt="العروض"></div><h4>العروض والبكجات</h4></div>
            @if (mainCategories != null)
            {
                foreach (var cat in mainCategories)
                {
                    string catImage = !string.IsNullOrEmpty(cat.ImageUrl) ? cat.ImageUrl : "https://cdn.salla.sa/form-builder/lnB9NCS8slVsu7xfA6j6Ka37ZIEGCnEu9de9JiR3.png";
                    <div class="cat-card" onclick="location.href='/Category/@cat.Slug'"><div class="circle-img"><img src="@catImage" alt="@cat.NameAr"></div><h4>@cat.NameAr</h4></div>
                }
            }
        </div>
    </section>

    <!-- بانر ستوديو التصميم 3D -->
    <section style="margin: 40px 0;">
        <div class="studio-banner">
            <div class="studio-banner-content">
                <div style="display: inline-flex; align-items: center; gap: 7px; background: rgba(56, 189, 248, 0.1); padding: 4px 13px; border-radius: 18px; margin-bottom: 14px; border: 1px solid rgba(56, 189, 248, 0.2);">
                    <span style="width: 5px; height: 5px; background: #38bdf8; border-radius: 50%; animation: pulseDot 1.5s infinite;"></span>
                    <span style="font-size: 10px; color: #38bdf8; font-weight: 800; letter-spacing: 1px;">ستوديو ثلاثي الأبعاد</span>
                </div>
                <h2>صمّم منتجك <span>بواقعية تامة</span></h2>
                <p>كراتين، تيشيرتات، أكواب — معاينة 3D لحظية. أضف نصوصك، صورك، واختار ألوانك وشوف النتيجة فوراً قبل الطلب.</p>
                <button onclick="openDesignStudio()" class="studio-btn-open">
                    <i class="fas fa-wand-magic-sparkles"></i> ادخل الستوديو
                </button>
            </div>
            <div class="studio-banner-visual">
                <div class="studio-visual-grid">
                    <div class="studio-visual-item"><img src="https://cdn.salla.sa/rDvVQ/1pKR8dtK4Hd9UoYFf1hqwqPQJMn5YFEqyOyJngiZ.jpg" alt="مطبوعات"></div>
                    <div class="studio-visual-item"><img src="https://cdn.salla.sa/rDvVQ/OQxmT3F9y8bS0SrRQOIZVusIvSyRHalGpw0j7rJX.png" alt="أكواب"></div>
                    <div class="studio-visual-item wide"><img src="https://cdn.salla.sa/form-builder/PD53rr1LUNb19Hj3je9ULKSfhYUGg0o3TOBdz1T7.png" alt="بوكسات"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- المنتجات المميزة -->
    <section class="products-slider-section">
        <div class="section-header">
            <div class="right-side"><h2 class="section-title">الأكثر مبيعاً / مميز</h2></div>
            <div class="left-side"><a href="/Products" class="view-all">عرض الكل</a><div class="slider-controls"><div class="swiper-button-prev-prod"><i class="fas fa-chevron-right"></i></div><div class="swiper-button-next-prod"><i class="fas fa-chevron-left"></i></div></div></div>
        </div>
        <div class="swiper most-selling-swiper">
            <div class="swiper-wrapper" id="featured-products-slider">
                @if (Model != null && Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <div class="swiper-slide">
                            <div class="product-card">
                                <div class="p-badge">منتج مميز</div>
                                <div class="wish-icon fav-btn-element" data-product-id="@product.Id" onclick="handleFavoriteToggle(@product.Id,this,'@product.NameAr.Replace("'", "\\'")','@product.CoverImageUrl')" style="cursor:pointer;z-index:5;"><i class="far fa-heart"></i></div>
                                <img src="@product.CoverImageUrl" alt="@product.NameAr" onclick="location.href='/Products/Details/@product.Id'" style="cursor:pointer;">
                                <div class="p-info">
                                    <h3 onclick="location.href='/Products/Details/@product.Id'" style="cursor:pointer;">@product.NameAr</h3>
                                    <span class="p-price">السعر حسب الاختيارات</span>
                                    <button class="add-to-cart-orange" onclick="location.href='/Products/Details/@product.Id'">عرض التفاصيل <i class="fas fa-arrow-left"></i></button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <section class="product-group"><div class="group-header"><h2>بوكسات وتغليف</h2><a href="/Category/boxes">عرض الكل</a></div><div class="products-grid" id="render-boxes"></div></section>
    <section class="product-group"><div class="group-header"><h2>مطبوعات ورقية</h2><a href="/Category/paperprints">عرض الكل</a></div><div class="products-grid" id="render-paperprints"></div></section>
    <section class="product-group"><div class="group-header"><h2>استيكرات</h2><a href="/Category/stickers">عرض الكل</a></div><div class="products-grid" id="render-stickers"></div></section>

</main>

<!-- ===== نافذة ستوديو الـ 3D ===== -->
<div id="designStudioModal" class="studio-overlay">
    <div class="studio-container">
        <div class="studio-loader" id="studioLoader"><div class="studio-spinner"></div></div>
        <div class="studio-header">
            <div class="studio-logo">
                <div class="studio-logo-icon"><i class="fas fa-wand-magic-sparkles"></i></div>
                <div><h3>ستوديو التصميم</h3><span>معاينة ثلاثية الأبعاد حية</span></div>
            </div>
            <div class="studio-header-actions">
                <button class="s-btn s-btn-dl" onclick="downloadDesign()"><i class="fas fa-download"></i> حفظ كصورة</button>
                <button class="s-btn s-btn-ghost" onclick="resetDesign()"><i class="fas fa-rotate-right"></i> تعيين</button>
