<!-- الملف: Views/Home/Index.cshtml -->
@model IEnumerable<Printnes.Models.Product>
@using Printnes.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

@{
    ViewData["Title"] = "الصفحة الرئيسية";

    var activeBanners = await DbContext.Banners
        .Where(b => b.IsActive)
        .OrderBy(b => b.SortOrder)
        .ToListAsync();

    var mainCategories = await DbContext.Categories
        .Where(c => c.IsActive && string.IsNullOrEmpty(c.ParentMenu))
        .OrderBy(c => c.SortOrder)
        .ToListAsync();
}

<main class="container">
    <section class="hero-slider-wrapper">
        <div class="swiper hero-swiper">
            <div class="swiper-wrapper">
                @if (activeBanners != null && activeBanners.Any())
                {
                    foreach (var banner in activeBanners)
                    {
                        <div class="swiper-slide">
                            <a href="@(string.IsNullOrEmpty(banner.LinkUrl) ? "#" : banner.LinkUrl)">
                                <img src="@banner.ImageUrl" alt="@banner.Title" class="full-banner-img">
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="swiper-slide">
                        <a href="#">
                            <img src="https://cdn.salla.sa/form-builder/wzsdRwVsUbNJVFVyQS6oTkganoSdKqnn1KADKYWk.png" alt="بانر افتراضي" class="full-banner-img">
                        </a>
                    </div>
                }
            </div>
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-pagination"></div>
        </div>
    </section>

    <section class="main-categories">
        <div class="section-title-box">
            <h2>الأقسام الرئيسية</h2>
            <p>حرك القائمة لليسار لعرض جميع الأقسام</p>
        </div>
        <div class="categories-scroll">
            <div class="cat-card" onclick="location.href='/Packages'">
                <div class="circle-img">
                    <img src="https://cdn.salla.sa/form-builder/PD53rr1LUNb19Hj3je9ULKSfhYUGg0o3TOBdz1T7.png" alt="العروض والبكجات">
                </div>
                <h4>العروض والبكجات</h4>
            </div>

            @foreach (var cat in mainCategories)
            {
                string catImage = !string.IsNullOrEmpty(cat.ImageUrl) ? cat.ImageUrl : "https://cdn.salla.sa/form-builder/lnB9NCS8slVsu7xfA6j6Ka37ZIEGCnEu9de9JiR3.png";
                <div class="cat-card" onclick="location.href='/Category/@cat.Slug'">
                    <div class="circle-img">
                        <img src="@catImage" alt="@cat.NameAr">
                    </div>
                    <h4>@cat.NameAr</h4>
                </div>
            }
        </div>
    </section>

    <!-- المنتجات المميزة (التي ترسم من السيرفر) تم ربطها بالمفضلة -->
    <section class="products-slider-section container">
        <div class="section-header">
            <div class="right-side">
                <h2 class="section-title">الأكثر مبيعاً / مميز</h2>
            </div>
            <div class="left-side">
                <a href="/Products" class="view-all">عرض الكل</a>
                <div class="slider-controls">
                    <div class="swiper-button-prev-prod"><i class="fas fa-chevron-right"></i></div>
                    <div class="swiper-button-next-prod"><i class="fas fa-chevron-left"></i></div>
                </div>
            </div>
        </div>
        <div class="swiper most-selling-swiper">
            <div class="swiper-wrapper" id="featured-products-slider">
                @if (Model != null && Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <div class="swiper-slide">
                            <div class="product-card">
                                <div class="p-badge">منتج مميز</div>
                                <!-- تم ربط الزر هنا وتمرير الـ ID -->
                                <div class="wish-icon fav-btn-element" data-product-id="@product.Id" onclick="handleFavoriteToggle(@product.Id, this, '@product.NameAr.Replace("'", "\\'")', '@product.CoverImageUrl')" style="cursor: pointer; z-index: 5;">
                                    <i class="far fa-heart"></i>
                                </div>
                                <img src="@product.CoverImageUrl" alt="@product.NameAr" onclick="location.href='/Products/Details/@product.Id'" style="cursor:pointer;">
                                <div class="p-info">
                                    <h3 onclick="location.href='/Products/Details/@product.Id'" style="cursor:pointer;">@product.NameAr</h3>
                                    <p class="p-desc" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@(string.IsNullOrEmpty(product.DescriptionAr) ? "منتج عالي الجودة" : product.DescriptionAr)</p>
                                    <span class="p-price">السعر حسب الاختيارات</span>
                                    <button class="add-to-cart-orange" onclick="location.href='/Products/Details/@product.Id'">
                                        عرض التفاصيل <i class="fas fa-arrow-left"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <!-- الأقسام الديناميكية السفلية -->
    <section class="product-group">
        <div class="group-header">
            <h2>بوكسات</h2> <a href="/Category/boxes">عرض الكل</a>
        </div>
        <div class="products-grid" id="render-boxes"></div>
    </section>

    <section class="product-group">
        <div class="group-header">
            <h2>مطبوعات ورقية</h2> <a href="/Category/paperprints">عرض الكل</a>
        </div>
        <div class="products-grid" id="render-paperprints"></div>
    </section>

    <section class="product-group">
        <div class="group-header">
            <h2>استيكرات</h2> <a href="/Category/stickers">عرض الكل</a>
        </div>
        <div class="products-grid" id="render-stickers"></div>
    </section>

    <section class="premium-stats">
        <div class="container">
            <div class="section-header-right">
                <h2 class="orange-line-title">لماذا برنتنس ؟!</h2>
            </div>
            <div class="stats-container">
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="far fa-user-circle"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+8000</span>
                        <p class="stat-desc">عميل جرب منتجاتنا</p>
                    </div>
                </div>
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="fas fa-location-arrow"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+500</span>
                        <p class="stat-desc">شحنة دولية ناجحة</p>
                    </div>
                </div>
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="far fa-envelope-open"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+160000</span>
                        <p class="stat-desc">رسالة رددنا عليها</p>
                    </div>
                </div>
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="fas fa-store-alt"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+700</span>
                        <p class="stat-desc">متجر يستفيد شهرياً</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="faq-section">
        <div class="container">
            <div class="section-title-wrapper">
                <h2 class="orange-title">الأسئلة الشائعة</h2>
            </div>
            <div class="faq-grid">
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>هل يمكنني تغيير طلبي الاضافة او التعديل ؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>نعم يمكنك الاضافة او التعديل في فترة اقصاها 24 ساعة ولكن بعد تنفيذ المنتج أو شحنه يجب طلب اضافتك في طلب جديد.</p>
                    </div>
                </div>
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>كيف يمكنني الطلب من الموقع ؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>يمكنك بكل سهولة اضافة جميع البيانات من خلال صفحة طلب المنتج وفي حال واجهت اي مشكلة بإمكانك التواصل معنا من خلال الواتس اب او الايميل.</p>
                    </div>
                </div>
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>هل يمكن تعديل بياناتي؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>نعم. يمكنك من خلال التواصل معنا ويتم تعديلها بشكل فوري.</p>
                    </div>
                </div>
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>هل تعملون افكار خارج ما هو بالموقع ؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>نعم، يعتمد على الفكرة والمنتج المطبوع يرجى مشاركتنا المنتج الذي تود تصنيعه من خلال الواتس اب او الايميل حتى يتسنى لنا اعطائك المزيد من التفاصيل.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof renderSection === "function") {
                renderSection("boxes", "render-boxes");
                renderSection("paperprints", "render-paperprints");
                renderSection("stickers", "render-stickers");
            }

            if (typeof Swiper !== 'undefined') {
                new Swiper('.hero-swiper', {
                    loop: true,
                    pagination: { el: '.swiper-pagination', clickable: true },
                    navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
                    autoplay: { delay: 5000, disableOnInteraction: false }
                });

                new Swiper('.most-selling-swiper', {
                    slidesPerView: 2,
                    spaceBetween: 15,
                    navigation: { nextEl: '.swiper-button-next-prod', prevEl: '.swiper-button-prev-prod' },
                    breakpoints: {
                        768: { slidesPerView: 3, spaceBetween: 20 },
                        1024: { slidesPerView: 4, spaceBetween: 25 }
                    }
                });
            }
        });
    </script>
}