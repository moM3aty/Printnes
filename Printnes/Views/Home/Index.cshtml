</div>
<div class="studio-toast" id="studioToast"><i class="fas fa-check-circle"></i><span id="toastMsg"></span></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof renderSection === "function") {
                renderSection("boxes", "render-boxes");
                renderSection("paperprints", "render-paperprints");
                renderSection("stickers", "render-stickers");
            }
            if (typeof Swiper !== 'undefined') {
                new Swiper('.hero-swiper', { loop: true, pagination: { el: '.swiper-pagination', clickable: true }, navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' }, autoplay: { delay: 5000, disableOnInteraction: false } });
                new Swiper('.most-selling-swiper', { slidesPerView: 2, spaceBetween: 15, navigation: { nextEl: '.swiper-button-next-prod', prevEl: '.swiper-button-prev-prod' }, breakpoints: { 768: { slidesPerView: 3, spaceBetween: 20 }, 1024: { slidesPerView: 4, spaceBetween: 25 } } });
            }
        });
    </script>
    
    <script type="importmap">
        {
            "imports": {
                "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
                "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
            }
        }
    </script>
    
    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        let scene, camera, renderer, controls, curMesh;
        let autoRot = true;
        let cTex, cCtx, tCanvas;
        const SZ = 1024;
        let els = [], selIdx = -1;
        let curType = 'shipping-box';
        let bgColor = '#c9a87c';
        let grad = null;
        let inited = false;
        let fabricBumpTex = null;

        const COLORS = ['#f97316','#ef4444','#dc2626','#ec4899','#a855f7','#7c3aed','#6366f1','#3b82f6','#0ea5e9','#06b6d4','#14b8a6','#10b981','#22c55e','#84cc16','#eab308','#f59e0b','#ffffff','#f1f5f9','#cbd5e1','#64748b','#334155','#1e293b','#0f172a','#c9a87c','#e8e0d4'];
        const GRADS = [['#f97316','#dc2626'],['#6366f1','#ec4899'],['#06b6d4','#3b82f6'],['#22c55e','#06b6d4'],['#f59e0b','#ef4444'],['#0f172a','#1e3a5f']];
        const PNAMES = {'shipping-box':'كرتون شحن مضلع', 'fold-box':'بوكس ورقي', 'gift-box':'بوكس هدايا صلب', 'tshirt':'تيشيرت قطني', 'cup':'كوب سيراميك'};
        const waNumber = "@waNumber";

        /* ===== خامة القماش للتيشيرت ===== */
        function makeFabricBump(){
            const s = 256, cv = document.createElement('canvas'); cv.width = s; cv.height = s;
            const x = cv.getContext('2d');
            x.fillStyle = '#808080'; x.fillRect(0, 0, s, s);
            x.globalAlpha = 0.2; x.strokeStyle = '#aaa'; x.lineWidth = 0.5;
            for(let i = -s; i < s * 2; i += 3) {
                x.beginPath(); x.moveTo(i, 0); x.lineTo(i + s, s); x.stroke();
                x.beginPath(); x.moveTo(i + s, 0); x.lineTo(i, s); x.stroke();
            }
            const t = new THREE.CanvasTexture(cv);
            t.wrapS = t.wrapT = THREE.RepeatWrapping;
            t.repeat.set(15, 15);
            return t;
        }

        /* ===== تهيئة الـ 3D ===== */
        function init(){
            const cv = document.getElementById('studio-canvas-3d');
            const ct = cv.parentElement;
            
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(38, ct.clientWidth / ct.clientHeight, 0.1, 1000);
            camera.position.set(3.5, 3.5, 5);

            renderer = new THREE.WebGLRenderer({ canvas: cv, antialias: true, alpha: true });
            renderer.setSize(ct.clientWidth, ct.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            renderer.toneMapping = THREE.ACESFilmicToneMapping;

            scene.add(new THREE.AmbientLight(0xffffff, 0.6));
            
            const key = new THREE.DirectionalLight(0xffffff, 1.2);
            key.position.set(5, 10, 5);
            key.castShadow = true;
            key.shadow.mapSize.set(1024, 1024);
            scene.add(key);

            const fill = new THREE.DirectionalLight(0xb4c6ef, 0.5);
            fill.position.set(-5, 4, -5);
            scene.add(fill);

            // أرضية عاكسة للظلال
            const sm = new THREE.Mesh(new THREE.PlaneGeometry(20, 20), new THREE.ShadowMaterial({ opacity: 0.15 }));
            sm.rotation.x = -Math.PI / 2; sm.position.y = -1.25; sm.receiveShadow = true;
            scene.add(sm);

            const grid = new THREE.GridHelper(14, 28, 0x1a2236, 0x1a2236);
            grid.position.y = -1.26; grid.material.opacity = 0.15; grid.material.transparent = true;
            scene.add(grid);

            controls = new OrbitControls(camera, cv);
            controls.enableDamping = true; controls.dampingFactor = 0.05;
            controls.minDistance = 2; controls.maxDistance = 15;
            controls.autoRotate = true; controls.autoRotateSpeed = 1.0;
            controls.target.set(0, 0, 0);

            tCanvas = document.createElement('canvas'); tCanvas.width = SZ; tCanvas.height = SZ;
            cCtx = tCanvas.getContext('2d');
            cTex = new THREE.CanvasTexture(tCanvas);
            cTex.colorSpace = THREE.SRGBColorSpace;
            cTex.anisotropy = renderer.capabilities.getMaxAnisotropy();

            fabricBumpTex = makeFabricBump();
            createProduct('shipping-box');
            anim();
            window.addEventListener('resize', onRS);
            inited = true;
        }

        function onRS(){
            const c = document.getElementById('studio-canvas-3d'), ct = c.parentElement;
            camera.aspect = ct.clientWidth / ct.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(ct.clientWidth, ct.clientHeight);
        }

        function anim() { 
            requestAnimationFrame(anim); 
            controls.update(); 
            renderer.render(scene, camera); 
        }

        /* ===== بناء المنتجات الهندسية ===== */
        function dispose(){
            if(!curMesh) return;
            scene.remove(curMesh);
            (function d(o){
                if(o.geometry) o.geometry.dispose();
                if(o.material){
                    if(Array.isArray(o.material)) o.material.forEach(m => { if(m.map) m.map.dispose(); m.dispose(); });
                    else { if(o.material.map) o.material.map.dispose(); o.material.dispose(); }
                }
                if(o.children) o.children.forEach(c => d(c));
            })(curMesh);
        }

        function animScale(o, t, dur){
            o.scale.set(0.01, 0.01, 0.01);
            const s = { x: 0.01, y: 0.01, z: 0.01 }, t0 = performance.now();
            !function tk(n){
                const p = Math.min((n - t0) / dur, 1);
                const e = p === 0 ? 0 : p === 1 ? 1 : Math.pow(2, -10 * p) * Math.sin((p * 10 - 0.75) * (2 * Math.PI) / 3) + 1;
                o.scale.x = s.x + (t.x - s.x) * e;
                o.scale.y = s.y + (t.y - s.y) * e;
                o.scale.z = s.z + (t.z - s.z) * e;
                if(p < 1) requestAnimationFrame(tk);
            }(performance.now());
        }

        function createProduct(type) {
            dispose(); updateTex();
            let m;
            switch(type){
                case 'shipping-box': m = mkBox(2, 1.5, 1.5, bgColor, 0.7); break;
                case 'fold-box': m = mkBox(2, 1, 1.5, bgColor, 0.4); break;
                case 'gift-box': m = mkBox(1.8, 1.8, 1.8, bgColor, 0.15); break;
                case 'tshirt': m = mkTshirt(); break;
                case 'cup': m = mkCup(); break;
                default: m = mkBox(2, 1.5, 1.5, bgColor, 0.7);
            }
            curMesh = m; 
            animScale(m, { x: 1, y: 1, z: 1 }, 800);
            scene.add(m); 
            curType = type;
            
            const cp = { x: 3.5, y: 2.5, z: 4.5 };
            if(type === 'tshirt') { controls.target.set(0, 0.2, 0); }
            else if(type === 'cup') { controls.target.set(0, 0, 0); cp.z = 3.5; }
            else { controls.target.set(0, 0, 0); }
            camera.position.set(cp.x, cp.y, cp.z);
        }

        function mkBox(w, h, d, sc, rough) {
            const g = new THREE.BoxGeometry(w, h, d, 10, 10, 10);
            const printedMat = new THREE.MeshStandardMaterial({ map: cTex, roughness: rough });
            const sideMat = new THREE.MeshStandardMaterial({ color: new THREE.Color(sc), roughness: rough });
            const m = new THREE.Mesh(g, [sideMat, sideMat, sideMat, sideMat, printedMat, sideMat]);
            m.castShadow = true; m.receiveShadow = true;
            
            // إضافة حواف واقعية
            const edges = new THREE.EdgesGeometry(new THREE.BoxGeometry(w, h, d));
            const edgeColor = isLightColor(sc) ? 0x94a3b8 : 0x000000;
            const lines = new THREE.LineSegments(edges, new THREE.LineBasicMaterial({ color: edgeColor, transparent: true, opacity: 0.3, linewidth: 2 }));
            m.add(lines);
            return m;
        }

        function mkTshirt() {
            const shape = new THREE.Shape();
            shape.moveTo(-1.2, -1.5); 
            shape.lineTo(1.2, -1.5);  
            shape.quadraticCurveTo(1.25, -1.0, 1.15, 0.2); 
            shape.quadraticCurveTo(1.15, 0.4, 1.25, 0.45); 
            shape.lineTo(2.0, -0.1);  
            shape.quadraticCurveTo(2.1, -0.15, 2.2, 0.05); 
            shape.lineTo(1.25, 1.0);   
            shape.quadraticCurveTo(1.1, 1.2, 0.8, 1.2); 
            shape.lineTo(0.5, 1.2);   
            shape.quadraticCurveTo(0, 0.8, -0.5, 1.2);  
            shape.lineTo(-0.8, 1.2);  
            shape.quadraticCurveTo(-1.1, 1.2, -1.25, 1.0);
            shape.lineTo(-2.2, 0.05);  
            shape.quadraticCurveTo(-2.1, -0.15, -2.0, -0.1);
            shape.lineTo(-1.25, 0.45);
            shape.quadraticCurveTo(-1.15, 0.4, -1.15, 0.2);
            shape.quadraticCurveTo(-1.25, -1.0, -1.2, -1.5);

            const extrudeSettings = { depth: 0.15, bevelEnabled: true, bevelSegments: 6, steps: 1, bevelSize: 0.05, bevelThickness: 0.1 };
            const g = new THREE.ExtrudeGeometry(shape, extrudeSettings);
            g.center();

            const printedMat = new THREE.MeshStandardMaterial({
                color: new THREE.Color(bgColor),
                map: cTex,
                roughness: 1.0,
                bumpMap: fabricBumpTex,
                bumpScale: 0.008
            });
            const sideMat = new THREE.MeshStandardMaterial({
                color: new THREE.Color(bgColor),
                roughness: 1.0,
                bumpMap: fabricBumpTex,
                bumpScale: 0.008
            });

            const m = new THREE.Mesh(g, [printedMat, sideMat]);
            m.castShadow = true; m.receiveShadow = true;
            return m;
        }

        function mkCup() {
            const grp = new THREE.Group();
            
            const outerG = new THREE.CylinderGeometry(0.78, 0.64, 2.3, 64, 1, true);
            const outerM = new THREE.MeshPhysicalMaterial({ map: cTex, roughness: 0.1, metalness: 0.1, clearcoat: 0.8, clearcoatRoughness: 0.1, side: THREE.DoubleSide });
            const outer = new THREE.Mesh(outerG, outerM);
            outer.rotation.y = -Math.PI / 2;
            outer.castShadow = true;
            grp.add(outer);
            
            const innerG = new THREE.CylinderGeometry(0.75, 0.62, 2.28, 64, 1, true);
            const innerM = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.1, side: THREE.BackSide });
            grp.add(new THREE.Mesh(innerG, innerM));
            
            const rimG = new THREE.TorusGeometry(0.765, 0.035, 16, 64);
            const rimM = new THREE.MeshPhysicalMaterial({ color: 0xffffff, roughness: 0.1, metalness: 0.05, clearcoat: 0.8 });
            const rim = new THREE.Mesh(rimG, rimM);
            rim.position.y = 1.15; rim.rotation.x = Math.PI / 2;
            grp.add(rim);
            
            const bG = new THREE.CircleGeometry(0.64, 64);
            const bM = new THREE.MeshPhysicalMaterial({ color: 0xffffff, roughness: 0.2, side: THREE.DoubleSide });
            const bt = new THREE.Mesh(bG, bM);
            bt.rotation.x = -Math.PI / 2; bt.position.y = -1.15;
            grp.add(bt);
            
            const brG = new THREE.TorusGeometry(0.64, 0.025, 12, 64);
            const br = new THREE.Mesh(brG, rimM.clone());
            br.position.y = -1.15; br.rotation.x = Math.PI / 2;
            grp.add(br);
            
            const hp = [new THREE.Vector3(0.78, 0.80, 0), new THREE.Vector3(1.15, 0.68, 0), new THREE.Vector3(1.25, 0.30, 0), new THREE.Vector3(1.20, -0.15, 0), new THREE.Vector3(1.05, -0.52, 0), new THREE.Vector3(0.78, -0.62, 0)];
            const hc = new THREE.CatmullRomCurve3(hp);
            const hG = new THREE.TubeGeometry(hc, 48, 0.06, 16, false);
            const hM = new THREE.MeshPhysicalMaterial({ color: new THREE.Color(bgColor), roughness: 0.1, metalness: 0.1, clearcoat: 0.8 });
            const handle = new THREE.Mesh(hG, hM);
            handle.castShadow = true;
            grp.add(handle);
            
            grp.position.y = 0.2;
            return grp;
        }

        /* ===== رسم الـ Texture ===== */
        function rrect(x, rx, ry, rw, rh, r) { x.beginPath(); x.moveTo(rx+r, ry); x.lineTo(rx+rw-r, ry); x.quadraticCurveTo(rx+rw, ry, rx+rw, ry+r); x.lineTo(rx+rw, ry+rh-r); x.quadraticCurveTo(rx+rw, ry+rh, rx+rw-r, ry+rh); x.lineTo(rx+r, ry+rh); x.quadraticCurveTo(rx, ry+rh, rx, ry+rh-r); x.lineTo(rx, ry+r); x.quadraticCurveTo(rx, ry, rx+r, ry); x.closePath(); }

        function updateTex() {
            const c = cCtx, W = SZ, H = SZ;
            c.clearRect(0, 0, W, H);

            if (curType === 'tshirt') {
                if(grad){ const g = c.createLinearGradient(0,0,W,H); g.addColorStop(0,grad[0]); g.addColorStop(1,grad[1]); c.fillStyle=g; } else { c.fillStyle=bgColor; }
                c.fillRect(0, 0, W, H);
                drawEls(c, W, H);
            } else if (curType === 'cup') {
                c.fillStyle = '#0a0f1a'; c.fillRect(0,0,W,H);
                const aw = W * 0.82, ah = H * 0.85, ax = (W - aw) / 2, ay = (H - ah) / 2;
                c.save(); rrect(c, ax, ay, aw, ah, 14);
                if(grad){ const g = c.createLinearGradient(0,0,W,H); g.addColorStop(0,grad[0]); g.addColorStop(1,grad[1]); c.fillStyle=g; } else { c.fillStyle=bgColor; }
                c.fill(); rrect(c, ax, ay, aw, ah, 14); c.clip();
                drawEls(c, W, H);
                c.restore();
                rrect(c, ax, ay, aw, ah, 14); c.strokeStyle = 'rgba(255,255,255,0.04)'; c.lineWidth = 1; c.stroke();
            } else {
                if(grad){ const g = c.createLinearGradient(0,0,W,H); g.addColorStop(0,grad[0]); g.addColorStop(1,grad[1]); c.fillStyle=g; } else { c.fillStyle=bgColor; }
                c.fillRect(0, 0, W, H);
                drawEls(c, W, H);
            }
            if(cTex) cTex.needsUpdate = true;
            update2D();
        }

        function drawEls(c, W, H) {
            els.forEach((el, i) => {
                c.save();
                const cx = (el.x / 100) * W, cy = (el.y / 100) * H;
                c.globalAlpha = (el.opacity || 100) / 100;
                
                if (el.type === 'text') {
                    const fs = el.size * (W / 500);
                    c.font = `${el.weight} ${fs}px "${el.font}", Arial, sans-serif`;
                    c.textAlign = 'center'; c.textBaseline = 'middle';
                    c.translate(cx, cy); c.rotate((el.rotation || 0) * Math.PI / 180);
                    if(el.stroke){ c.strokeStyle=el.stroke; c.lineWidth=Math.max(2,fs*0.06); c.lineJoin='round'; c.strokeText(el.content,0,0); }
                    c.fillStyle = el.color; c.fillText(el.content, 0, 0);
                    
                    if (i === selIdx) {
                        const m = c.measureText(el.content), tw = m.width, th = fs;
                        c.strokeStyle = '#f97316'; c.lineWidth = 2.5; c.setLineDash([7, 4]); c.strokeRect(-tw/2-10, -th/2-6, tw+20, th+12); c.setLineDash([]);
                    }
                } else if (el.type === 'image' && el.img) {
                    c.translate(cx, cy); c.rotate((el.rotation || 0) * Math.PI / 180);
                    const iw = el.width * (W / 500), ih = el.height * (W / 500);
                    c.drawImage(el.img, -iw/2, -ih/2, iw, ih);
                    
                    if (i === selIdx) {
                        c.strokeStyle = '#f97316'; c.lineWidth = 2.5; c.setLineDash([7, 4]); c.strokeRect(-iw/2-5, -ih/2-5, iw+10, ih+10); c.setLineDash([]);
                    }
                }
                c.restore();
            });
        }

        function update2D(){
            const cv = document.getElementById('editor-canvas-2d');
            if(!cv) return;
            const x = cv.getContext('2d');
            x.clearRect(0, 0, cv.width, cv.height);
            x.drawImage(tCanvas, 0, 0, cv.width, cv.height);
        }

        /* ===== المحرر 2D والأحداث ===== */
        function init2D() {
            const cv = document.getElementById('editor-canvas-2d');
            let dragging = false, mode = 'none', di = -1, ox = 0, oy = 0, sw = 0, sh = 0, sdx = 0, sdy = 0;
            
            function gp(e){ const r = cv.getBoundingClientRect(); const cl = e.touches ? e.touches[0] : e; return { x: ((cl.clientX - r.left) / r.width) * 100, y: ((cl.clientY - r.top) / r.height) * 100 }; }
            
            function hitEl(mx, my, el) {
                if(el.type === 'text') return Math.abs(mx - el.x) < el.size * 1.5 && Math.abs(my - el.y) < el.size * 0.8;
                if(el.type === 'image') { const iw = (el.width / 500) * 100, ih = (el.height / 500) * 100; return Math.abs(mx - el.x) < iw / 2 && Math.abs(my - el.y) < ih / 2; }
                return false;
            }

            function down(e) {
                e.preventDefault(); const p = gp(e);
                for(let i = els.length - 1; i >= 0; i--) {
                    if(hitEl(p.x, p.y, els[i])) {
                        mode = 'drag'; di = i; ox = p.x - els[i].x; oy = p.y - els[i].y;
                        selElement(i); updateTex(); return;
                    }
                }
                selIdx = -1; document.getElementById('textProps').style.display = 'none'; document.getElementById('imgProps').style.display = 'none';
                renderTList(); renderIList(); updateTex();
            }

            function move(e) {
                e.preventDefault();
                if(mode === 'drag' && di >= 0) {
                    const p = gp(e); els[di].x = Math.max(2, Math.min(98, p.x - ox)); els[di].y = Math.max(2, Math.min(98, p.y - oy)); updateTex();
                }
                if(mode === 'none' && selIdx >= 0 && els[selIdx]) {
                    cv.style.cursor = hitEl(gp(e).x, gp(e).y, els[selIdx]) ? 'move' : 'default';
                }
            }

            function up() { mode = 'none'; di = -1; cv.style.cursor = 'default'; }
            
            cv.addEventListener('mousedown', down); cv.addEventListener('mousemove', move); cv.addEventListener('mouseup', up); cv.addEventListener('mouseleave', up);
            cv.addEventListener('touchstart', down, { passive: false }); cv.addEventListener('touchmove', move, { passive: false }); cv.addEventListener('touchend', up);
        }

        /* ===== الألوان ===== */
        function initColors(){
            const cg = document.getElementById('colorGrid'); cg.innerHTML = '';
            COLORS.forEach(c => {
                const s = document.createElement('div'); s.className = `c-sw ${c === bgColor ? 'act' : ''}`; s.style.background = c;
                if(isLightColor(c)) s.style.border = '2px solid rgba(255,255,255,.1)';
                s.onclick = () => { grad = null; bgColor = c; document.querySelectorAll('#colorGrid .c-sw, #gradientGrid .c-sw').forEach(x => x.classList.remove('act')); s.classList.add('act'); document.getElementById('customColorPicker').value = c; document.getElementById('customColorHex').value = c; updateTex(); updSides(); };
                cg.appendChild(s);
            });
            const gg = document.getElementById('gradientGrid'); gg.innerHTML = '';
            GRADS.forEach(g => {
                const s = document.createElement('div'); s.className = 'c-sw'; s.style.background = `linear-gradient(135deg, ${g[0]}, ${g[1]})`;
                s.onclick = () => { grad = g; bgColor = g[0]; document.querySelectorAll('#colorGrid .c-sw, #gradientGrid .c-sw').forEach(x => x.classList.remove('act')); s.classList.add('act'); updateTex(); updSides(); };
                gg.appendChild(s);
            });
            document.getElementById('customColorPicker').addEventListener('input', e => { grad = null; bgColor = e.target.value; document.getElementById('customColorHex').value = e.target.value; document.querySelectorAll('.c-sw').forEach(x => x.classList.remove('act')); updateTex(); updSides(); });
        }
        
        function applyCustomColor(h) { if(/^#[0-9a-fA-F]{6}$/.test(h)) { grad = null; bgColor = h; document.getElementById('customColorPicker').value = h; document.querySelectorAll('.c-sw').forEach(x => x.classList.remove('act')); updateTex(); updSides(); } }
        function updSides() { if(!curMesh || curType === 'tshirt' || curType === 'cup' || !Array.isArray(curMesh.material)) return; const c = new THREE.Color(bgColor); curMesh.material.forEach((m, i) => { if(i !== 4 && m.color) m.color.copy(c); }); }
        function isLightColor(h) { const c = h.replace('#', ''); return c.length === 6 && (parseInt(c.substr(0,2),16)*299 + parseInt(c.substr(2,2),16)*587 + parseInt(c.substr(4,2),16)*114)/1000 > 150; }

        /* ===== التبديلات والإجراءات ===== */
        function switchProduct(t, b) { document.querySelectorAll('.pt-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); createProduct(t); }
        function switchView(v, b) { document.querySelectorAll('.vm-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); document.getElementById('editor2dWrap').classList.toggle('active', v === '2d'); }
        function switchToolTab(t, b) { document.querySelectorAll('.t-tab').forEach(x => x.classList.remove('active')); b.classList.add('active'); document.querySelectorAll('.t-sec').forEach(x => x.classList.remove('active')); document.getElementById('tab-' + t).classList.add('active'); }
        function toggleAutoRotate() { autoRot = !autoRot; controls.autoRotate = autoRot; document.getElementById('autoRotateBtn').style.color = autoRot ? '#22c55e' : '#64748b'; }
        
        function updateDims() { 
            if(!curMesh) return; 
            const l = +(document.getElementById('dimL').value) || 30, w = +(document.getElementById('dimW').value) || 20, h = +(document.getElementById('dimH').value) || 15; 
            const mx = Math.max(l, w, h), s = 3 / mx; 
            if(curType === 'tshirt') curMesh.scale.set(s*l, s*h, 1); 
            else if(curType === 'cup') curMesh.scale.set(1, s*h, 1); 
            else curMesh.scale.set(s*w, s*h, s*l); // تصحيح بسيط للكرتون
        }

        function resetDesign() { els = []; selIdx = -1; bgColor = '#c9a87c'; grad = null; document.getElementById('textProps').style.display = 'none'; document.getElementById('imgProps').style.display = 'none'; document.getElementById('dimL').value = 20; document.getElementById('dimW').value = 15; document.getElementById('dimH').value = 10; document.getElementById('dimQty').value = 100; document.getElementById('dimNotes').value = ''; renderTList(); renderIList(); createProduct(curType); initColors(); showToast('تم إعادة التعيين'); }

        function showToast(t) { const s = document.getElementById('studioToast'); document.getElementById('toastMsg').textContent = t; s.classList.add('show'); setTimeout(() => s.classList.remove('show'), 3000); }

        /* ===== إدارة العناصر ===== */
        function addTextElement() { els.push({ type: 'text', content: 'نص جديد', x: 50, y: 45, size: 28, color: '#ffffff', font: 'Cairo', weight: 'bold', rotation: 0, opacity: 100, stroke: null }); selIdx = els.length - 1; renderTList(); document.getElementById('textProps').style.display = 'block'; updateTex(); showToast('أضف النص — حرّكه من المحرر'); }
        
        function updateSelectedText() { if(selIdx < 0 || els[selIdx]?.type !== 'text') return; const e = els[selIdx]; e.content = document.getElementById('textContent').value || 'نص'; e.size = +document.getElementById('textSize').value; e.color = document.getElementById('textColor').value; e.font = document.getElementById('textFont').value; e.weight = document.getElementById('textWeight').value; e.rotation = +document.getElementById('textRotation').value; e.opacity = +document.getElementById('textOpacity').value; e.stroke = document.getElementById('textStroke').checked ? 'rgba(0,0,0,0.5)' : null; document.getElementById('textSizeVal').textContent = e.size; document.getElementById('textOpacityVal').textContent = e.opacity + '%'; renderTList(); updateTex(); }
        
        function deleteElement(i) { els.splice(i, 1); if(selIdx === i) { selIdx = -1; document.getElementById('textProps').style.display = 'none'; document.getElementById('imgProps').style.display = 'none'; } else if(selIdx > i) selIdx--; renderTList(); renderIList(); updateTex(); }
        
        function selElement(i) { selIdx = i; const e = els[i]; if(e.type === 'text') { document.getElementById('textProps').style.display = 'block'; document.getElementById('textContent').value = e.content; document.getElementById('textSize').value = e.size; document.getElementById('textSizeVal').textContent = e.size; document.getElementById('textColor').value = e.color; document.getElementById('textFont').value = e.font; document.getElementById('textWeight').value = e.weight; document.getElementById('textRotation').value = e.rotation || 0; document.getElementById('textOpacity').value = e.opacity || 100; document.getElementById('textOpacityVal').textContent = (e.opacity || 100) + '%'; document.getElementById('textStroke').checked = !!e.stroke; } else if(e.type === 'image') { document.getElementById('imgProps').style.display = 'block'; document.getElementById('imgW').value = Math.round(e.width); document.getElementById('imgWVal').textContent = Math.round(e.width); document.getElementById('imgOpacity').value = e.opacity || 100; } renderTList(); renderIList(); updateTex(); }
        
        function renderTList() { const c = document.getElementById('textList'); c.innerHTML = ''; els.forEach((e, i) => { if(e.type !== 'text') return; const d = document.createElement('div'); d.className = `el-item ${i === selIdx ? 'sel' : ''}`; d.innerHTML = `<div style="width:28px;height:28px;border-radius:6px;background:${e.color};display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="fas fa-font" style="color:${isLightColor(e.color)?'#000':'#fff'};font-size:10px;"></i></div><div class="el-info"><span>${e.content.substring(0,16)}</span><small>${e.size}px</small></div><button class="del-el" onclick="event.stopPropagation();deleteElement(${i})"><i class="fas fa-trash"></i></button>`; d.onclick = () => selElement(i); c.appendChild(d); }); }
        
        function renderIList() { const c = document.getElementById('imageList'); c.innerHTML = ''; els.forEach((e, i) => { if(e.type !== 'image') return; const d = document.createElement('div'); d.className = `el-item ${i === selIdx ? 'sel' : ''}`; d.innerHTML = `<div style="width:36px;height:36px;border-radius:6px;overflow:hidden;background:#1e293b;flex-shrink:0;"><img src="${e.imgSrc}" style="width:100%;height:100%;object-fit:cover;"></div><div class="el-info"><span>صورة ${i+1}</span></div><button class="del-el" onclick="event.stopPropagation();deleteElement(${i})"><i class="fas fa-trash"></i></button>`; d.onclick = () => selElement(i); c.appendChild(d); }); }

        function handleImageUpload(ev) {
            const f = ev.target.files[0]; if(!f) return;
            const r = new FileReader();
            r.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    let w = img.width, h = img.height; const mx = 300;
                    if(w > mx || h > mx) { const r2 = Math.min(mx/w, mx/h); w *= r2; h *= r2; }
                    els.push({ type: 'image', img, imgSrc: e.target.result, x: 50, y: 50, width: w, height: h, origW: w, origH: h, rotation: 0, opacity: 100 });
                    selIdx = els.length - 1; renderIList(); document.getElementById('imgProps').style.display = 'block'; updateTex(); showToast('تم رفع الصورة — حرّكها من المحرر');
                }; img.src = e.target.result;
            }; r.readAsDataURL(f); ev.target.value = '';
        }

        function updateSelectedImage() { if(selIdx < 0 || els[selIdx]?.type !== 'image') return; const e = els[selIdx]; e.width = +document.getElementById('imgW').value; e.opacity = +document.getElementById('imgOpacity').value; document.getElementById('imgWVal').textContent = Math.round(e.width); updateTex(); }

        /* ===== الإرسال ===== */
        function sendDesignWhatsApp() {
            const qty = document.getElementById('dimQty').value, l = document.getElementById('dimL').value, w = document.getElementById('dimW').value, h = document.getElementById('dimH').value, notes = document.getElementById('dimNotes').value, er = document.getElementById('studioError');
            if(!qty || +qty < 1) { er.textContent = 'أدخل الكمية'; er.style.display = 'block'; return; }
            er.style.display = 'none';
            let m = `مرحباً برنتنس 👋\nتصميم مخصص:\n\n📦 *المنتج:* ${PNAMES[curType]}\n🎨 *اللون:* ${bgColor}${grad ? ` تدرج` : ''}\n`;
            const tx = els.filter(e => e.type === 'text');
            if(tx.length) { m += `✏️ *النصوص:*\n`; tx.forEach((t, i) => { m += `   ${i+1}. "${t.content}" — ${t.size}px — ${t.color}\n`; }); }
            const ix = els.filter(e => e.type === 'image');
            if(ix.length) m += `🖼️ *صور:* ${ix.length} صورة\n`;
            if(curType !== 'tshirt' && curType !== 'cup') m += `\n📏 *المقاسات:* ${l}×${w}×${h} سم\n`;
            m += `🔢 *الكمية:* ${qty}\n`; if(notes) m += `📝 *ملاحظات:* ${notes}\n`;
            m += `\nالتسعيرة؟ شكراً!`;
            window.open(`https://wa.me/${waNumber}?text=${encodeURIComponent(m)}`, '_blank');
        }

        /* ===== ربط الدوال بالواجهة ===== */
        window.openDesignStudio = function() {
            document.getElementById('designStudioModal').classList.add('open');
            document.body.style.overflow = 'hidden';
            const ld = document.getElementById('studioLoader');
            ld.classList.remove('hidden');
            setTimeout(() => {
                if(!inited) { init(); init2D(); initColors(); } else { onRS(); initColors(); }
                setTimeout(() => ld.classList.add('hidden'), 350);
            }, 120);
        };
        window.closeDesignStudio = function() { document.getElementById('designStudioModal').classList.remove('open'); document.body.style.overflow = 'auto'; };
        
        // توجيه الدوال للمساحة العالمية للوصول من الـ HTML
        window.switchProduct = switchProduct; window.switchView = switchView; window.switchToolTab = switchToolTab; window.toggleAutoRotate = toggleAutoRotate; window.updateDims = updateDims; window.addTextElement = addTextElement; window.updateSelectedText = updateSelectedText; window.deleteElement = deleteElement; window.handleImageUpload = handleImageUpload; window.updateSelectedImage = updateSelectedImage; window.applyCustomColor = applyCustomColor; window.sendDesignWhatsApp = sendDesignWhatsApp; window.resetDesign = resetDesign; window.downloadDesign = function(){ const a=document.createElement('a');a.download='printnes-design.png';a.href=tCanvas.toDataURL('image/png');a.click();showToast('تم تحميل التصميم كصورة'); };

        document.getElementById('designStudioModal').addEventListener('click', e => { if (e.target === document.getElementById('designStudioModal')) closeDesignStudio(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDesignStudio(); });

    </script>
}