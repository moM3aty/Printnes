                            <div class="dim-grp"><label>الارتفاع / العمق</label><input type="number" id="dimH" value="10" min="1" max="200" oninput="updateDimensions()"></div>
                        </div>
                        <div class="t-grp"><label class="t-lbl">الكمية المطلوبة لتسعيرها</label><input type="number" id="dimQty" class="t-inp" placeholder="مثال: 500" min="1" value="100"></div>
                        <div class="t-grp"><label class="t-lbl">ملاحظات إضافية (اختياري)</label><textarea id="dimNotes" class="t-inp" rows="3" placeholder="اكتب أي ملاحظات للطباعة..." style="resize:vertical;"></textarea></div>
                        <button class="s-btn s-btn-wa" onclick="sendDesignWhatsApp()" style="width:100%;padding:14px;font-size:14px;border-radius:11px;margin-top:10px;justify-content:center;">
