<!-- الملف: Views/Home/Index.cshtml -->
@model IEnumerable<Printnes.Models.Product>
@using Printnes.Data
@using Microsoft.EntityFrameworkCore
@using Printnes.Helpers
@inject ApplicationDbContext DbContext

@{
    ViewData["Title"] = "الصفحة الرئيسية";
    var siteSettings = SiteSettingsManager.LoadSettings();
    string waNumber = siteSettings.WhatsappNumber?.Replace("+", "") ?? "";
    var activeBanners = ViewBag.ActiveBanners as List<Printnes.Models.Banner>;
    var mainCategories = ViewBag.MainCategories as List<Printnes.Models.Category>;
}

<style>
    /* ==========================================
           تنسيقات البانر الترويجي للستوديو في الصفحة الرئيسية
           ========================================== */
    @@keyframes pulseDot {
        0%, 100%

    {
        opacity: 1;
        transform: scale(1);
    }

    50% {
        opacity: 0.4;
        transform: scale(1.5);
    }

    }

    @@keyframes floatBox {
        0%, 100%

    {
        transform: translateY(0) rotate(0deg);
    }

    50% {
        transform: translateY(-12px) rotate(2deg);
    }

    }

    @@keyframes rotateIcon {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }
</style>

<main class="container">
    <!-- البانرات المتحركة -->
    <section class="hero-slider-wrapper">
        <div class="swiper hero-swiper">
            <div class="swiper-wrapper">
                @if (activeBanners != null && activeBanners.Any())
                {
                    foreach (var banner in activeBanners)
                    {
                        <div class="swiper-slide">
                            <a href="@(string.IsNullOrEmpty(banner.LinkUrl) ? "#" : banner.LinkUrl)">
                                <img src="@banner.ImageUrl" alt="@banner.Title" class="full-banner-img">
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="swiper-slide">
                        <a href="#">
                            <img src="https://cdn.salla.sa/form-builder/wzsdRwVsUbNJVFVyQS6oTkganoSdKqnn1KADKYWk.png" alt="بانر افتراضي" class="full-banner-img">
                        </a>
                    </div>
                }
            </div>
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-pagination"></div>
        </div>
    </section>

    <!-- الأقسام الرئيسية -->
    <section class="main-categories">
        <div class="section-title-box">
            <h2>الأقسام الرئيسية</h2>
            <p>حرك القائمة لليسار لعرض جميع الأقسام</p>
        </div>
        <div class="categories-scroll">
            <div class="cat-card" onclick="location.href='/Packages'">
                <div class="circle-img">
                    <img src="https://cdn.salla.sa/form-builder/PD53rr1LUNb19Hj3je9ULKSfhYUGg0o3TOBdz1T7.png" alt="العروض">
                </div>
                <h4>العروض والبكجات</h4>
            </div>

            @if (mainCategories != null)
            {
                foreach (var cat in mainCategories)
                {
                    string catImage = !string.IsNullOrEmpty(cat.ImageUrl) ? cat.ImageUrl : "https://cdn.salla.sa/form-builder/lnB9NCS8slVsu7xfA6j6Ka37ZIEGCnEu9de9JiR3.png";
                    <div class="cat-card" onclick="location.href='/Category/@cat.Slug'">
                        <div class="circle-img">
                            <img src="@catImage" alt="@cat.NameAr">
                        </div>
                        <h4>@cat.NameAr</h4>
                    </div>
                }
            }
        </div>
    </section>

    <!-- بانر الدخول إلى ستوديو التصميم 3D -->
    <section class="custom-box-banner" style="margin: 40px 0;">
        <div style="background: linear-gradient(135deg, #080d18 0%, #1e293b 50%, #080d18 100%); border-radius: 28px; padding: 46px 38px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 28px; position: relative; overflow: hidden; border: 1px solid rgba(249,115,22,0.08);">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(249,115,22,0.3), transparent);"></div>
            <i class="fas fa-cube" style="position: absolute; right: -40px; top: -40px; font-size: 240px; color: rgba(249,115,22,0.025); transform: rotate(15deg);"></i>

            <div style="color: #fff; max-width: 580px; position: relative; z-index: 2;">
                <div style="display: inline-flex; align-items: center; gap: 7px; background: rgba(249,115,22,0.1); padding: 4px 13px; border-radius: 18px; margin-bottom: 14px; border: 1px solid rgba(249,115,22,0.18);">
                    <span style="width: 5px; height: 5px; background: #f97316; border-radius: 50%; animation: pulseDot 1.5s infinite;"></span>
                    <span style="font-size: 10px; color: #f97316; font-weight: 800; letter-spacing: 1px;">ستوديو ثلاثي الأبعاد</span>
                </div>
                <h2 style="font-size: 32px; font-weight: 900; margin-bottom: 12px; line-height: 1.3;">صمّم منتجك <span style="color: #f97316;">بالحجم الحقيقي</span></h2>
                <p style="font-size: 13px; line-height: 1.9; margin-bottom: 26px; color: #475569;">كراتين، تيشيرتات، أكواب — معاينة 3D لحظية مع تحكم كامل بالنصوص والصور والألوان.</p>

                <!-- هنا تم التعديل: الزر أصبح رابط يوجه لصفحة الستوديو -->
                <a href="/Studio" style="text-decoration: none; background: linear-gradient(135deg, #f97316, #dc2626); color: #fff; border: none; padding: 13px 30px; font-size: 14px; border-radius: 13px; font-weight: 800; cursor: pointer; display: inline-flex; align-items: center; gap: 9px; box-shadow: 0 8px 28px rgba(249,115,22,0.25); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                    <i class="fas fa-wand-magic-sparkles"></i> ادخل الستوديو
                </a>
            </div>

            <div style="position: relative; z-index: 2;">
                <div style="width: 230px; height: 230px; border-radius: 22px; background: linear-gradient(135deg, rgba(249,115,22,0.07), rgba(249,115,22,0.015)); border: 1px solid rgba(249,115,22,0.08); display: flex; align-items: center; justify-content: center; animation: floatBox 4s ease-in-out infinite;">
                    <i class="fas fa-cube" style="font-size: 80px; color: #f97316; opacity: 0.4; animation: rotateIcon 8s linear infinite;"></i>
                </div>
            </div>
        </div>
    </section>

    <!-- المنتجات المميزة -->
    <section class="products-slider-section">
        <div class="section-header">
            <div class="right-side">
                <h2 class="section-title">الأكثر مبيعاً / مميز</h2>
            </div>
            <div class="left-side">
                <a href="/Products" class="view-all">عرض الكل</a>
                <div class="slider-controls">
                    <div class="swiper-button-prev-prod"><i class="fas fa-chevron-right"></i></div>
                    <div class="swiper-button-next-prod"><i class="fas fa-chevron-left"></i></div>
                </div>
            </div>
        </div>
        <div class="swiper most-selling-swiper">
            <div class="swiper-wrapper" id="featured-products-slider">
                @if (Model != null && Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <div class="swiper-slide">
                            <div class="product-card">
                                <div class="p-badge">منتج مميز</div>
                                <div class="wish-icon fav-btn-element" data-product-id="@product.Id" onclick="handleFavoriteToggle(@product.Id, this, '@product.NameAr.Replace("'", "\\'")', '@product.CoverImageUrl')" style="cursor: pointer; z-index: 5;">
                                    <i class="far fa-heart"></i>
                                </div>
                                <img src="@product.CoverImageUrl" alt="@product.NameAr" onclick="location.href='/Products/Details/@product.Id'" style="cursor:pointer;">
                                <div class="p-info">
                                    <h3 onclick="location.href='/Products/Details/@product.Id'" style="cursor:pointer;">@product.NameAr</h3>
                                    <p class="p-desc" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@(string.IsNullOrEmpty(product.DescriptionAr) ? "منتج عالي الجودة" : product.DescriptionAr)</p>
                                    <span class="p-price">السعر حسب الاختيارات</span>
                                    <button class="add-to-cart-orange" onclick="location.href='/Products/Details/@product.Id'">
                                        عرض التفاصيل <i class="fas fa-arrow-left"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <section class="product-group">
        <div class="group-header">
            <h2>بوكسات</h2> <a href="/Category/boxes">عرض الكل</a>
        </div>
        <div class="products-grid" id="render-boxes"></div>
    </section>

    <section class="product-group">
        <div class="group-header">
            <h2>مطبوعات ورقية</h2> <a href="/Category/paperprints">عرض الكل</a>
        </div>
        <div class="products-grid" id="render-paperprints"></div>
    </section>

    <section class="product-group">
        <div class="group-header">
            <h2>استيكرات</h2> <a href="/Category/stickers">عرض الكل</a>
        </div>
        <div class="products-grid" id="render-stickers"></div>
    </section>

    <!-- إحصائيات -->
    <section class="premium-stats">
        <div class="container">
            <div class="section-header-right">
                <h2 class="orange-line-title">لماذا برنتنس ؟!</h2>
            </div>
            <div class="stats-container">
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="far fa-user-circle"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+8000</span>
                        <p class="stat-desc">عميل جرب منتجاتنا</p>
                    </div>
                </div>
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="fas fa-location-arrow"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+500</span>
                        <p class="stat-desc">شحنة دولية ناجحة</p>
                    </div>
                </div>
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="far fa-envelope-open"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+160000</span>
                        <p class="stat-desc">رسالة رددنا عليها</p>
                    </div>
                </div>
                <div class="stat-card-new">
                    <div class="icon-circle-navy"><i class="fas fa-store-alt"></i></div>
                    <div class="stat-content">
                        <span class="stat-num">+700</span>
                        <p class="stat-desc">متجر يستفيد شهرياً</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- الأسئلة الشائعة -->
    <section class="faq-section mb-5">
        <div class="container">
            <div class="section-title-wrapper">
                <h2 class="orange-title">الأسئلة الشائعة</h2>
            </div>
            <div class="faq-grid">
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>هل يمكنني تغيير طلبي ؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>نعم يمكنك التعديل خلال 24 ساعة من الطلب.</p>
                    </div>
                </div>
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>كيف أطلب من الموقع ؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>أضف بياناتك من صفحة المنتج أو تواصل معنا واتساب.</p>
                    </div>
                </div>
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>هل يمكن تعديل بياناتي؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>نعم عبر التواصل معنا ويتم التعديل فورياً.</p>
                    </div>
                </div>
                <div class="faq-item" onclick="toggleFaq(this)">
                    <div class="faq-question">
                        <div class="faq-btn"><i class="fas fa-plus"></i></div>
                        <span>هل تعملون أفكار خارج الموقع ؟</span>
                    </div>
                    <div class="faq-answer">
                        <p>نعم شاركنا فكرتك وسيتم دراستها وتنفيذها.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // تفعيل الأقسام الديناميكية
            if (typeof renderSection === "function") {
                renderSection("boxes", "render-boxes");
                renderSection("paperprints", "render-paperprints");
                renderSection("stickers", "render-stickers");
            }

            // تفعيل السلايدر
            if (typeof Swiper !== 'undefined') {
                new Swiper('.hero-swiper', {
                    loop: true,
                    pagination: { el: '.swiper-pagination', clickable: true },
                    navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
                    autoplay: { delay: 5000, disableOnInteraction: false }
                });

                new Swiper('.most-selling-swiper', {
                    slidesPerView: 2,
                    spaceBetween: 15,
                    navigation: { nextEl: '.swiper-button-next-prod', prevEl: '.swiper-button-prev-prod' },
                    breakpoints: {
                        768: { slidesPerView: 3, spaceBetween: 20 },
                        1024: { slidesPerView: 4, spaceBetween: 25 }
                    }
                });
            }
        });
    </script>
}