<!--
    الملف: Views/Order/Success.cshtml
    تم ربط رقم الواتساب ديناميكياً بإعدادات المتجر
-->
@using Printnes.Helpers
@{
    ViewData["Title"] = "تم استلام الطلب بنجاح";
    Layout = "_Layout";

    // جلب الإعدادات ديناميكياً
    var siteSettings = SiteSettingsManager.LoadSettings();
    string waNumber = siteSettings.WhatsappNumber?.Replace("+", "") ?? "";
}

<main class="container" style="padding: 60px 15px; min-height: 70vh; display: flex; align-items: center; justify-content: center;">
    <div style="width: 100%; max-width: 600px; text-align: center; background: #fff; border-radius: 24px; box-shadow: 0 20px 60px rgba(0,0,0,0.05); border: 1px solid #f0f0f0; padding: 50px 30px;">

        <!-- أيقونة النجاح -->
        <div style="width: 100px; height: 100px; background: #ecfdf5; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; box-shadow: 0 10px 25px rgba(16, 185, 129, 0.2);">
            <i class="fas fa-check" style="font-size: 45px; color: #10b981;"></i>
        </div>

        <h1 style="color: var(--navy); font-size: 28px; font-weight: 900; margin-bottom: 10px;">شكراً لك! تم استلام طلبك بنجاح</h1>
        <p style="color: #666; font-size: 15px; margin-bottom: 20px; line-height: 1.6;">
            رقم طلبك هو: <strong style="color: var(--orange); font-size: 18px; display: inline-block; margin: 0 5px; padding: 5px 15px; background: #fff5f2; border-radius: 8px;">@ViewBag.OrderNumber</strong>
        </p>

        <!-- تأكيد الحفظ في قاعدة البيانات -->
        <div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 30px; background: #f0fdf4; color: #166534; padding: 10px 20px; border-radius: 50px; width: fit-content; margin-left: auto; margin-right: auto; font-weight: 700; border: 1px solid #bbf7d0;">
            <i class="fas fa-database"></i> تم حفظ الطلب بنجاح في قاعدة بيانات المتجر
        </div>

        <!-- خطوة الواتساب -->
        <div style="background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 16px; padding: 25px; margin-bottom: 30px;">
            <h3 style="font-size: 16px; color: var(--navy); font-weight: 800; margin-bottom: 10px;">
                <i class="fas fa-exclamation-circle" style="color: #f59e0b; margin-left: 5px;"></i> خطوة أخيرة ومهمة!
            </h3>
            <p style="font-size: 14px; color: #555; margin-bottom: 20px;">
                لضمان سرعة التنفيذ، الرجاء إرسال تفاصيل الطلب لإدارة المبيعات والتصميم عبر الواتساب وتزويدهم بملفات الطباعة (إن وجدت).
            </p>

            <!-- الزر الذي يجمع السلة ويرسلها للواتساب -->
            <button id="sendToWaBtn" onclick="generateAndSendWhatsApp('@ViewBag.OrderNumber')" style="width: 100%; padding: 16px; background: #25d366; color: #fff; border: none; border-radius: 12px; font-family: inherit; font-size: 16px; font-weight: 800; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 10px 20px rgba(37, 211, 102, 0.3);"
                    onmouseover="this.style.background='#128c7e'; this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.background='#25d366'; this.style.transform='none'">
                <i class="fab fa-whatsapp" style="font-size: 22px;"></i> أرسل الطلب لإدارة المتجر
            </button>
        </div>

        <a href="/" style="color: var(--navy); font-weight: 700; text-decoration: none; font-size: 15px; display: inline-block; transition: 0.3s;" onmouseover="this.style.color='var(--orange)'" onmouseout="this.style.color='var(--navy)'">
            العودة للصفحة الرئيسية <i class="fas fa-arrow-left" style="font-size: 12px; margin-right: 5px;"></i>
        </a>
    </div>
</main>

@section Scripts {
    <script>
        let savedCartForWa = [];

        document.addEventListener("DOMContentLoaded", function() {
            // أخذ نسخة من السلة قبل مسحها
            savedCartForWa = JSON.parse(localStorage.getItem('printnesCart')) || [];

            // مسح السلة من المتصفح لأن الطلب تم بنجاح بالفعل في قاعدة البيانات
            localStorage.removeItem('printnesCart');

            // تصفير العداد في الهيدر إن وجد
            const badge = document.getElementById('cart-count');
            if (badge) badge.innerText = "0";
        });

        function generateAndSendWhatsApp(orderNumber) {
            let message = `مرحباً @siteSettings.StoreName 👋\nأتممت الطلب رقم: *${orderNumber}*\n\n`;
            message += `📦 *تفاصيل المنتجات:*\n`;
            message += `━━━━━━━━━━━━━\n`;

            let total = 0;
            if(savedCartForWa.length > 0){
                savedCartForWa.forEach((item, index) => {
                    let itemQty = item.quantity || 1;
                    let itemPrice = parseFloat(item.price) * itemQty;
                    total += itemPrice;

                    message += `${index + 1}. *${item.name}*\n`;
                    message += `   - الكمية: ${itemQty}\n`;

                    if(item.details) {
                        if(item.details.paperType) message += `   - الورق: ${item.details.paperType}\n`;
                        if(item.details.sides) message += `   - الأوجه: ${item.details.sides}\n`;
                        if(item.details.cover) message += `   - الحماية: ${item.details.cover}\n`;
                    }
                    message += `\n`;
                });

                let shipping = parseFloat('@siteSettings.DefaultShippingCost');
                let taxRate = parseFloat('@siteSettings.TaxPercentage') / 100;
                let tax = (total + shipping) * taxRate;
                let finalTotal = total + shipping + tax;

                message += `━━━━━━━━━━━━━\n`;
                message += `💰 المجموع الفرعي: ${total.toFixed(2)} @siteSettings.Currency\n`;
                message += `💵 *الإجمالي (مع الشحن والضريبة): ${finalTotal.toFixed(2)} @siteSettings.Currency*\n\n`;
            } else {
                message += `تم إرسال الطلب مسبقاً للوحة التحكم.\n`;
            }

            message += `الرجاء تأكيد الطلب وتزويدي بالتفاصيل المتبقية.`;

            // رقم الإدارة من الإعدادات الديناميكية
            const adminPhone = "@waNumber";

            // فتح الواتساب
            const waUrl = `https://wa.me/${adminPhone}?text=${encodeURIComponent(message)}`;
            window.open(waUrl, '_blank');

            // تغيير شكل الزر
            const btn = document.getElementById('sendToWaBtn');
            btn.innerHTML = '<i class="fas fa-check-double"></i> تم الفتح في الواتساب';
            btn.style.background = '#1e293b';
            btn.style.boxShadow = 'none';
        }
    </script>
}