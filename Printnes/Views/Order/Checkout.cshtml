<!-- الملف: Views/Order/Checkout.cshtml -->
@model Printnes.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "إتمام الطلب";
    Layout = "_Layout";
}

<div class="category-header-bar" style="background: linear-gradient(90deg, var(--navy) 0%, #2a4b91 100%); padding: 30px 0; position: relative; overflow: hidden;">
    <div class="container" style="position: relative; z-index: 2;">
        <h1 style="color: #fff; font-size: 32px; font-weight: 900; margin-bottom: 10px; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">إتمام الطلب</h1>
        <nav class="breadcrumb-white" style="font-size: 14px; opacity: 0.9;">
            <a href="/" style="color: #fff; text-decoration: none;"><i class="fas fa-home"></i> الرئيسية</a> <span>/</span>
            <a href="/Cart" style="color: #fff; text-decoration: none;">سلة المشتريات</a> <span>/</span>
            <strong style="color: var(--orange);">إتمام الطلب</strong>
        </nav>
    </div>
</div>

<main class="container py-5">
    <div class="shop-controls">
        <h2 class="orange-line-title">معلومات الشحن والدفع</h2>
    </div>

    <div class="product-details-wrapper" style="flex-direction: row-reverse;">
        <!-- ملخص الطلب الجانبي -->
        <div class="product-info-side" style="flex: 1; background: #f9f9f9; padding: 25px; border-radius: 15px;">
            <h3 style="color: var(--navy); margin-bottom: 20px;">ملخص الطلب</h3>
            <div id="checkout-summary-items">
                <!-- سيتم تعبئته بواسطة الجافاسكريبت -->
            </div>
            <hr style="border-color: #eee; margin: 20px 0;">
            <div style="display: flex; justify-content: space-between; font-size: 18px; font-weight: bold; color: var(--orange);">
                <span>الإجمالي:</span>
                <span id="checkout-total">0 ر.س</span>
            </div>
        </div>

        <!-- فورم بيانات العميل -->
        <div class="product-image-side" style="flex: 2;">
            <form asp-action="Checkout" method="post" id="checkoutForm" class="options-body" style="background: #fff; padding: 30px; border-radius: 15px; border: 1px solid #eee;">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="color: red; margin-bottom: 15px;"></div>

                <!-- حقل مخفي يحتوي على بيانات السلة -->
                <input type="hidden" asp-for="CartItemsJson" id="CartItemsJson" />

                <div class="form-group" style="margin-bottom: 15px;">
                    <label asp-for="CustomerName" style="display: block; font-weight: bold; margin-bottom: 5px;">الاسم الكامل *</label>
                    <input asp-for="CustomerName" class="form-control" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px;" placeholder="اكتب اسمك الثلاثي" />
                    <span asp-validation-for="CustomerName" style="color: red; font-size: 12px;"></span>
                </div>

                <div style="display: flex; gap: 15px; margin-bottom: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="CustomerPhone" style="display: block; font-weight: bold; margin-bottom: 5px;">رقم الجوال *</label>
                        <input asp-for="CustomerPhone" class="form-control" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px;" placeholder="05XXXXXXXX" />
                        <span asp-validation-for="CustomerPhone" style="color: red; font-size: 12px;"></span>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="CustomerEmail" style="display: block; font-weight: bold; margin-bottom: 5px;">البريد الإلكتروني</label>
                        <input asp-for="CustomerEmail" class="form-control" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px;" placeholder="example@domain.com" />
                    </div>
                </div>

                <div style="display: flex; gap: 15px; margin-bottom: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="City" style="display: block; font-weight: bold; margin-bottom: 5px;">المدينة *</label>
                        <input asp-for="City" class="form-control" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px;" />
                        <span asp-validation-for="City" style="color: red; font-size: 12px;"></span>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="District" style="display: block; font-weight: bold; margin-bottom: 5px;">الحي</label>
                        <input asp-for="District" class="form-control" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px;" />
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 15px;">
                    <label asp-for="Address" style="display: block; font-weight: bold; margin-bottom: 5px;">العنوان بالتفصيل *</label>
                    <textarea asp-for="Address" rows="3" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; resize: none;"></textarea>
                    <span asp-validation-for="Address" style="color: red; font-size: 12px;"></span>
                </div>

                <div class="form-group" style="margin-bottom: 25px;">
                    <label asp-for="PaymentMethod" style="display: block; font-weight: bold; margin-bottom: 5px;">طريقة الدفع *</label>
                    <select asp-for="PaymentMethod" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px;">
                        <option value="1">بطاقة مدى</option>
                        <option value="2">البطاقة الائتمانية (Visa/Mastercard)</option>
                        <option value="3">Apple Pay</option>
                        <option value="4">تحويل بنكي</option>
                    </select>
                </div>

                <button type="submit" class="btn-add-main" style="width: 100%; font-size: 18px; padding: 15px; border-radius: 8px; border: none; background: var(--orange); color: #fff; font-weight: bold; cursor: pointer;">
                    تأكيد الطلب والدفع <i class="fas fa-check-circle" style="margin-right: 5px;"></i>
                </button>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const cart = JSON.parse(localStorage.getItem('printnesCart')) || [];
            if(cart.length === 0) {
                alert("سلتك فارغة، سيتم توجيهك للرئيسية.");
                window.location.href = "/";
                return;
            }

            // تخزين الـ JSON في الحقل المخفي
            document.getElementById('CartItemsJson').value = JSON.stringify(cart);

            // عرض ملخص الطلب
            const summaryContainer = document.getElementById('checkout-summary-items');
            let total = 0;
            let html = "";

            cart.forEach(item => {
                // === التعديل: دعم السعر الجديد (unitPrice) والقديم (price) ===
                let pricePerUnit = parseFloat(item.unitPrice || item.price || 0);
                let quantity = parseInt(item.quantity || 1);
                let itemTotal = parseFloat(item.totalPrice || (pricePerUnit * quantity));
                total += itemTotal;

                // تجهيز التفاصيل
                let detailsText = "";
                if (item.SelectedOptionsJson) {
                    try {
                        let opts = JSON.parse(item.SelectedOptionsJson);
                        if (opts["المقاس"]) detailsText += ` | ${opts["المقاس"]}`;
                        if (opts["الخامة"]) detailsText += ` | ${opts["الخامة"]}`;
                    } catch(e) {}
                }

                html += `<div style="display:flex; justify-content:space-between; margin-bottom:10px; font-size:14px; border-bottom:1px solid #eee; padding-bottom:5px;">
                            <div>
                                <strong>${item.name}</strong>
                                <div style="font-size:12px; color:#888; font-weight:normal;">الكمية: ${quantity} ${detailsText}</div>
                            </div>
                            <strong style="white-space:nowrap;">${itemTotal.toFixed(2)} ر.س</strong>
                         </div>`;
            });

            summaryContainer.innerHTML = html;
            document.getElementById('checkout-total').innerText = total.toFixed(2) + " ر.س";
        });
    </script>
}