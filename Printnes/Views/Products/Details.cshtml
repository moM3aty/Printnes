@model Printnes.Models.Product
@using Printnes.Helpers
@{
    ViewData["Title"] = Model != null ? Model.NameAr : "تفاصيل المنتج";
    Layout = "_Layout";

    // جلب الإعدادات ديناميكياً
    var siteSettings = SiteSettingsManager.LoadSettings();
    string waNumber = siteSettings.WhatsappNumber?.Replace("+", "") ?? "";
    bool hasAnyOptions = !Model.IsReadyProduct && ((ViewBag.PaperOptions != null && ((ViewBag.PaperOptions != null && Enumerable.Count(ViewBag.PaperOptions) > 0) ||
                         (ViewBag.SizeOptions != null && Enumerable.Count(ViewBag.SizeOptions) > 0) ||
                         (ViewBag.SidesOptions != null && Enumerable.Count(ViewBag.SidesOptions) > 0))));


    var approvedReviews = Model?.ProductReviews?.Where(r => r.IsApproved).OrderByDescending(r => r.CreatedAt).ToList() ?? new List<Printnes.Models.ProductReview>();
    int reviewsCount = approvedReviews.Count;
    double avgRating = reviewsCount > 0 ? approvedReviews.Average(r => r.Rating) : 5.0;
}

<main class="container py-5">
    <nav class="breadcrumb">
        <a href="/">الرئيسية</a> &gt;
        <span id="breadcrumb-cat">@(Model != null ? Model.Category?.NameAr : "القسم")</span> &gt;
        <span id="breadcrumb-name">@(Model != null ? Model.NameAr : "اسم المنتج")</span>
    </nav>

    <div class="product-details-wrapper">
        <div class="product-image-side">
            <div class="main-img-holder">
                <img id="main-product-img" src="@(Model != null ? Model.CoverImageUrl : "")" alt="@(Model?.NameAr)">
            </div>
        </div>

        <div class="product-info-side">
            <h1 id="product-title" style="display: flex; align-items: flex-start; justify-content: space-between; gap: 15px;">
                <span>@(Model != null ? Model.NameAr : "اسم المنتج")</span>
                @if (Model != null)
                {
                    <button type="button" class="fav-btn-element" data-product-id="@Model.Id" onclick="handleFavoriteToggle(@Model.Id, this, '@Model.NameAr.Replace("'", "\\'")', '@Model.CoverImageUrl')"
                            style="background: #f8faff; border: 1px solid #e2e8f0; border-radius: 50%; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; color: #cbd5e1; flex-shrink: 0; transition: 0.3s;"
                            onmouseover="this.style.borderColor='var(--orange)'" onmouseout="this.style.borderColor='#e2e8f0'">
                        <i class="far fa-heart"></i>
                    </button>
                }
            </h1>

            <div class="rating-stars" style="display: flex; align-items: center; gap: 5px; margin-bottom: 15px;">
                <div style="color: #f59e0b; font-size: 14px;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(avgRating))
                        {
                            <i class="fas fa-star"></i>
                        }
                        else
                        {

                            <i class="far fa-star"></i>
                        }
                    }
                </div>
                <span style="color: var(--text-muted); font-size: 13px; font-weight: 600;">(@Math.Round(avgRating, 1)) من @reviewsCount تقييم</span>
            </div>

            <div class="short-desc" id="product-short-desc">
                @(Model != null && !string.IsNullOrEmpty(Model.DescriptionAr) ? Model.DescriptionAr : "وصف مختصر للمنتج.")
            </div>

            <div class="options-container">
                <div class="options-tabs">
                    <button class="tab-btn active">خيارات الطباعة والتفاصيل</button>
                </div>

                <div class="options-body">
                    @if (hasAnyOptions)
                    {
                        @if (ViewBag.PaperOptions != null && Enumerable.Count(ViewBag.PaperOptions) > 0)
                        {
                            <div class="form-group">
                                <label>نوع الورق *</label>
                                <select id="opt-paper" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;" onchange="calculateDynamicPrice()">
                                    <option value="">-- اختر --</option>
                                    @foreach (var opt in ViewBag.PaperOptions)
                                    {
                                        <option value="@opt.Id">@opt.NameAr</option>
                                    }
                                </select>
                            </div>
                        }

                        @if (ViewBag.SizeOptions != null && Enumerable.Count(ViewBag.SizeOptions) > 0)
                        {
                            <div class="form-group">
                                <label>المقاس *</label>
                                <select id="opt-size" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;" onchange="handleSizeChange()">
                                    <option value="">-- اختر --</option>
                                    @foreach (var opt in ViewBag.SizeOptions)
                                    {
                                        <option value="@opt.Id">@opt.NameAr</option>
                                    }
                                    @if (Model != null && Model.AllowCustomSize)
                                    {
                                        <option value="custom" style="color: var(--orange); font-weight: bold;">✨ تفصيل مقاس خاص</option>
                                    }
                                </select>
                            </div>

                            <div id="custom-size-inputs" style="display: none; background: #fff5f2; border: 1px dashed var(--orange); border-radius: 8px; padding: 15px; margin-top: -10px; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
                                <div style="width: 100%; margin-bottom: 5px;">
                                    <strong style="color: var(--orange); font-size: 13px;"><i class="fas fa-ruler-combined"></i> أدخل أبعادك المخصصة بالسنتيمتر (سم)</strong>
                                </div>
                                <div style="flex: 1; min-width: 80px;">
                                    <label style="font-size: 12px; color: var(--navy); font-weight: bold;">الطول *</label>
                                    <input type="number" id="custom-length" class="form-control" placeholder="مثال: 20" min="1" style="padding: 8px;" />
                                </div>
                                <div style="flex: 1; min-width: 80px;">
                                    <label style="font-size: 12px; color: var(--navy); font-weight: bold;">العرض *</label>
                                    <input type="number" id="custom-width" class="form-control" placeholder="مثال: 15" min="1" style="padding: 8px;" />
                                </div>
                                <div style="flex: 1; min-width: 80px;">
                                    <label style="font-size: 12px; color: var(--navy); font-weight: bold;">الارتفاع</label>
                                    <input type="number" id="custom-height" class="form-control" placeholder="للعلب" min="0" style="padding: 8px;" />
                                </div>
                                <div style="width: 100%; margin-top: 5px;">
                                    <span style="font-size: 11px; color: #dc2626;"><i class="fas fa-info-circle"></i> المقاسات المخصصة يتم تحديد سعرها من قبل الإدارة بعد إرسال الطلب.</span>
                                </div>
                            </div>
                        }

                        @if (ViewBag.SidesOptions != null && Enumerable.Count(ViewBag.SidesOptions) > 0)
                        {
                            <div class="form-group">
                                <label>عدد أوجه الطباعة *</label>
                                <select id="opt-sides" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;" onchange="calculateDynamicPrice()">
                                    <option value="">-- اختر --</option>
                                    @foreach (var opt in ViewBag.SidesOptions)
                                    {
                                        <option value="@opt.Id">@opt.NameAr</option>
                                    }
                                </select>
                            </div>
                        }

                        @if (ViewBag.FinishOptions != null && Enumerable.Count(ViewBag.FinishOptions) > 0)
                        {
                            <div class="form-group">
                                <label>خيارات التشطيب والحماية</label>
                                <select id="opt-finish" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;">
                                    <option value="">-- اختر (اختياري) --</option>
                                    @foreach (var opt in ViewBag.FinishOptions)
                                    {
                                        <option value="@opt.Id">@opt.NameAr</option>
                                    }
                                </select>
                            </div>
                        }

                        @if (Model != null && Model.ProductExtras != null && Model.ProductExtras.Any())
                        {
                            <div class="form-group" style="margin-top: 20px; background: #fdfdfd; padding: 15px; border-radius: 8px; border: 1px solid #eee;">
                                <label style="color: var(--navy); font-weight: 800; margin-bottom: 10px; display: block;"><i class="fas fa-plus-circle" style="color: var(--orange);"></i> إضافات اختيارية</label>
                                @foreach (var extra in Model.ProductExtras)
                                {
                                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; margin-bottom: 8px; font-size: 14px;">
                                        <input type="checkbox" class="extra-checkbox" value="@extra.Id" onchange="calculateDynamicPrice()" style="width: 18px; height: 18px; accent-color: var(--orange);" />
                                        @extra.NameAr <strong style="color: var(--success); margin-right: 5px;">(+@extra.Price.ToString("0.00") @siteSettings.Currency)</strong>
                                    </label>
                                }
                            </div>
                        }

                        @if (ViewBag.QuantityTiers != null && Enumerable.Count(ViewBag.QuantityTiers) > 0)
                        {
                            <div style="background: #ecfdf5; padding: 12px; border-radius: 8px; border: 1px dashed #10b981; margin-top: 15px; font-size: 13px;">
                                <strong style="color: #065f46;"><i class="fas fa-tags"></i> عروض الكميات المتاحة:</strong>
                                <ul style="margin: 5px 20px 0; color: #047857;">
                                    @foreach (var tier in ViewBag.QuantityTiers)
                                    {
                                        <li>خصم @tier.DiscountPercent% عند طلب @tier.MinQuantity إلى @tier.MaxQuantity نسخة</li>
                                    }
                                </ul>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- 🟢 التعديل هنا: المنتجات الجاهزة أو بدون خيارات 🟢 -->
                        <div style="text-align: center; padding: 30px 10px; background: #f8fafc; border-radius: 12px; border: 1px solid #e2e8f0;">
                            <div style="width: 60px; height: 60px; background: #ecfdf5; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; color: #10b981;">
                                <i class="fas fa-check" style="font-size: 24px;"></i>
                            </div>
                            <h3 style="font-size: 16px; color: var(--navy); margin-bottom: 10px; font-weight: 800;">المنتج جاهز للطلب</h3>
                            <p style="font-size: 14px; color: #888; line-height: 1.6; font-weight: 600;">هذا المنتج لا يتطلب تخصيص خيارات. حدد الكمية واضغط "إضافة للسلة" مباشرة.</p>
                        </div>
                    }
                </div>
            </div>

            <div class="help-center-card">
                <div class="help-content-wrap">
                    <div class="help-text">
                        <h3>تحتاج مساعدة في اتمام طلبك ؟ <i class="fab fa-whatsapp"></i></h3>
                        <p>ما عرفت تكمل طلبك أو واجهت أي مشكلة تواصل معنا على الواتس اب</p>
                        <a href="https://wa.me/@waNumber" target="_blank" class="btn-click-here">اضغط هنا</a>
                    </div>
                </div>
                <img src="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" class="bg-logo-fade" alt="">
            </div>
        </div>
    </div>

    <!-- قسم التقييمات (Reviews Section) -->
    <section class="product-reviews-section mt-5">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2 class="sec-title" style="margin: 0;"><i class="fas fa-star" style="color: var(--orange);"></i> آراء وتجارب العملاء</h2>
        </div>

        <div class="reviews-container">
            @if (reviewsCount > 0)
            {
                <div class="reviews-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
                    @foreach (var review in approvedReviews)
                    {
                        <div class="review-card" style="background: #fff; padding: 25px; border-radius: 16px; border: 1px solid #f1f5f9; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
                            <div class="review-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div style="width: 45px; height: 45px; background: var(--primary-light); color: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 18px;">
                                        @(string.IsNullOrEmpty(review.ReviewerName) ? "ع" : review.ReviewerName.Substring(0, 1))
                                    </div>
                                    <div>
                                        <strong style="color: var(--navy); display: block; font-size: 15px;">@review.ReviewerName</strong>
                                        <small style="color: #94a3b8; font-size: 12px;">@review.CreatedAt.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ar-SA"))</small>
                                    </div>
                                </div>
                                <div class="stars" style="color: #f59e0b; font-size: 13px;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.Rating)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        else
                                        {

                                            <i class="far fa-star" style="color: #cbd5e1;"></i>
                                        }
                                    }
                                </div>
                            </div>
                            <p style="color: var(--text-secondary); font-size: 14px; line-height: 1.7; margin: 0;">@review.ReviewText</p>

                            @if (!string.IsNullOrEmpty(review.AdminReply))
                            {
                                <div style="margin-top: 20px; background: #f8fafc; padding: 15px; border-radius: 10px; border-right: 4px solid var(--info);">
                                    <strong style="color: var(--info); font-size: 13px; display: block; margin-bottom: 5px;"><i class="fas fa-reply"></i> رد فريق العمل:</strong>
                                    <p style="color: var(--text-main); font-size: 13.5px; margin: 0; line-height: 1.6;">@review.AdminReply</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 50px 20px; background: #f8fafc; border-radius: 16px; border: 2px dashed #e2e8f0;">
                    <i class="far fa-comment-dots" style="font-size: 45px; color: #cbd5e1; margin-bottom: 15px;"></i>
                    <h3 style="color: var(--navy); font-size: 18px; font-weight: 800; margin-bottom: 5px;">لا توجد تقييمات حتى الآن</h3>
                    <p style="color: var(--text-muted); font-size: 15px;">كن أول من يشاركنا رأيه بعد تجربة هذا المنتج!</p>
                </div>
            }
        </div>
    </section>

    <section class="related-products mt-5">
        <h2 class="sec-title">منتجات قد تعجبك</h2>
        <div class="products-grid" id="related-render"></div>
    </section>
</main>

<div class="sticky-footer-bar">
    <div class="container bar-content">
        <!-- 🟢 التعديل هنا: يظهر زر السلة للجميع دائماً 🟢 -->
        <div class="price-side">
            <span class="final-price" id="sticky-price" style="font-size: 22px; color: var(--primary-color);">
                @(hasAnyOptions ? "حدد الخيارات" : "حسب الكمية")
            </span>
            <small>السعر شامل الضريبة</small>
        </div>
        <div class="action-side">
            <div class="quantity-picker">
                <button type="button" onclick="changeQty(-10)">-</button>
                <input type="number" id="prod-qty" value="@(Model != null ? Model.MinQuantity : 100)" min="@(Model != null ? Model.MinQuantity : 1)" onchange="calculateDynamicPrice()">
                <button type="button" onclick="changeQty(10)">+</button>
            </div>
            <button class="btn-add-main" onclick="addToCartFromDetails()">إضافة للسلة <i class="fas fa-cart-plus"></i></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var hasOptions = @(hasAnyOptions.ToString().ToLower());
        var currency = '@siteSettings.Currency';

        document.addEventListener("DOMContentLoaded", function() {
            if (typeof renderSection === "function") {
                renderSection("featured", "related-render");
            }
            if(hasOptions) {
                calculateDynamicPrice();
            }
        });

        function handleSizeChange() {
            const sizeSelect = document.getElementById('opt-size');
            const customInputs = document.getElementById('custom-size-inputs');

            if (sizeSelect && sizeSelect.value === 'custom') {
                customInputs.style.display = 'flex';
            } else if (customInputs) {
                customInputs.style.display = 'none';
            }

            calculateDynamicPrice();
        }

        // 🟢 التعديل: فك القيد للسماح بتغيير الكمية حتى لو لا يوجد خيارات
        function changeQty(val) {
            const input = document.getElementById('prod-qty');
            if (!input) return;
            let current = parseInt(input.value) || 0;
            let min = parseInt(input.getAttribute('min')) || 1;

            if (current + val >= min) {
                input.value = current + val;
            } else {
                input.value = min;
            }

            if(hasOptions) {
                calculateDynamicPrice();
            }
        }

        async function calculateDynamicPrice() {
            if(!hasOptions) return; // المنتجات بدون خيارات لا تحتاج لحساب من الـ API

            const productId = @(Model != null ? Model.Id : 0);

            const paperEl = document.getElementById('opt-paper');
            const sizeEl = document.getElementById('opt-size');
            const sidesEl = document.getElementById('opt-sides');
            const qtyEl = document.getElementById('prod-qty');

            if(!paperEl || !sizeEl || !sidesEl) return;

            const paperId = paperEl.value;
            const sizeId = sizeEl.value;
            const sidesId = sidesEl.value;
            const qty = parseInt(qtyEl.value) || 1;

            if (!paperId || !sizeId || !sidesId) {
                document.getElementById('sticky-price').innerText = 'حدد الخيارات لعرض السعر';
                if(document.getElementById('tabby-price')) document.getElementById('tabby-price').innerText = '0.00';
                return;
            }

            if (sizeId === 'custom') {
                document.getElementById('sticky-price').innerHTML = '<span style="font-size: 16px;">يحدد بعد المراجعة</span>';
                if(document.getElementById('tabby-price')) document.getElementById('tabby-price').innerText = '0.00';
                return;
            }

            const extraCheckboxes = document.querySelectorAll('.extra-checkbox:checked');
            const extraIds = Array.from(extraCheckboxes).map(cb => parseInt(cb.value));

            document.getElementById('sticky-price').innerHTML = '<i class="fas fa-spinner fa-spin" style="font-size:18px;"></i> حساب...';

            const result = await ApiClient.calculatePrice(productId, paperId, sizeId, sidesId, qty, extraIds);

            if (result && result.success) {
                document.getElementById('sticky-price').innerText = result.total.toFixed(2) + ' ' + currency;
                if(document.getElementById('tabby-price')) document.getElementById('tabby-price').innerText = (result.total / 4).toFixed(2);
            } else {
                document.getElementById('sticky-price').innerText = 'غير متاح بهذه المواصفات';
                if(document.getElementById('tabby-price')) document.getElementById('tabby-price').innerText = '0.00';
            }
        }

        // 🟢 التعديل: فك القيد للسماح بإضافة المنتج للسلة دائماً
        function addToCartFromDetails() {
            const titleEl = document.getElementById('product-title');
            const imgEl = document.getElementById('main-product-img');
            const priceEl = document.getElementById('sticky-price');
            const qtyEl = document.getElementById('prod-qty');

            // الفحص يعمل فقط للمنتجات التي تحتوي على خيارات
            if (hasOptions && (priceEl.innerText.includes('حدد الخيارات') || priceEl.innerText.includes('غير متاح') || priceEl.innerText.includes('حساب'))) {
                alert('الرجاء تحديد كافة الخيارات المطلوبة أولاً.');
                return;
            }

            const paperText = document.getElementById('opt-paper') ? document.getElementById('opt-paper').options[document.getElementById('opt-paper').selectedIndex].text : '';
            const sidesText = document.getElementById('opt-sides') ? document.getElementById('opt-sides').options[document.getElementById('opt-sides').selectedIndex].text : '';
            const finishEl = document.getElementById('opt-finish');
            const finishText = finishEl && finishEl.value ? finishEl.options[finishEl.selectedIndex].text : '';

            let sizeText = '';
            const sizeSelect = document.getElementById('opt-size');
            let itemPrice = 0;

            if (hasOptions && sizeSelect && sizeSelect.value === 'custom') {
                const l = document.getElementById('custom-length').value;
                const w = document.getElementById('custom-width').value;
                const h = document.getElementById('custom-height').value;

                if (!l || !w) {
                    alert('الرجاء إدخال الطول والعرض على الأقل لتفصيل المقاس الخاص.');
                    return;
                }
                sizeText = `مقاس مخصص: الطول ${l}سم، العرض ${w}سم` + (h ? `، الارتفاع ${h}سم` : '');
                itemPrice = 0;
            } else if (hasOptions) {
                sizeText = sizeSelect ? sizeSelect.options[sizeSelect.selectedIndex].text : '';
                itemPrice = parseFloat(priceEl.innerText.replace(currency, '').replace('يحدد بعد المراجعة', '0').trim()) || 0;
            } else {
                // للمنتجات التي لا تحتوي على خيارات
                sizeText = '';
                itemPrice = 0; // يمكنك ربطها بسعر المنتج لو موجود في قاعدة البيانات مستقبلاً
            }

            const item = {
                id: @(Model != null ? Model.Id : 0),
                name: titleEl.innerText.trim(),
                price: itemPrice,
                img: imgEl ? imgEl.src : '',
                quantity: parseInt(qtyEl.value) || 1,
                details: { paperType: paperText, sides: sidesText, design: sizeText, cover: finishText },
                SelectedOptionsJson: "{}" // منع الإيرور في صفحة الـ Checkout
            };

            let cart = JSON.parse(localStorage.getItem('printnesCart')) || [];
            cart.push(item);
            localStorage.setItem('printnesCart', JSON.stringify(cart));

            if (typeof updateBadges === "function") updateBadges();
            if (typeof showToastMessage === "function") showToastMessage('تمت الإضافة إلى سلة التسوق', item.name, item.img, true);
        }
    </script>
}