@model IEnumerable<Printnes.Models.Product>
@using Printnes.Helpers
@{
    ViewData["Title"] = "كل المنتجات";
    Layout = "_Layout";
    var siteSettings = SiteSettingsManager.LoadSettings();
}

<style>
    /* Premium Product Card Styles */
    .premium-prod-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #f1f5f9;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        position: relative;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

        .premium-prod-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08);
            border-color: var(--primary-light);
        }

    .prod-img-box {
        position: relative;
        width: 100%;
        padding-top: 100%; /* 1:1 Aspect Ratio */
        background: #f8fafc;
        overflow: hidden;
    }

        .prod-img-box img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .premium-prod-card:hover .prod-img-box img {
        transform: scale(1.05);
    }

    .prod-info {
        padding: 20px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .prod-cat {
        font-size: 11px;
        color: var(--primary-color);
        font-weight: 800;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .prod-title {
        font-size: 15px;
        font-weight: 800;
        color: var(--navy);
        margin: 0 0 10px 0;
        line-height: 1.5;
        text-decoration: none;
    }

        .prod-title:hover {
            color: var(--orange);
        }

    .prod-desc {
        font-size: 12px;
        color: #64748b;
        margin-bottom: 15px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .prod-footer {
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px dashed #e2e8f0;
        padding-top: 15px;
    }

    .btn-view-prod {
        background: var(--navy);
        color: #fff;
        padding: 8px 15px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .btn-view-prod:hover {
            background: var(--orange);
            color: #fff;
        }
</style>

<div class="category-header-bar" style="background: linear-gradient(90deg, var(--navy) 0%, #2a4b91 100%); padding: 30px 0; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
    <div class="container" style="position: relative; z-index: 2;">
        <h1 style="color: #fff; font-size: 32px; font-weight: 900; margin-bottom: 10px; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">كل المنتجات</h1>
        <nav class="breadcrumb-white" style="font-size: 14px; opacity: 0.9;">
            <a href="/" style="color: #fff; text-decoration: none; transition: 0.3s;" onmouseover="this.style.color='var(--orange)'" onmouseout="this.style.color='#fff'"><i class="fas fa-home"></i> الرئيسية</a>
            <span style="margin: 0 8px;">/</span>
            <strong style="color: var(--orange);">المنتجات</strong>
        </nav>
    </div>
</div>

<main class="container py-5">
    <div class="shop-controls" style="background: #fff; padding: 20px 25px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.03); border: 1px solid #f0f0f0; margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
        <h2 class="page-title-main" style="font-size: 18px; color: var(--navy); margin: 0; font-weight: 800;">
            <i class="fas fa-box-open" style="color: var(--orange); margin-left: 8px;"></i> قائمة المنتجات الكاملة (@(Model?.Count() ?? 0) منتج)
        </h2>

        <div class="sort-filter" style="display: flex; align-items: center; gap: 10px;">
            <label style="color: #666; font-weight: 700; font-size: 14px;">ترتيب حسب:</label>
            <div class="custom-select-wrapper" style="min-width: 200px;">
                <!-- استخدام جافاسكريبت لتغيير الرابط عند تغيير الترتيب مع خياراتك الأصلية -->
                <select id="sort-options" onchange="window.location.href='?sortBy=' + this.value" style="width: 100%; padding: 10px 15px; border: 1px solid #ddd; border-radius: 8px; background: #fdfdfd; font-family: inherit; font-weight: 600; color: var(--navy); outline: none; cursor: pointer;">
                    <option value="suggestions" selected="@(ViewBag.SortBy?.ToString() == "suggestions" || string.IsNullOrEmpty(ViewBag.SortBy?.ToString()))">مقترحاتنا</option>
                    <option value="best-selling" selected="@(ViewBag.SortBy?.ToString() == "best-selling")">الأكثر مبيعاً</option>
                    <option value="top-rated" selected="@(ViewBag.SortBy?.ToString() == "top-rated")">الأعلى تقييماً</option>
                    <option value="price-high" selected="@(ViewBag.SortBy?.ToString() == "price-high")">السعر من الأعلى إلى الأقل</option>
                    <option value="price-low" selected="@(ViewBag.SortBy?.ToString() == "price-low")">السعر من الأقل إلى الأعلى</option>
                </select>
            </div>
        </div>
    </div>

    <!-- حاوية عرض كل المنتجات -->
    <div class="products-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 25px;">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="premium-prod-card">
                    <!-- التوجيه بالـ Id إلى الـ Details -->
                    <a href="/Products/Details/@product.Id" class="prod-img-box">
                        <img src="@product.CoverImageUrl" alt="@product.NameAr" onerror="this.src='/images/placeholder.jpg'">
                    </a>
                    <div class="prod-info">
                        <span class="prod-cat">@(product.Category?.NameAr ?? "منتجات الطباعة")</span>
                        <a href="/Products/Details/@product.Id" class="prod-title">@product.NameAr</a>
                        <p class="prod-desc">@(string.IsNullOrEmpty(product.DescriptionAr) ? "اكتشف خيارات الطباعة المتعددة لهذا المنتج بتصميم مخصص." : product.DescriptionAr)</p>

                        <div class="prod-footer">
                            <span style="font-size: 12px; font-weight: 700; color: #94a3b8;"><i class="fas fa-tags"></i> خيارات متعددة</span>
                            <a href="/Products/Details/@product.Id" class="btn-view-prod">التفاصيل <i class="fas fa-arrow-left"></i></a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="width: 100%; text-align: center; padding: 60px 20px; grid-column: 1 / -1; background: #fff; border-radius: 15px; border: 1px dashed #eee;">
                <div style="width: 80px; height: 80px; background: #fff5f5; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                    <i class="fas fa-box-open" style="color: #ffb8b8; font-size: 35px;"></i>
                </div>
                <h3 style="color: var(--navy); font-weight: 800;">لا توجد منتجات حالياً</h3>
                <p style="color: #888;">جاري إضافة المزيد من المنتجات الرائعة قريباً...</p>
                <a href="/" class="btn-view-prod" style="display: inline-flex; margin-top: 15px; background: var(--orange); padding: 12px 25px; font-size: 14px;">العودة للرئيسية</a>
            </div>
        }
    </div>
</main>