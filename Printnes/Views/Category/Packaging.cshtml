@{
    ViewData["Title"] = "التغليف والتعبئة";
}

<div class="category-header-bar">
    <div class="container">
        <nav class="breadcrumb-white">
            <a href="/">الرئيسية</a> <span>/</span> <strong>التغليف والتعبئة</strong>
        </nav>
    </div>
</div>

<section class="sub-categories-pills">
    <div class="container pills-wrapper">
        <button class="pill active">عرض الكل</button>
        <button class="pill" onclick="location.href='/Category/WrappingPaper'">ورق تغليف</button>
        <button class="pill">سليف الأكواب</button>
        <button class="pill">حامل الأكواب</button>
        <button class="pill">سليف علب</button>
        <button class="pill">تغليف العلب</button>
        <button class="pill">ليبل ملابس قماشي</button>
        <button class="pill">شرائط الهدايا</button>
    </div>
</section>

<main class="container py-4">
    <div class="shop-controls">
        <h2 class="orange-line-title">التغليف والتعبئة</h2>
        <div class="sort-filter">
            <label>ترتيب</label>
            <div class="custom-select-wrapper">
                <select>
                    <option>مقترحاتنا</option>
                    <option>الأكثر مبيعاً</option>
                </select>
            </div>
        </div>
    </div>

    <!-- حاوية التغليف -->
    <div class="products-grid" id="render-packaging-page">
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof renderSection === "function") {
                renderSection("packaging", "render-packaging-page");
            }
        });
    </script>
}