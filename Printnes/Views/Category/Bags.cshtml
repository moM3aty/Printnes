@{
    ViewData["Title"] = "الطباعة على الأكياس";
}

<div class="category-header-bar">
    <div class="container">
        <nav class="breadcrumb-white">
            <a href="/">الرئيسية</a> <span>/</span> <strong>الطباعة على الأكياس</strong>
        </nav>
    </div>
</div>

<main class="container py-4">
    <div class="shop-controls">
        <h2 class="page-title-main">الطباعة على الأكياس</h2>
        <div class="sort-filter">
            <label>ترتيب</label>
            <div class="custom-select-wrapper">
                <select id="sort-options">
                    <option value="suggestions" selected>مقترحاتنا</option>
                    <option value="best-selling">الأكثر مبيعاً</option>
                    <option value="top-rated">الأعلى تقييماً</option>
                    <option value="price-high">السعر من الأعلى إلى الأقل</option>
                    <option value="price-low">السعر من الأقل إلى الأعلى</option>
                </select>
            </div>
        </div>
    </div>

    <!-- حاوية الأكياس -->
    <div class="products-grid" id="render-bags-page">
    </div>

    <!-- آراء العملاء -->
    <section class="testimonials-section mt-5">
        <div class="section-title-wrapper">
            <h2 class="orange-title">آراء العملاء</h2>
        </div>
        <div class="testimonials-grid">
            <div class="test-card">
                <div class="stars">⭐⭐⭐⭐⭐</div>
                <p>حلوووووين طلبتهم كتجربه شفت شغلهم عند بنت خالتي وكل شي يجنن وبيرفكت</p>
                <div class="user-info">
                    <strong>زهراء الزاهر</strong>
                    <img src="https://cdn.assets.salla.network/prod/stores/themes/default/assets/images/avatar_female.png" width="30" alt="Avatar">
                </div>
            </div>
            <div class="test-card">
                <div class="stars">⭐⭐⭐⭐⭐</div>
                <p>الجوده والطباعه رووووووعه مره متعاون فريق العمل وسرعه بالأنجاز والتوصيل مو آخر تجربه</p>
                <div class="user-info">
                    <strong>قاسم الراشد</strong>
                    <img src="https://cdn.assets.salla.network/prod/stores/themes/default/assets/images/avatar_male.png" width="30" alt="Avatar">
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof renderSection === "function") {
                renderSection("bags", "render-bags-page");
            }
        });
    </script>
}