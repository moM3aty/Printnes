@{
    ViewData["Title"] = "مطبوعات ورقية";
}

<div class="category-header-bar">
    <div class="container">
        <nav class="breadcrumb-white">
            <a href="/">الرئيسية</a> <span>/</span> <strong>مطبوعات ورقية</strong>
        </nav>
    </div>
</div>

<section class="sub-categories-pills">
    <div class="container pills-wrapper">
        <button class="pill active">عرض الكل</button>
        <button class="pill" onclick="location.href='/Category/FilePrints'">ملف</button>
        <button class="pill">مخططات هندسية</button>
        <button class="pill">أظرف كروت</button>
        <button class="pill">كروت شخصية</button>
        <button class="pill">تاقات</button>
        <button class="pill">أظرف مراسلات</button>
        <button class="pill">ورق تقديم الطعام</button>
        <button class="pill">قائمة الطعام MENU</button>
        <button class="pill">بروشور</button>
        <button class="pill">فلاير</button>
        <button class="pill">شهادات الشكر</button>
    </div>
</section>

<main class="container py-4">
    <div class="shop-controls">
        <h2 class="orange-line-title">مطبوعات ورقية</h2>
        <div class="sort-filter">
            <label>ترتيب</label>
            <div class="custom-select-wrapper">
                <select>
                    <option>مقترحاتنا</option>
                </select>
            </div>
        </div>
    </div>

    <!-- حاوية المطبوعات الورقية -->
    <div class="products-grid" id="render-paper-prints">
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof renderSection === "function") {
                renderSection("paper_prints", "render-paper-prints");
            }
        });
    </script>
}