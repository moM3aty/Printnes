@{
    // يمكنك لاحقاً ربط هذا الملف بأكشن Packages في الـ CategoryController أو ProductsController
    ViewData["Title"] = "عروض البكجات";
}

<div class="category-header-bar">
    <div class="container">
        <nav class="breadcrumb-white">
            <a href="/">الرئيسية</a> <span>/</span> <strong>عروض البكجات</strong>
        </nav>
    </div>
</div>

<main class="container py-4">
    <div class="shop-controls">
        <h2 class="page-title-main">عروض البكجات</h2>
    </div>

    <div class="products-grid" id="packages-render">
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof renderSection === "function") {
                // يعتمد على مصفوفة featured مؤقتاً لحين استبدالها بـ packages من الداتابيز
                renderSection("featured", "packages-render");
            }
        });
    </script>
}