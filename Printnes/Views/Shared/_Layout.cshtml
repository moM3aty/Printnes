<!-- الملف: Views/Shared/_Layout.cshtml -->
@using Printnes.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

@{
    var allCategories = await DbContext.Categories
        .Where(c => c.IsActive)
        .OrderBy(c => c.SortOrder)
        .ToListAsync();

    // التحقق من حالة تسجيل الدخول
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] | برنتس للطباعة والمطبوعات</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        .menu-promo-item {
            padding: 15px;
            text-align: center;
            background: #f8faff;
            margin: 10px 20px;
            border-radius: 12px;
            border: 1px dashed var(--orange);
        }

            .menu-promo-item img {
                width: 80%;
                max-height: 80px;
                object-fit: contain;
                margin-bottom: 5px;
            }

            .menu-promo-item p {
                font-size: 11px;
                color: var(--navy);
                font-weight: bold;
                margin: 0;
            }

        .has-submenu.open > .menu-item-flex .arrow {
            transform: rotate(-90deg);
            color: var(--orange);
        }

        .submenu-list {
            transition: all 0.3s ease;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <!-- حفظ حالة تسجيل الدخول في الجافاسكريبت للتحقق المباشر -->
    <script>
        window.isAuthenticated = @(isAuthenticated.ToString().ToLower());
    </script>

    <header class="main-header">
        <div class="container header-content">
            <div class="brand-area">
                <div class="logo-and-text" onclick="location.href='/'" style="cursor: pointer;">
                    <img src="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" alt="Printnes" class="logo-img">
                    <div class="brand-text">
                        <h1>Printnes</h1>
                        <span>للطباعة والمطبوعات</span>
                    </div>
                </div>
                <button class="menu-toggle-btn" onclick="openSideMenu()"><i class="fas fa-bars"></i></button>
            </div>

            <div class="search-wrapper">
                <form action="/Products/Search" method="get" style="display: flex; width: 100%;">
                    <input type="text" name="q" placeholder="ادخل كلمة البحث">
                    <button type="submit"><i class="fas fa-search"></i></button>
                </form>
            </div>

            <div class="user-nav">
                <!-- أيقونة المفضلات (تتطلب تسجيل دخول) -->
                <div class="nav-item" onclick="if(window.isAuthenticated){ location.href='/Favorites'; } else { location.href='/Account/Login'; }" style="position: relative;">
                    <i class="far fa-heart"></i>
                    <span>المفضلة</span>
                    <span id="fav-count" style="position: absolute; top: -4px; right: -4px; background: #f26a2e; color: #fff; font-size: 9px; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">0</span>
                </div>

                <!-- التبديل بين حسابي (Profile) وتسجيل الدخول -->
                @if (isAuthenticated)
                {
                    <div class="nav-item" onclick="location.href='/Account/Profile'">
                        <i class="far fa-user-circle" style="color: var(--orange);"></i>
                        <span>حسابي</span>
                    </div>
                }
                else
                {
                    <div class="nav-item" onclick="location.href='/Account/Login'">
                        <i class="far fa-user"></i>
                        <span>دخول / تسجيل</span>
                    </div>
                }

                <div class="nav-item cart" onclick="location.href='/Cart'">
                    <i class="fas fa-shopping-bag"></i>
                    <span id="cart-count">0</span>
                </div>
            </div>
        </div>
    </header>

    <!-- إشعار السلة والمفضلات -->
    <div id="cart-toast" class="cart-toast-container hidden">
        <div class="toast-progress"></div>
        <div class="toast-header">
            <span class="status-icon" id="toast-status-icon"><i class="fas fa-check-circle"></i> تمت الإضافة بنجاح</span>
            <span class="close-toast" onclick="hideToast()">&times;</span>
        </div>
        <div class="toast-body">
            <img id="toast-product-img" src="" alt="">
            <div class="toast-info">
                <h4 id="toast-product-name">اسم المنتج</h4>
                <span class="toast-price" id="toast-price-container"><span id="toast-product-price">0</span> ر.س</span>
            </div>
        </div>
        <div class="toast-footer" id="toast-footer">
            <button class="btn-white-toast" onclick="location.href='/Cart'"><i class="fas fa-shopping-bag"></i> عرض السلة</button>
            <button class="btn-orange-toast" onclick="checkoutFullCart()"><i class="fas fa-check"></i> اتمام الطلب</button>
        </div>
    </div>

    @Html.AntiForgeryToken()
    <div id="menu-overlay" class="menu-overlay hidden" onclick="closeSideMenu()"></div>

    <!-- القائمة الجانبية الديناميكية -->
    <aside id="side-menu" class="side-menu shadow-lg">
        <div class="menu-header">
            <div class="brand-small">
                <img src="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" alt="Printnes">
                <span>برنتس</span>
            </div>
            <button class="close-menu-btn" onclick="closeSideMenu()">&times;</button>
        </div>

        <div class="menu-body">
            <ul class="main-nav-list">
                <li><a href="/"><i class="fas fa-home"></i> الرئيسية</a></li>
                <li><a href="/Products">كل المنتجات</a></li>
                <li><a href="/Packages">عروض البكجات</a></li>

                @{
                    var mainCategories = allCategories.Where(c => string.IsNullOrEmpty(c.ParentMenu)).ToList();
                }

                @foreach (var mainCat in mainCategories)
                {
                    var subCategories = allCategories.Where(c => c.ParentMenu == mainCat.Slug).ToList();

                    if (subCategories.Any())
                    {
                        <li class="has-submenu">
                            <div class="menu-item-flex" onclick="toggleSubMenu(this)">
                                <a href="/Category/@mainCat.Slug" style="padding:0; flex:1; background:none; color:inherit;">@mainCat.NameAr</a>
                                <i class="fas fa-chevron-left arrow"></i>
                            </div>
                            <ul class="submenu-list">
                                <li><a href="/Category/@mainCat.Slug">عرض الكل</a></li>
                                @foreach (var subCat in subCategories)
                                {
                                    <li><a href="/Category/@subCat.Slug">@subCat.NameAr</a></li>
                                }
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li><a href="/Category/@mainCat.Slug">@mainCat.NameAr</a></li>
                    }
                }

                <li><a href="/Blog"><i class="fas fa-book"></i> المدونة</a></li>
            </ul>
        </div>
    </aside>

    @RenderBody()

    <!-- الفوتر -->
    <footer class="main-footer">
        <div class="container footer-inner">
            <div class="footer-col brand-col">
                <img src="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" alt="Printnes" class="footer-logo">
                <p class="footer-desc">
                    PRINTNES مؤسسة سعودية معرّفه في وزارة التجارة "معروف" متخصصين في تصنيع المطبوعات وتقديم خدمات التصميم الفريدة والمتميزة
                </p>
                <div class="footer-socials">
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-tiktok"></i></a>
                </div>
            </div>

            <div class="footer-col links-col">
                <h3>روابط مهمة</h3>
                <ul class="footer-links">
                    <li><a href="/Privacy">سياسة الخصوصية</a></li>
                    <li><a href="/FAQ">الأسئلة الشائعة</a></li>
                    <li><a href="/RefundPolicy">سياسة الاستبدال والاسترجاع</a></li>
                    <li><a href="/Terms">سياسة الطباعة والتصميم</a></li>
                </ul>
            </div>

            <div class="footer-col contact-col">
                <h3>تواصل معنا</h3>
                <div class="contact-item">
                    <i class="fab fa-whatsapp"></i>
                    <a href="tel:+966554804857" dir="ltr">+966554804857</a>
                </div>
                <div class="contact-item">
                    <i class="far fa-envelope"></i>
                    <a href="mailto:support@printnes.co">support@printnes.co</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container bottom-wrap">
                <div class="payment-icons">
                    <img src="https://img.icons8.com/color/48/visa.png" alt="visa">
                    <img src="https://img.icons8.com/color/48/mastercard.png" alt="mastercard">
                    <img src="https://img.icons8.com/color/48/apple-pay.png" alt="apple-pay">
                    <span class="tabby-tamara">Tabby | Tamara</span>
                </div>
                <div class="tax-info">الرقم الضريبي : <span>310595349100003</span></div>
                <div class="copyright">الحقوق محفوظة @DateTime.Now.Year | <a href="/">Printnes</a></div>
                <div class="copyright">تصميم وتطوير <a href="https://gmtweb.online/">GMTWEB</a></div>
            </div>
        </div>
    </footer>

    <!-- واتساب العائم -->
    <div class="whatsapp-fixed">
        <a href="https://wa.me/966554804857" target="_blank" class="wa-icon"><i class="fab fa-whatsapp"></i></a>
        <div class="wa-tooltip">راسلنا على الواتساب</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="~/js/api-client.js" asp-append-version="true"></script>
    <script src="~/js/script.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>