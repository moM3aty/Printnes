<!-- الملف: Views/Blog/Details.cshtml -->
@{
    // سيتم استبدالها ببيانات الـ Model مستقبلاً
    ViewData["Title"] = "طباعة كروت وهدايا للمناسبات الخاصة";
    Layout = "_Layout";
}

<main class="container py-5">
    <nav class="breadcrumb-simple">
        <a href="/">الرئيسية</a> <span>&gt;</span> <a href="/Blog">المدونة</a> <span>&gt;</span>
        <strong>@ViewData["Title"]</strong>
    </nav>

    <div class="article-layout">
        <!-- محتوى المقال -->
        <div class="article-body">
            <header class="article-header">
                <h1>@ViewData["Title"]</h1>
                <div class="article-meta">
                    <span><i class="far fa-calendar"></i> 23 أكتوبر 2024</span>
                    <span><i class="far fa-user"></i> Mena Malak</span>
                </div>
            </header>

            <img src="https://cdn.salla.sa/rDvVQ/1pKR8dtK4Hd9UoYFf1hqwqPQJMn5YFEqyOyJngiZ.jpg" class="featured-image" alt="طباعة كروت">

            <div class="content-rich-text">
                <p>تُعد <strong>طباعة كروت وهدايا للمناسبات الخاصة</strong> من أجمل الطرق للتعبير عن المشاعر والمشاركة في اللحظات المميزة، سواء كانت زفافاً، تخرجاً، أو عيد ميلاد. فالهدايا المطبوعة بشكل شخصي لا تُقدّر بثمن، لأنها تحمل لمسة من العاطفة والاهتمام تجعلها أكثر قيمة من أي هدية تقليدية.</p>

                <h3>أهمية طباعة كروت وهدايا للمناسبات الخاصة</h3>
                <p>اختيار طباعة كروت وهدايا للمناسبات الخاصة لا يعني فقط إضافة الجمال للمناسبة، بل يعني تقديم تجربة مؤثرة تبقى في ذاكرة من يتلقاها.</p>

                <ul class="styled-list">
                    <li><strong>تعزيز القيمة العاطفية:</strong> الكرت أو الهدية المطبوعة بتصميم مخصص تحمل رسالة شخصية تعبر عن الاهتمام الحقيقي.</li>
                    <li><strong>توثيق اللحظات الجميلة:</strong> من خلال كروت التهاني أو الهدايا التذكارية المطبوعة، يمكن الاحتفاظ بذكرى المناسبة لسنوات طويلة.</li>
                </ul>

                <div class="help-banner">
                    <div class="help-text">
                        <h3>تحتاج مساعدة في إتمام طلبك ؟</h3>
                        <p>ما عرفت تكمل طلبك أو واجهت أي مشكلة تواصل معنا على الواتساب</p>
                        <a href="https://wa.me/966554804857" target="_blank" class="btn-help-wa">اضغط هنا</a>
                    </div>
                    <div class="help-icon"><i class="fab fa-whatsapp"></i></div>
                </div>

                <h3>مزايا الطباعة من Printnes</h3>
                <p>يُعد متجر Printnes أحد أبرز المتاجر التي تقدم خدمة طباعة كروت وهدايا للمناسبات الخاصة بجودة عالية وتصاميم مخصصة.</p>

                <div class="highlight-box">
                    <h4>تنوع كبير في التصاميم:</h4>
                    <p>يتيح المتجر خيارات واسعة من الأشكال والألوان والمواد، بما يناسب مختلف الأذواق والمناسبات.</p>
                </div>
            </div>

            <div class="article-tags">
                <span><i class="fas fa-tag"></i> طباعة كروت وهدايا</span>
                <span><i class="fas fa-tag"></i> أهمية طباعة الكروت</span>
                <span><i class="fas fa-tag"></i> نصائح للتصميم</span>
            </div>
        </div>

        <!-- القائمة الجانبية للمقال -->
        <aside class="article-sidebar">
            <div class="sidebar-widget">
                <h4>مقالات ذات صلة</h4>
                <ul class="related-links">
                    <li><a href="/Blog/Details/2">كيفية اختيار نوع الورق المناسب</a></li>
                    <li><a href="/Blog/Details/3">طباعة علب تغليف احترافية</a></li>
                </ul>
            </div>

            <div class="sidebar-widget promo-widget">
                <img src="https://cdn.salla.sa/form-builder/PD53rr1LUNb19Hj3je9ULKSfhYUGg0o3TOBdz1T7.png" alt="Promo">
                <p style="margin-top: 15px;">اطلب الآن واحصل على خصم خاص للمناسبات الكبيرة!</p>
                <button class="add-to-cart" style="width:100%; margin-top: 10px;" onclick="location.href='/Packages'">اكتشف العروض</button>
            </div>
        </aside>
    </div>
</main>