@model Printnes.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "إنشاء حساب جديد";
    Layout = "_Layout";
}

<main class="container" style="padding: 60px 15px; min-height: 70vh; display: flex; align-items: center; justify-content: center;">
    <div style="width: 100%; max-width: 500px;">

        @if (TempData["RegisterError"] != null)
        {
            <div style="background: #fef2f2; color: #991b1b; padding: 14px 18px; border-radius: 12px; margin-bottom: 20px; font-size: 14px; font-weight: 600; border: 1px solid #fecaca; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-exclamation-circle" style="font-size: 18px;"></i>
                @Html.Raw(TempData["RegisterError"])
            </div>
        }

        <div style="background: #fff; border-radius: 24px; box-shadow: 0 20px 60px rgba(0,0,0,0.08); border: 1px solid #f0f0f0; overflow: hidden; padding: 40px 30px;">

            <div style="text-align: center; margin-bottom: 30px;">
                <div style="width: 70px; height: 70px; background: #f0f5ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                    <i class="fas fa-user-plus" style="font-size: 28px; color: var(--navy);"></i>
                </div>
                <h2 style="font-size: 24px; color: var(--navy); margin-bottom: 5px; font-weight: 900;">إنشاء حساب جديد</h2>
                <p style="font-size: 14px; color: #888;">انضم لبرنتس واستمتع بتجربة تسوق وطباعة مميزة</p>
            </div>

            <form asp-action="Register" method="post">
                <div style="margin-bottom: 16px;">
                    <label asp-for="FullName" style="display: block; font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 8px;"></label>
                    <input asp-for="FullName" placeholder="أدخل اسمك الكريم"
                           style="width: 100%; padding: 13px 16px; border: 1.5px solid #e0e0e0; border-radius: 12px; font-family: inherit; font-size: 14px; outline: none; transition: 0.3s;"
                           onfocus="this.style.borderColor='var(--orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                    <span asp-validation-for="FullName" style="color: #ef4444; font-size: 12px;"></span>
                </div>

                <div style="margin-bottom: 16px;">
                    <label asp-for="Email" style="display: block; font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 8px;"></label>
                    <input asp-for="Email" placeholder="example@email.com"
                           style="width: 100%; padding: 13px 16px; border: 1.5px solid #e0e0e0; border-radius: 12px; font-family: inherit; font-size: 14px; outline: none; text-align: left; transition: 0.3s;"
                           onfocus="this.style.borderColor='var(--orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                    <span asp-validation-for="Email" style="color: #ef4444; font-size: 12px;"></span>
                </div>

                <div style="margin-bottom: 16px;">
                    <label asp-for="Phone" style="display: block; font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 8px;"></label>
                    <input asp-for="Phone" placeholder="05XXXXXXXX" dir="ltr"
                           style="width: 100%; padding: 13px 16px; border: 1.5px solid #e0e0e0; border-radius: 12px; font-family: inherit; font-size: 14px; outline: none; text-align: left; transition: 0.3s;"
                           onfocus="this.style.borderColor='var(--orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                    <span asp-validation-for="Phone" style="color: #ef4444; font-size: 12px;"></span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px;">
                    <div>
                        <label asp-for="Password" style="display: block; font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 8px;"></label>
                        <input asp-for="Password" placeholder="6 أحرف على الأقل"
                               style="width: 100%; padding: 13px 16px; border: 1.5px solid #e0e0e0; border-radius: 12px; font-family: inherit; font-size: 14px; outline: none; text-align: left; transition: 0.3s;"
                               onfocus="this.style.borderColor='var(--orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                        <span asp-validation-for="Password" style="color: #ef4444; font-size: 12px;"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" style="display: block; font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 8px;"></label>
                        <input asp-for="ConfirmPassword" placeholder="تأكيد كلمة المرور"
                               style="width: 100%; padding: 13px 16px; border: 1.5px solid #e0e0e0; border-radius: 12px; font-family: inherit; font-size: 14px; outline: none; text-align: left; transition: 0.3s;"
                               onfocus="this.style.borderColor='var(--orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                        <span asp-validation-for="ConfirmPassword" style="color: #ef4444; font-size: 12px;"></span>
                    </div>
                </div>

                <button type="submit" style="width: 100%; padding: 15px; background: var(--navy); color: #fff; border: none; border-radius: 12px; font-family: inherit; font-size: 16px; font-weight: 800; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px;"
                        onmouseover="this.style.background='#162d5f'; this.style.transform='translateY(-2px)'"
                        onmouseout="this.style.background='var(--navy)'; this.style.transform='none'">
                    <i class="fas fa-user-plus"></i> إنشاء الحساب
                </button>
            </form>

            <div style="text-align: center; margin-top: 25px; padding-top: 20px; border-top: 1px solid #f5f5f5;">
                <p style="font-size: 14px; color: #888;">
                    لديك حساب بالفعل؟
                    <a href="/Account/Login" style="color: var(--orange); font-weight: 800; text-decoration: none; margin-right: 5px;">سجل دخولك</a>
                </p>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}