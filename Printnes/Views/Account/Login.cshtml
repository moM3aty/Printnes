@model Printnes.ViewModels.CustomerLoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "_Layout";
}

<main class="container" style="padding: 60px 15px; min-height: 70vh; display: flex; align-items: center; justify-content: center;">
    <div style="width: 100%; max-width: 450px;">

        @if (TempData["LoginError"] != null)
        {
            <div style="background: #fef2f2; color: #991b1b; padding: 14px 18px; border-radius: 12px; margin-bottom: 20px; font-size: 14px; font-weight: 600; border: 1px solid #fecaca; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-exclamation-circle" style="font-size: 18px;"></i>
                @TempData["LoginError"]
            </div>
        }

        <div style="background: #fff; border-radius: 24px; box-shadow: 0 20px 60px rgba(0,0,0,0.08); border: 1px solid #f0f0f0; overflow: hidden; padding: 40px 30px;">

            <div style="text-align: center; margin-bottom: 30px;">
                <div style="width: 70px; height: 70px; background: #fff5f2; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                    <i class="fas fa-user-circle" style="font-size: 32px; color: var(--orange);"></i>
                </div>
                <h2 style="font-size: 24px; color: var(--navy); margin-bottom: 5px; font-weight: 900;">مرحباً بعودتك!</h2>
                <p style="font-size: 14px; color: #888;">سجل دخولك لمتابعة طلباتك ومفضلاتك</p>
            </div>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size: 13px; margin-bottom: 15px;"></div>
                <input type="hidden" asp-for="ReturnUrl" />

                <div style="margin-bottom: 18px;">
                    <label asp-for="Email" style="display: block; font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 8px;"></label>
                    <div style="position: relative;">
                        <input asp-for="Email" placeholder="example@email.com"
                               style="width: 100%; padding: 14px 16px 14px 44px; border: 1.5px solid #e0e0e0; border-radius: 12px; font-family: inherit; font-size: 14px; outline: none; text-align: left; transition: 0.3s;"
                               onfocus="this.style.borderColor='var(--orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                        <i class="fas fa-envelope" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #bbb;"></i>
                    </div>
                    <span asp-validation-for="Email" style="color: #ef4444; font-size: 12px;"></span>
                </div>

                <div style="margin-bottom: 25px;">
                    <label asp-for="Password" style="display: block; font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 8px;"></label>
                    <div style="position: relative;">
                        <input asp-for="Password" placeholder="••••••••" id="loginPassword"
                               style="width: 100%; padding: 14px 44px 14px 44px; border: 1.5px solid #e0e0e0; border-radius: 12px; font-family: inherit; font-size: 14px; outline: none; text-align: left; transition: 0.3s;"
                               onfocus="this.style.borderColor='var(--orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                        <i class="fas fa-lock" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #bbb;"></i>
                        <button type="button" onclick="togglePass('loginPassword', this)"
                                style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #bbb; cursor: pointer; font-size: 16px;">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" style="color: #ef4444; font-size: 12px;"></span>
                </div>

                <button type="submit" style="width: 100%; padding: 15px; background: var(--orange); color: #fff; border: none; border-radius: 12px; font-family: inherit; font-size: 16px; font-weight: 800; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px;"
                        onmouseover="this.style.background='#d8561d'; this.style.transform='translateY(-2px)'"
                        onmouseout="this.style.background='var(--orange)'; this.style.transform='none'">
                    <i class="fas fa-sign-in-alt"></i> تسجيل الدخول
                </button>
            </form>

            <div style="text-align: center; margin-top: 25px; padding-top: 20px; border-top: 1px solid #f5f5f5;">
                <p style="font-size: 14px; color: #888;">
                    ليس لديك حساب؟
                    <a href="/Account/Register" style="color: var(--navy); font-weight: 800; text-decoration: none; margin-right: 5px;">أنشئ حساباً الآن</a>
                </p>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(id, btn) {
            const input = document.getElementById(id);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
}