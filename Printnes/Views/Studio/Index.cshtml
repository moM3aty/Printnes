                    </optgroup>
                    <option value="custom">أبعاد مخصصة <i class="fas fa-sliders-h"></i></option>
                </select>

                <div class="dim-box" id="custom-dim-box">
                    <label>الطول (سم)</label><input type="number" id="dim-l" class="dim-input" value="15">
                    <label>العرض (سم)</label><input type="number" id="dim-w" class="dim-input" value="10">
                    <label>الارتفاع (سم)</label><input type="number" id="dim-d" class="dim-input" value="5">
                    <button class="dim-apply" onclick="applyCustomDims()">تطبيق الأبعاد</button>
