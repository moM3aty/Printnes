                    <div class="bg-fill-row">
                        <span>لون الوجه الحالي</span>
                        <input type="color" id="face-bg-color" class="simple-color" value="#ffffff" oninput="changeBackgroundColor()">
                    </div>

                    <div class="text-properties-box" id="text-properties">
                        <label class="title"><i class="fas fa-font"></i> خصائص النص المحدد</label>
                        <div class="bg-fill-row" style="padding: 8px 12px; background: #fff;">
                            <span>لون النص</span><input type="color" id="text-color-picker" class="simple-color" value="#1f2937" oninput="updateTextProperty('fill', this.value)">
                        </div>
                        <select class="custom-select" id="text-font-family" onchange="updateTextProperty('fontFamily', this.value)" style="padding: 8px 12px;">
                            <option value="Cairo">Cairo (كيرو)</option>
                            <option value="Arial">Arial (عريض الأساسي)</option>
                            <option value="Tahoma">Tahoma (تاهوما)</option>
