                <div class="align-row">
                    <button class="btn-align" onclick="alignObject('fit')"><i class="fas fa-compress"></i> ملائمة</button>
                    <button class="btn-align" onclick="alignObject('center')"><i class="fas fa-align-center"></i> توسيط</button>
                    <button class="btn-align" onclick="alignObject('stretch')"><i class="fas fa-expand"></i> تمدد</button>
