    <div id="studio-workspace">
        <div class="studio-header">
            <div class="studio-logo" onclick="window.location.reload()"><i class="fas fa-cube"></i> برينتنس<sup>®</sup></div>
            <div class="top-nav"><button class="btn-cart-top" onclick="window.location.href='/Cart'"><i class="fas fa-shopping-cart"></i> <span>السلة</span></button></div>
        </div>

        <div id="three-canvas"></div>

        <div class="mobile-tabs" id="mobile-tabs">
            <button id="tab-settings-btn" class="active" onclick="toggleMobileTab('settings')">المواصفات والتسعير</button>
            <button id="tab-design-btn" onclick="toggleMobileTab('design')">أدوات التصميم 2D</button>
