@{
    ViewData["Title"] = "استوديو التصميم | علب مخصصة";
    Layout = null;
    var settings = ViewBag.StudioSettings as Printnes.ViewModels.StudioSettingsViewModel;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>@ViewData["Title"]</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" rel="icon" type="image/x-icon" />

    <style>
        /* ==========================================
                   1. ROOT VARIABLES & GLOBAL RESET
                   ========================================== */
        :root {
            --primary: #0f62fe;
            --primary-hover: #0353e9;
            --bg-panel: rgba(255, 255, 255, 0.95);
            --text-main: #1f2937;
            --text-light: #64748b;
            --border-color: rgba(0, 0, 0, 0.08);
            --shadow-sm: 0 4px 6px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 30px rgba(0,0,0,0.12);
            --radius: 12px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            outline: none;
            font-family: 'Cairo', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            overflow: hidden;
            width: 100vw;
            height: 100vh;
            background-color: #e2e8f0;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

        /* ==========================================
                   2. PREMIUM WELCOME SCREEN
                   ========================================== */
        #premium-welcome {
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-y: auto;
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .pw-nav {
            width: 100%;
            padding: 30px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .pw-logo {
            font-size: 26px;
            font-weight: 900;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .pw-logo i {
                color: var(--primary);
                background: #fff;
                padding: 6px;
                border-radius: 8px;
                font-size: 22px;
            }

        .pw-hero {
            text-align: center;
            margin-top: 6vh;
            max-width: 1200px;
            padding: 0 20px;
        }

        .pw-title {
            font-size: 50px;
            font-weight: 900;
            margin-bottom: 20px;
            background: linear-gradient(to left, #fff, #93c5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .pw-subtitle {
            font-size: 18px;
            color: #94a3b8;
            margin-bottom: 60px;
            font-weight: 500;
        }

        .pw-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
            margin-bottom: 50px;
            direction: rtl;
        }

        .pw-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 40px 20px;
            cursor: pointer;
            transition: all 0.4s;
            backdrop-filter: blur(12px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

            .pw-card:hover {
                transform: translateY(-10px);
                background: rgba(255,255,255,0.08);
                border-color: rgba(255,255,255,0.3);
                box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            }

        .pw-card-icon {
            width: 100%;
            margin-bottom: 25px;
            transition: transform 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-radius: 12px;
        }

            .pw-card-icon img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .pw-card:hover .pw-card-icon {
            transform: scale(1.1);
        }

        .pw-card h2 {
            font-size: 22px;
            font-weight: 800;
            margin-bottom: 12px;
            color: #f8fafc;
        }

        .pw-card p {
            font-size: 14px;
            color: #94a3b8;
            line-height: 1.6;
            text-align: center;
        }

        /* ==========================================
                   3. STUDIO WORKSPACE UI
                   ========================================== */
        #studio-workspace {
            position: fixed;
            inset: 0;
            background: radial-gradient(circle at 50% 50%, #f8fafc 0%, #cbd5e1 100%);
            transition: background 0.3s ease;
        }

        #three-canvas {
            position: absolute;
            inset: 0;
            cursor: grab;
        }

            #three-canvas:active {
                cursor: grabbing;
            }

        .studio-header {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 30px;
            z-index: 10;
            pointer-events: none;
        }

            .studio-header > * {
                pointer-events: auto;
            }

        .studio-logo {
            color: var(--text-main);
            font-size: 22px;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            text-shadow: 0 2px 4px rgba(255,255,255,0.5);
        }

            .studio-logo i {
                color: var(--primary);
            }

        .top-nav {
            display: flex;
            gap: 15px;
        }

        .btn-cart-top {
            background: #fff;
            color: var(--text-main);
            border: none;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            box-shadow: var(--shadow-sm);
            display: flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }

            .btn-cart-top:hover {
                box-shadow: var(--shadow-lg);
                transform: translateY(-2px);
                color: var(--primary);
            }

        /* Panels Shared */
        .panel {
            position: absolute;
            background: var(--bg-panel);
            backdrop-filter: blur(16px);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            display: flex;
            flex-direction: column;
            z-index: 10;
            border: 1px solid rgba(255,255,255,0.6);
        }

        .panel-header {
            padding: 18px;
            border-bottom: 1px solid var(--border-color);
            font-weight: 800;
            font-size: 15px;
            color: var(--text-main);
            text-align: center;
        }

        /* --- Right Panel --- */
        .panel-settings {
            top: 80px;
            right: 25px;
            width: 280px;
            max-height: calc(100vh - 100px);
        }

        .panel-content {
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .custom-select {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: #f8fafc;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-main);
            cursor: pointer;
            appearance: none;
            transition: all 0.2s;
            background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23888%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E");
            background-repeat: no-repeat;
            background-position: left 1em top 50%;
            background-size: .65em auto;
        }

            .custom-select:focus {
                border-color: var(--primary);
                background: #fff;
            }

        .dim-box {
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 12px;
            background: #f8fafc;
            display: none;
        }

            .dim-box.active {
                display: block;
                animation: fadeIn 0.3s;
            }

            .dim-box label {
                font-size: 12px;
                color: var(--text-light);
                font-weight: 700;
                display: block;
                margin-bottom: 5px;
            }

        .dim-input {
            text-align: center;
            padding: 10px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-weight: 700;
            width: 100%;
            font-size: 14px;
            margin-bottom: 8px;
            transition: 0.2s;
        }

            .dim-input:focus {
                border-color: var(--primary);
                background: #fff;
            }

        .dim-apply {
            width: 100%;
            padding: 10px;
            background: var(--text-main);
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.2s;
        }

            .dim-apply:hover {
                background: #000;
                box-shadow: var(--shadow-sm);
            }

        .qty-container {
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 12px 15px;
            background: #f8fafc;
        }

        .qty-label {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-light);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .qty-row {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .qty-slider {
            flex: 1;
            accent-color: var(--primary);
            cursor: pointer;
            height: 4px;
            background: #e2e8f0;
            outline: none;
            -webkit-appearance: none;
            border-radius: 2px;
        }

            .qty-slider::-webkit-slider-thumb {
                -webkit-appearance: none;
                appearance: none;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background: var(--primary);
                cursor: pointer;
                border: 3px solid #fff;
                box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            }

        .qty-input {
            width: 70px;
            border: 1px solid var(--border-color);
            padding: 8px;
            text-align: center;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-main);
        }

        .price-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid var(--border-color);
            background: #f0fdf4;
            padding: 15px;
            border-radius: 8px;
            margin-top: 5px;
            border-right: 4px solid #22c55e;
        }

            .price-box span {
                font-size: 13px;
                font-weight: 700;
                color: #166534;
            }

            .price-box strong {
                font-size: 24px;
                font-weight: 900;
                color: #16a34a;
            }

        .price-table-wrapper {
            position: relative;
            margin-top: 5px;
            width: 100%;
        }

        .pt-header {
            padding: 12px 15px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: #f8fafc;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-main);
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: 0.2s;
        }

            .pt-header:hover {
                border-color: var(--primary);
                background: #fff;
            }

        .pt-list {
            position: absolute;
            bottom: 100%;
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid var(--border-color);
            border-bottom: none;
            border-radius: 8px 8px 0 0;
            z-index: 1000;
            list-style: none;
            padding: 0;
            margin: 0;
            display: none;
            box-shadow: 0 -10px 25px rgba(0,0,0,0.1);
            max-height: 200px;
            overflow-y: auto;
            margin-bottom: 5px;
        }

            .pt-list.show {
                display: block;
                animation: slideUp 0.2s ease forwards;
            }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .pt-list li {
            padding: 12px 15px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            cursor: pointer;
            font-size: 14px;
            transition: 0.2s;
        }

            .pt-list li:last-child {
                border-bottom: none;
            }

            .pt-list li:hover {
                background: #eff6ff;
                color: var(--primary);
                padding-right: 20px;
            }

            .pt-list li span:first-child {
                font-weight: 700;
            }

            .pt-list li span:last-child {
                font-weight: 800;
                color: #10b981;
            }

        /* --- Left Panel --- */
        .design-wrapper {
            position: absolute;
            top: 80px;
            left: 25px;
            display: flex;
            gap: 0;
            box-shadow: var(--shadow-lg);
            border-radius: var(--radius);
            background: var(--bg-panel);
            border: 1px solid rgba(255,255,255,0.6);
            backdrop-filter: blur(16px);
        }

        .face-selector-col {
            width: 85px;
            background: #f8fafc;
            border-left: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 10px;
            border-radius: 0 var(--radius) var(--radius) 0;
        }

        .face-btn {
            width: 100%;
            background: transparent;
            border: none;
            padding: 15px 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            font-size: 10px;
            font-weight: 800;
            color: var(--text-light);
            cursor: pointer;
            border-right: 3px solid transparent;
            transition: 0.2s;
            position: relative;
        }

            .face-btn i {
                font-size: 20px;
                transition: 0.2s;
            }

            .face-btn:hover {
                background: #f1f5f9;
                color: var(--text-main);
            }

                .face-btn:hover i {
                    color: var(--text-main);
                    transform: scale(1.1);
                }

            .face-btn.active {
                color: var(--primary);
                background: #fff;
                border-right-color: var(--primary);
                box-shadow: -2px 0 10px rgba(0,0,0,0.02);
            }

                .face-btn.active i {
                    color: var(--primary);
                }

            .face-btn.action-btn {
                color: #f59e0b;
                background: #fffbeb;
                border-bottom: 1px solid #fde68a;
                margin-bottom: 5px;
            }

                .face-btn.action-btn i {
                    color: #f59e0b;
                }

                .face-btn.action-btn:hover {
                    background: #fef3c7;
                }

        .zoom-controls {
            margin-top: auto;
            padding: 15px 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            width: 100%;
            border-top: 1px solid var(--border-color);
            background: #fff;
        }

        .zoom-btn {
            background: #f1f5f9;
            border: none;
            color: var(--text-main);
            width: 32px;
            height: 32px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
            font-size: 14px;
        }

            .zoom-btn:hover {
                background: #e2e8f0;
                color: var(--primary);
                transform: scale(1.05);
            }

        .design-board-col {
            width: 340px;
            display: flex;
            flex-direction: column;
        }

        .db-tools-top {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border-bottom: 1px solid var(--border-color);
        }

        .btn-upload {
            background: linear-gradient(135deg, var(--primary) 0%, #3b82f6 100%);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 15px;
            cursor: pointer;
            text-align: center;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(15, 98, 254, 0.3);
        }

            .btn-upload:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(15, 98, 254, 0.4);
            }

        .formats-txt {
            font-size: 10px;
            color: var(--text-light);
            text-align: center;
            margin-top: -5px;
            font-weight: 600;
        }

        .bg-fill-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #f8fafc;
            padding: 12px 15px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
        }

            .bg-fill-row span {
                font-size: 13px;
                font-weight: 700;
                color: var(--text-main);
            }

        input[type="color"].simple-color {
            width: 40px;
            height: 30px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            cursor: pointer;
            padding: 0;
            background: none;
        }

        .text-properties-box {
            display: none;
            flex-direction: column;
            gap: 10px;
            margin-top: 10px;
            padding: 12px;
            background: #f8fafc;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            animation: fadeIn 0.3s ease;
        }

            .text-properties-box label.title {
                font-size: 12px;
                font-weight: 800;
                color: var(--primary);
                margin-bottom: 2px;
                display: flex;
                align-items: center;
                gap: 5px;
            }

        .canvas-wrapper {
            background: #f1f5f9;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 270px;
            position: relative;
        }

        .canvas-container-outer {
            position: relative;
            border: 1px dashed #94a3b8;
            background: #fff;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            border-radius: 4px;
        }

        .btn-trash {
            position: absolute;
            bottom: -12px;
            left: -12px;
            background: #ef4444;
            color: white;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            cursor: pointer;
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100;
            font-size: 14px;
            box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3);
            transition: 0.2s;
        }

            .btn-trash:hover {
                background: #dc2626;
                transform: scale(1.1);
            }

        .canvas-container-outer:hover .btn-trash {
            display: flex;
        }

        .align-row {
            padding: 15px 20px;
            display: flex;
            gap: 10px;
            justify-content: center;
            border-top: 1px solid var(--border-color);
            background: #fff;
            border-radius: 0 0 12px 12px;
        }

        .btn-align {
            flex: 1;
            background: #f8fafc;
            border: 1px solid var(--border-color);
            padding: 10px;
            border-radius: 6px;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            color: var(--text-main);
            transition: 0.2s;
        }

            .btn-align:hover {
                background: #e2e8f0;
                color: var(--primary);
                border-color: #cbd5e1;
            }

        .scene-bg-picker {
            position: absolute;
            bottom: 30px;
            right: 30px;
            z-index: 20;
            background: var(--bg-panel);
            padding: 12px 20px;
            border-radius: 30px;
            box-shadow: var(--shadow-lg);
            display: flex;
            align-items: center;
            gap: 12px;
            border: 1px solid rgba(255,255,255,0.6);
            backdrop-filter: blur(10px);
        }

            .scene-bg-picker label {
                font-size: 13px;
                font-weight: 800;
                color: var(--text-main);
                display: flex;
                align-items: center;
                gap: 8px;
                cursor: pointer;
                margin-bottom: 0;
            }

            .scene-bg-picker i {
                color: var(--text-light);
            }

        .bottom-bar {
            position: absolute;
            bottom: 30px;
            left: 20%;
            transform: translateX(50%);
            display: flex;
            gap: 15px;
            z-index: 20;
        }

        .btn-bottom {
            background: #fff;
            color: var(--text-main);
            border: 1px solid var(--border-color);
            padding: 14px 30px;
            border-radius: 30px;
            font-weight: 800;
            font-size: 14px;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: var(--shadow-sm);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .btn-bottom:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-lg);
                border-color: #cbd5e1;
            }

        .btn-cart {
            background: linear-gradient(135deg, var(--primary) 0%, #3b82f6 100%);
            color: white;
            border: none;
            padding: 14px 40px;
            box-shadow: 0 4px 15px rgba(15, 98, 254, 0.3);
            border-radius: 30px;
            font-weight: 800;
            cursor: pointer;
        }

            .btn-cart:hover {
                background: linear-gradient(135deg, var(--primary-hover) 0%, #2563eb 100%);
                color: white;
                box-shadow: 0 6px 20px rgba(15, 98, 254, 0.4);
            }

        /* Loader & Toast */
        #loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.8);
            z-index: 9999;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            backdrop-filter: blur(5px);
        }

        .spinner {
            border: 4px solid rgba(255,255,255,0.1);
            border-left-color: var(--primary);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translate(50%, -100px);
            background: #1f2937;
            color: white;
            padding: 12px 25px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 14px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 10000;
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid rgba(255,255,255,0.1);
        }

            .toast.show {
                transform: translate(50%, 0);
                opacity: 1;
            }

        /* ==========================================
                   4. PREMIUM RESPONSIVE DESIGN (MOBILE APP FEEL)
                   ========================================== */
        .mobile-tabs {
            display: none;
        }

        @@media (max-width: 1200px) {
            .pw-grid {
                grid-template-columns: 1fr 1fr;
                gap: 20px;
            }

            .studio-header {
                padding: 15px 20px;
                background: linear-gradient(to bottom, rgba(255,255,255,0.9), transparent);
            }

            .studio-logo {
                font-size: 18px;
            }

            .btn-cart-top {
                padding: 8px 12px;
            }

                .btn-cart-top span {
                    display: none;
                }
            /* 3D Canvas takes top half */
            #three-canvas {
                height: 45vh !important;
            }
            /* App-like Segmented Tabs */
            .mobile-tabs {
                display: flex;
                position: absolute;
                top: 45vh;
                left: 0;
                width: 100%;
                background: rgba(255,255,255,0.85);
                backdrop-filter: blur(10px);
                border-top: 1px solid rgba(0,0,0,0.05);
                border-bottom: 1px solid rgba(0,0,0,0.05);
                z-index: 50;
                padding: 5px;
                justify-content: center;
                gap: 5px;
            }

                .mobile-tabs button {
                    flex: 1;
                    padding: 10px;
                    border: none;
                    background: transparent;
                    font-weight: 800;
                    font-size: 13px;
                    color: var(--text-light);
                    border-radius: 8px;
                    transition: 0.3s;
                }

                    .mobile-tabs button.active {
                        background: #fff;
                        color: var(--primary);
                        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
                    }
            /* Panels as Bottom Sheets */
            .panel-settings, .design-wrapper {
                top: calc(45vh + 50px) !important;
                left: 0 !important;
                right: 0 !important;
                width: 100% !important;
                bottom: 75px !important;
                border-radius: 20px 20px 0 0;
                border: none;
                background: #fff;
                box-shadow: 0 -5px 25px rgba(0,0,0,0.05);
                max-height: none;
            }

            .panel-settings {
                display: flex;
            }

            .panel-header {
                display: none;
            }

            .panel-content {
                padding: 20px;
                padding-bottom: 40px;
            }

            .design-wrapper {
                display: none;
                flex-direction: column;
                overflow: hidden;
            }
            /* Horizontal Scroll Face Selector */
            .face-selector-col {
                width: 100%;
                flex-direction: row;
                overflow-x: auto;
                border-radius: 20px 20px 0 0;
                border-left: none;
                border-bottom: 1px solid var(--border-color);
                padding: 10px;
                justify-content: flex-start;
                height: auto;
                order: -1;
                -ms-overflow-style: none;
                scrollbar-width: none;
            }

                .face-selector-col::-webkit-scrollbar {
                    display: none;
                }

            .face-btn {
                min-width: 70px;
                padding: 8px 5px;
                border-right: none;
                border-radius: 12px;
                margin-left: 5px;
                flex-direction: column;
                justify-content: center;
            }

                .face-btn i {
                    font-size: 20px;
                    margin-bottom: 4px;
                    display: block;
                }

                .face-btn span {
                    display: block;
                    font-size: 11px;
                    white-space: nowrap;
                }

                .face-btn.active {
                    background: var(--primary);
                    color: #fff;
                    box-shadow: 0 4px 10px rgba(15,98,254,0.2);
                }

                    .face-btn.active i {
                        color: #fff;
                    }

            .design-board-col {
                width: 100%;
                height: 100%;
                overflow-y: auto;
                padding-bottom: 20px;
            }

            .canvas-wrapper {
                height: 200px;
                padding: 10px;
            }
            /* App Action Bar (Sticky Bottom) */
            .bottom-bar {
                bottom: 0;
                left: 0;
                width: 100%;
                transform: none;
                padding: 12px 20px;
                background: rgba(255,255,255,0.9);
                backdrop-filter: blur(15px);
                border-top: 1px solid rgba(0,0,0,0.08);
                justify-content: space-between;
                gap: 12px;
                z-index: 100;
                box-shadow: 0 -4px 20px rgba(0,0,0,0.05);
            }

            .btn-bottom, .btn-cart {
                padding: 12px;
                flex: 1;
                justify-content: center;
                font-size: 14px;
                border-radius: 12px;
            }

                .btn-bottom span {
                    display: none;
                }

            .btn-bottom {
                flex: 0 0 50px;
                padding: 0;
            }
            /* Square Reset Button */

            .scene-bg-picker {
                display: none;
            }

            .zoom-controls {
                flex-direction: row;
                width: auto;
                border-top: none;
                border-left: 1px solid var(--border-color);
                padding: 0 10px;
                background: transparent;
                margin-right: auto;
                align-items: center;
            }
        }

        @@media (max-width: 576px) {
            .pw-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .pw-title {
                font-size: 36px;
            }

            .pw-subtitle {
                font-size: 15px;
                margin-bottom: 30px;
            }

            .pw-card-icon {
                height: 100px;
            }
        }
    </style>
</head>
<body>

