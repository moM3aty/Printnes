        <div class="scene-bg-picker">
            <label for="scene-bg-color"><i class="fas fa-palette"></i> الخلفية المضيئة</label>
            <input type="color" id="scene-bg-color" class="simple-color" style="border-radius: 50%;" value="#cbd5e1" oninput="changeSceneBackground()">
        </div>

        <div class="bottom-bar">
            <button class="btn-bottom" onclick="resetDesign()"><i class="fas fa-sync-alt"></i> <span>مسح</span></button>
            <button class="btn-cart" onclick="saveDesignData()"><i class="fas fa-shopping-bag"></i> اعتمـاد للسلة</button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tween.js/18.6.4/tween.umd.js"></script>

    <script>
        function toggleMobileTab(tab) {
            if(window.innerWidth > 1200) return;
            const settingsPanel = document.getElementById('panel-settings');
            const designPanel = document.getElementById('design-wrapper');
            const btnSet = document.getElementById('tab-settings-btn');
            const btnDes = document.getElementById('tab-design-btn');

            if (tab === 'settings') {
                settingsPanel.style.display = 'flex'; designPanel.style.display = 'none';
                btnSet.classList.add('active'); btnDes.classList.remove('active');
            } else {
                settingsPanel.style.display = 'none'; designPanel.style.display = 'flex';
                btnDes.classList.add('active'); btnSet.classList.remove('active');
                setTimeout(resizeCanvasesToFitUI, 100);
            }
        }

        window.addEventListener('resize', () => {
            if(window.innerWidth > 1200) {
                document.getElementById('panel-settings').style.display = 'flex';
                document.getElementById('design-wrapper').style.display = 'flex';
                document.getElementById('mobile-tabs').style.display = 'none';
            } else {
                document.getElementById('mobile-tabs').style.display = 'flex';
                if(!document.getElementById('tab-design-btn').classList.contains('active')) toggleMobileTab('settings');
            }
        });

        const BOX_CONFIGS = {
            'mailer': [ { id: 'top', name: 'أعلى', icon: 'fa-cube' }, { id: 'front', name: 'الأمام', icon: 'fa-box' }, { id: 'right', name: 'يمين', icon: 'fa-box' }, { id: 'back', name: 'الخلف', icon: 'fa-box' }, { id: 'left', name: 'يسار', icon: 'fa-box' }, { id: 'bottom', name: 'أسفل', icon: 'fa-cube' }, { id: 'inside', name: 'الداخل', icon: 'fa-box-open' } ],
            'rigid': [ { id: 'top', name: 'الغطاء', icon: 'fa-cube' }, { id: 'bottom', name: 'القاعدة', icon: 'fa-cube' }, { id: 'front', name: 'الأمام', icon: 'fa-box' }, { id: 'right', name: 'يمين', icon: 'fa-box' }, { id: 'back', name: 'الخلف', icon: 'fa-box' }, { id: 'left', name: 'يسار', icon: 'fa-box' } ],
            'folding': [ { id: 'front', name: 'الأمام', icon: 'fa-box' }, { id: 'right', name: 'يمين', icon: 'fa-box' }, { id: 'back', name: 'الخلف', icon: 'fa-box' }, { id: 'left', name: 'يسار', icon: 'fa-box' }, { id: 'top', name: 'أعلى', icon: 'fa-cube' }, { id: 'bottom', name: 'أسفل', icon: 'fa-cube' } ],
            'shipping': [ { id: 'top', name: 'أعلى', icon: 'fa-cube' }, { id: 'front', name: 'الأمام', icon: 'fa-box' }, { id: 'right', name: 'يمين', icon: 'fa-box' }, { id: 'back', name: 'الخلف', icon: 'fa-box' }, { id: 'left', name: 'يسار', icon: 'fa-box' }, { id: 'bottom', name: 'أسفل', icon: 'fa-cube' } ]
        };

        const ALL_POSSIBLE_FACES = ['top', 'bottom', 'front', 'back', 'left', 'right', 'inside'];
        let currentType = 'mailer'; let activeFace = 'top'; let isBoxOpen = false; let userCustomizedColors = {};
        const PIXELS_PER_CM = 40; let canvases = {}; let textures = {}; let activeFabricObj = null;
        let scene, camera, renderer, controls, mainBoxGroup; let animatedParts = [];

        document.addEventListener('DOMContentLoaded', () => {
            setupFabricEngine(); setupThreeEngine();
            if(window.innerWidth <= 1200) { document.getElementById('mobile-tabs').style.display = 'flex'; toggleMobileTab('settings'); }
            const urlParams = new URLSearchParams(window.location.search);
            const designId = urlParams.get('designId');
            if (designId) loadDesignFromServer(designId);
            handleSizeChange(); onMaterialChange();
        });

        function getCurrentMaterialSettings() {
            const matSelect = document.getElementById('box-material');
            const selectedOpt = matSelect.options[matSelect.selectedIndex];
            return { color: selectedOpt.getAttribute('data-color') || '#ffffff', isGlossy: selectedOpt.getAttribute('data-glossy') === 'true' };
        }

        function getDefaultFaceColor(faceId) {
            const matSettings = getCurrentMaterialSettings();
            if (faceId === 'inside') {
                const val = document.getElementById('box-material').value;
                if (val.includes('kraft')) return '#a8835a';
                return '#f1f5f9';
            }
            const val = document.getElementById('box-material').value;
            if (val.includes('kraft') && faceId !== 'inside') return '#c29b70';
            return matSettings.color;
        }

        function onMaterialChange() {
            const defaultMatColor = getDefaultFaceColor(activeFace);
            ALL_POSSIBLE_FACES.forEach(face => {
                if (canvases[face] && !userCustomizedColors[face]) {
                    canvases[face].backgroundColor = getDefaultFaceColor(face);
                    canvases[face].renderAll();
                }
            });
            if(!userCustomizedColors[activeFace]) { document.getElementById('face-bg-color').value = defaultMatColor; }
            updateGeometry();
        }

        function enterStudio(type) {
            document.getElementById('box-type').value = type;
            const welcome = document.getElementById('premium-welcome');
            welcome.style.opacity = '0'; welcome.style.transform = 'scale(1.05)';
            setTimeout(() => {
                welcome.style.display = 'none'; changeBoxType(); handleSizeChange();
                if(mainBoxGroup) {
                    mainBoxGroup.position.y += 10; mainBoxGroup.rotation.y = Math.PI;
                    new TWEEN.Tween(mainBoxGroup.position).to({y: mainBoxGroup.position.y - 10}, 1500).easing(TWEEN.Easing.Cubic.Out).start();
                    new TWEEN.Tween(mainBoxGroup.rotation).to({y: 0}, 1500).easing(TWEEN.Easing.Cubic.Out).start();
                }
            }, 600);
        }

        async function loadDesignFromServer(id) {
            const welcome = document.getElementById('premium-welcome');
            const overlay = document.getElementById('loading-overlay');
            welcome.style.display = 'none'; overlay.style.display = 'flex';
            try {
                const response = await fetch(`/Studio/GetDesignData?id=${id}`);
                const result = await response.json();
                if (result.success && result.data) {
                    const data = result.data;
                    let typeVal = 'mailer';
                    if(data.productType.includes('طوي') || data.productType.includes('Folding')) typeVal = 'folding';
                    else if(data.productType.includes('صلب') || data.productType.includes('Rigid')) typeVal = 'rigid';
                    else if(data.productType.includes('شحن') || data.productType.includes('Shipping')) typeVal = 'shipping';

                    document.getElementById('box-type').value = typeVal;
                    document.getElementById('dim-l').value = data.length;
                    document.getElementById('dim-w').value = data.width;
                    document.getElementById('dim-d').value = data.height;

                    const matSelect = document.getElementById('box-material');
                    for (let i = 0; i < matSelect.options.length; i++) {
                        if (matSelect.options[i].value === data.colorHex) { matSelect.selectedIndex = i; break; }
                    }

                    changeBoxType();
                    document.getElementById('size-preset').value = 'custom';
                    document.getElementById('custom-dim-box').classList.add('active');

                    const parsedJson = JSON.parse(data.canvasJsonData);
                    let loadedCount = 0;
                    const facesToLoad = Object.keys(parsedJson).filter(k => canvases[k]);
                    if (facesToLoad.length === 0) { updateGeometry(); overlay.style.display = 'none'; return; }

                    facesToLoad.forEach(face => {
                        canvases[face].loadFromJSON(parsedJson[face], () => {
                            canvases[face].renderAll(); textures[face].needsUpdate = true; loadedCount++;
                            if(loadedCount === facesToLoad.length) { updateGeometry(); overlay.style.display = 'none'; showToast('تم جلب بيانات التصميم بنجاح'); }
                        });
                    });
                } else throw new Error(result.message || 'بيانات غير صالحة');
            } catch (e) {
                console.error(e); showToast('حدث خطأ أثناء جلب التصميم'); overlay.style.display = 'none';
            }
        }

        function showToast(msg) {
            const t = document.getElementById('toast'); document.getElementById('toast-msg').innerText = msg;
            t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 3000);
        }

        function changeSceneBackground() {
            const color = document.getElementById('scene-bg-color').value;
            document.getElementById('studio-workspace').style.background = `radial-gradient(circle at 50% 50%, #ffffff 0%, ${color} 100%)`;
        }

        function syncQty(source) {
            const slider = document.getElementById('qty-slider'); const input = document.getElementById('box-qty');
            if (source === 'slider') input.value = slider.value; else slider.value = input.value;
            calculatePrice();
        }

        function handleSizeChange() {
            const preset = document.getElementById('size-preset').value;
            const customBox = document.getElementById('custom-dim-box');
            if (preset === 'custom') { customBox.classList.add('active'); }
            else {
                customBox.classList.remove('active');
                if(preset) {
                    const dims = preset.split('x');
                    if(dims.length === 3) { document.getElementById('dim-l').value = dims[0]; document.getElementById('dim-w').value = dims[1]; document.getElementById('dim-d').value = dims[2]; updateGeometry(); }
                }
            }
        }

        function applyCustomDims() { document.getElementById('size-preset').value = 'custom'; updateGeometry(); }

        function changeBoxType() {
            currentType = document.getElementById('box-type').value;
            const config = BOX_CONFIGS[currentType];
            isBoxOpen = false;
            const selector = document.getElementById('face-selector'); selector.innerHTML = '';

            if (currentType === 'mailer' || currentType === 'rigid') {
                const btnOpen = document.createElement('button');
                btnOpen.className = 'face-btn action-btn'; btnOpen.id = 'btn-anim-toggle';
                btnOpen.innerHTML = `<i class="fas fa-box-open"></i> <span>فتح</span>`;
                btnOpen.onclick = toggle3DAnimation; selector.appendChild(btnOpen);
            }

            config.forEach((f, idx) => {
                const btn = document.createElement('button');
                btn.className = `face-btn ${idx === 0 ? 'active' : ''}`; btn.id = `btn-face-${f.id}`;
                btn.innerHTML = `<i class="fas ${f.icon}"></i> <span>${f.name}</span>`;
                btn.onclick = () => switchActiveFace(f.id); selector.appendChild(btn);
            });

            const zoomHtml = `<div class="zoom-controls"><button class="zoom-btn" onclick="zoom3D(true)" title="تقريب المشهد"><i class="fas fa-plus"></i></button><button class="zoom-btn" onclick="zoom3D(false)" title="إبعاد المشهد"><i class="fas fa-minus"></i></button></div>`;
            selector.insertAdjacentHTML('beforeend', zoomHtml);
            switchActiveFace(config[0].id); updateGeometry();
        }

        function switchActiveFace(faceId) {
            activeFace = faceId;
            document.querySelectorAll('.face-btn').forEach(b => b.classList.remove('active'));
            const btn = document.getElementById(`btn-face-${faceId}`);
            if(btn) btn.classList.add('active');

            ALL_POSSIBLE_FACES.forEach(f => {
                const wrapper = document.getElementById(`wrap-${f}`);
                if (wrapper) wrapper.style.display = (f === faceId) ? 'block' : 'none';
            });

            if(canvases[faceId]) {
                const bg = canvases[faceId].backgroundColor || getDefaultFaceColor(faceId);
                document.getElementById('face-bg-color').value = bg;
                canvases[faceId].discardActiveObject(); canvases[faceId].renderAll();
            }

            resizeCanvasesToFitUI(); toggleTrashBtn(false); document.getElementById('text-properties').style.display = 'none'; moveCameraToFace(faceId);
        }

        function moveCameraToFace(faceId) {
            if(!camera || !controls) return;
            const L = parseFloat(document.getElementById('dim-l').value) || 15;
            const W = parseFloat(document.getElementById('dim-w').value) || 10;
            const D = parseFloat(document.getElementById('dim-d').value) || 5;

            const maxDim = Math.max(L, W, D);
            const isMobile = window.innerWidth <= 1200;
            const distMultiplier = isMobile ? 3 : 2;
            const dist = maxDim * distMultiplier + 15;

            let targetPos = new THREE.Vector3(); let targetLook = new THREE.Vector3(0,0,0);

            switch(faceId) {
                case 'top': targetPos.set(0, dist, 0.1); break;
                case 'bottom': targetPos.set(0, -dist, 0.1); break;
                case 'front': targetPos.set(0, 0, dist); break;
                case 'back': targetPos.set(0, 0, -dist); break;
                case 'left': targetPos.set(-dist, 0, 0); break;
                case 'right': targetPos.set(dist, 0, 0); break;
                case 'inside':
                    if(!isBoxOpen && document.getElementById('btn-anim-toggle')) toggle3DAnimation();
                    targetPos.set(0, dist * 1.2, dist * 0.5); break;
            }

            new TWEEN.Tween(camera.position).to({x: targetPos.x, y: targetPos.y, z: targetPos.z}, 1000).easing(TWEEN.Easing.Cubic.Out).start();
            new TWEEN.Tween(controls.target).to({x: targetLook.x, y: targetLook.y, z: targetLook.z}, 1000).easing(TWEEN.Easing.Cubic.Out).start();
        }

        function zoom3D(zoomIn) {
            if(!camera || !controls) return;
            const zoomSpeed = 5; const dir = new THREE.Vector3();
            camera.getWorldDirection(dir);
            camera.position.addScaledVector(dir, zoomIn ? zoomSpeed : -zoomSpeed);
            controls.update();
        }

        function setupFabricEngine() {
            fabric.Object.prototype.transparentCorners = false;
            fabric.Object.prototype.cornerColor = 'var(--primary)';
            fabric.Object.prototype.borderColor = 'var(--primary)';
            fabric.Object.prototype.cornerSize = 10;

            const container = document.getElementById('canvas-wrapper-inner');
            const trashBtnHtml = '<button class="btn-trash" id="btn-delete-obj" onclick="deleteObject()"><i class="fas fa-trash"></i></button>';
            container.innerHTML = trashBtnHtml;

            ALL_POSSIBLE_FACES.forEach(face => {
                const div = document.createElement('div');
                div.id = `wrap-${face}`; div.style.display = 'none';
                div.innerHTML = `<canvas id="cvs-${face}"></canvas>`;
                container.prepend(div);

                const cvs = new fabric.Canvas(`cvs-${face}`, { backgroundColor: getDefaultFaceColor(face), preserveObjectStacking: true });
                canvases[face] = cvs;

                cvs.on('after:render', () => { if (textures[face]) textures[face].needsUpdate = true; });
                cvs.on('selection:created', onObjectSelected);
                cvs.on('selection:updated', onObjectSelected);
                cvs.on('selection:cleared', () => { toggleTrashBtn(false); document.getElementById('text-properties').style.display = 'none'; activeFabricObj = null; });
            });
        }

        function resizeCanvasesToFitUI() {
            const L = parseFloat(document.getElementById('dim-l').value) || 15;
            const W = parseFloat(document.getElementById('dim-w').value) || 10;
            const D = parseFloat(document.getElementById('dim-d').value) || 5;

            let dimMap = {
                'top': { w: L, h: W }, 'bottom': { w: L, h: W }, 'inside': { w: L, h: W },
                'front': { w: L, h: D }, 'back': { w: L, h: D },
                'left': { w: W, h: D }, 'right': { w: W, h: D }
            };

            if (currentType === 'folding') {
                dimMap = {
                    'front': { w: L, h: D }, 'back': { w: L, h: D },
                    'left': { w: W, h: D }, 'right': { w: W, h: D },
                    'top': { w: L, h: W }, 'bottom': { w: L, h: W }
                };
            }

            const isMobile = window.innerWidth <= 1200;
            const maxUiSizeW = isMobile ? window.innerWidth - 120 : 250;
            const maxUiSizeH = isMobile ? 180 : 220;

            ALL_POSSIBLE_FACES.forEach(face => {
                if(!canvases[face] || !dimMap[face]) return;
                const cvs = canvases[face];
                const internalW = dimMap[face].w * PIXELS_PER_CM;
                const internalH = dimMap[face].h * PIXELS_PER_CM;
                const scale = Math.min(maxUiSizeW / internalW, maxUiSizeH / internalH);
                const cssW = internalW * scale; const cssH = internalH * scale;

                cvs.setDimensions({ width: internalW, height: internalH }, { backstoreOnly: true });
                cvs.setDimensions({ width: cssW, height: cssH }, { cssOnly: true });
                cvs.setZoom(scale);

                const wrap = document.getElementById(`wrap-${face}`);
                if(wrap) { wrap.style.width = `${cssW}px`; wrap.style.height = `${cssH}px`; }
                cvs.renderAll();
            });
        }

        function changeBackgroundColor() {
            const color = document.getElementById('face-bg-color').value;
            userCustomizedColors[activeFace] = true;
            if(canvases[activeFace]) { canvases[activeFace].backgroundColor = color; canvases[activeFace].renderAll(); }
        }

        function addText() {
            const cvs = canvases[activeFace];
            const text = new fabric.IText('نص جديد', { originX: 'center', originY: 'center', left: cvs.width / (2 * cvs.getZoom()), top: cvs.height / (2 * cvs.getZoom()), fontFamily: 'Cairo', fill: '#1f2937', fontSize: 60, fontWeight: 'bold' });
            cvs.add(text); cvs.setActiveObject(text);
        }

        function updateTextProperty(property, value) {
            if (!activeFabricObj || activeFabricObj.type !== 'i-text') return;
            activeFabricObj.set(property, value); canvases[activeFace].renderAll();
        }

        function uploadImage(e) {
            const file = e.target.files[0]; if (!file) return;
            const reader = new FileReader();
            reader.onload = function (f) {
                fabric.Image.fromURL(f.target.result, (img) => {
                    const cvs = canvases[activeFace];
                    const centerW = cvs.width / (2 * cvs.getZoom()); const centerH = cvs.height / (2 * cvs.getZoom());
                    const scale = Math.min((centerW * 1.5) / img.width, (centerH * 1.5) / img.height);
                    img.set({ originX: 'center', originY: 'center', left: centerW, top: centerH, scaleX: scale, scaleY: scale });
                    cvs.add(img); cvs.setActiveObject(img);
                });
            };
            reader.readAsDataURL(file); e.target.value = '';
        }

        function onObjectSelected(e) {
            activeFabricObj = e.selected[0];
            if(!activeFabricObj) return;

            activeFabricObj.set({ cornerSize: 12 / canvases[activeFace].getZoom() });
            toggleTrashBtn(true);

            const textPropsBox = document.getElementById('text-properties');
            if (activeFabricObj.type === 'i-text') {
                textPropsBox.style.display = 'flex';
                document.getElementById('text-color-picker').value = activeFabricObj.fill;
                document.getElementById('text-font-family').value = activeFabricObj.fontFamily;
            } else { textPropsBox.style.display = 'none'; }
        }

        function toggleTrashBtn(show) {
            const btn = document.getElementById('btn-delete-obj');
            if(btn) btn.style.display = show ? 'flex' : 'none';
        }

        function alignObject(pos) {
            if(!activeFabricObj) return;
            const cvs = canvases[activeFace];
            const cw = cvs.width / cvs.getZoom(); const ch = cvs.height / cvs.getZoom();
            if (pos === 'center') { activeFabricObj.set({ left: cw/2, top: ch/2 }); }
            else if (pos === 'fit') { const s = Math.min(cw/activeFabricObj.width, ch/activeFabricObj.height); activeFabricObj.set({ scaleX: s, scaleY: s, left: cw/2, top: ch/2 }); }
            else if (pos === 'stretch') { activeFabricObj.set({ scaleX: cw/activeFabricObj.width, scaleY: ch/activeFabricObj.height, left: cw/2, top: ch/2 }); }
            activeFabricObj.setCoords(); cvs.renderAll();
        }

        function deleteObject() { if(activeFabricObj) { canvases[activeFace].remove(activeFabricObj); toggleTrashBtn(false); document.getElementById('text-properties').style.display='none'; } }
        document.addEventListener('keydown', (e) => { if((e.key === 'Delete' || e.key === 'Backspace') && e.target.tagName !== 'INPUT') deleteObject(); });

        function resetDesign() {
            if(confirm("هل أنت متأكد من مسح جميع التصاميم؟")) {
                userCustomizedColors = {};
                ALL_POSSIBLE_FACES.forEach(f => {
                    if(canvases[f]){
                        canvases[f].clear();
                        canvases[f].backgroundColor = getDefaultFaceColor(f);
                        canvases[f].renderAll();
                    }
                });
                document.getElementById('face-bg-color').value = getDefaultFaceColor(activeFace);
                document.getElementById('text-properties').style.display = 'none';
                updateGeometry();
                showToast('تمت إعادة الضبط بنجاح');
            }
        }

        // --- Three.js ---
        function setupThreeEngine() {
            const container = document.getElementById('three-canvas');
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(40, container.clientWidth / container.clientHeight, 0.1, 1000);

            const isMobile = window.innerWidth <= 1200;
            camera.position.set(isMobile ? 40 : 30, isMobile ? 60 : 40, isMobile ? 80 : 50);

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, preserveDrawingBuffer: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.outputEncoding = THREE.sRGBEncoding;
            container.appendChild(renderer.domElement);

            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true; controls.dampingFactor = 0.05; controls.enablePan = false;

            scene.add(new THREE.AmbientLight(0xffffff, 0.8));
            const dl = new THREE.DirectionalLight(0xffffff, 0.5); dl.position.set(30, 60, 30); scene.add(dl);
            const fl = new THREE.DirectionalLight(0xffffff, 0.2); fl.position.set(-30, 30, -30); scene.add(fl);

            ALL_POSSIBLE_FACES.forEach(face => {
                if(canvases[face]) {
                    const tex = new THREE.CanvasTexture(canvases[face].getElement());
                    tex.anisotropy = renderer.capabilities.getMaxAnisotropy(); tex.encoding = THREE.sRGBEncoding;
                    textures[face] = tex;
                }
            });

            const animate = (time) => { requestAnimationFrame(animate); TWEEN.update(time); controls.update(); renderer.render(scene, camera); };
            animate();
            window.addEventListener('resize', () => { camera.aspect = container.clientWidth / container.clientHeight; camera.updateProjectionMatrix(); renderer.setSize(container.clientWidth, container.clientHeight); });
        }

        function createHingedPanel(w, h, d, px, py, pz, outFace, inFace, rotFix = 0) {
            const matSettings = getCurrentMaterialSettings();
            const val = document.getElementById('box-material').value;
            const isKraft = val.includes('kraft');

            const rgh = matSettings.isGlossy ? 0.1 : (isKraft ? 0.9 : 0.8);
            const mtl = matSettings.isGlossy ? 0.3 : 0.0;

            const edgeColor = isKraft ? 0xa8835a : matSettings.color;
            const edgeM = new THREE.MeshStandardMaterial({ color: edgeColor, roughness: 0.9, metalness: 0 });

            let fM = edgeM, bM = edgeM;

            if(outFace) {
                if(textures[outFace]) {
                    textures[outFace].center.set(0.5, 0.5); textures[outFace].rotation = rotFix;
                    fM = new THREE.MeshStandardMaterial({map: textures[outFace], roughness: rgh, metalness: mtl, color: 0xffffff});
                } else {
                    const outColor = isKraft ? 0xc29b70 : matSettings.color;
                    fM = new THREE.MeshStandardMaterial({color: outColor, roughness: rgh, metalness: mtl});
                }
            }
            if(inFace) {
                if(textures[inFace]) {
                    textures[inFace].center.set(0.5, 0.5);
                    bM = new THREE.MeshStandardMaterial({map: textures[inFace], roughness: rgh, metalness: mtl, color: 0xffffff});
                } else {
                    const inColor = isKraft ? 0xa8835a : (matSettings.color === '#ffffff' ? '#f1f5f9' : matSettings.color);
                    bM = new THREE.MeshStandardMaterial({color: inColor, roughness: rgh, metalness: mtl});
                }
            }

            const geo = new THREE.BoxGeometry(w, h, d); geo.translate(px, py, pz);
            const mesh = new THREE.Mesh(geo, [edgeM, edgeM, edgeM, edgeM, bM, fM]);

            const line = new THREE.LineSegments(new THREE.EdgesGeometry(geo), new THREE.LineBasicMaterial({ color: 0x000000, transparent:true, opacity: 0.05 }));
            mesh.add(line);

            const hinge = new THREE.Group(); hinge.add(mesh);
            return { mesh, hinge };
        }

        function updateGeometry() {
            resizeCanvasesToFitUI(); calculatePrice();

            if (!scene) return;
            if (mainBoxGroup) {
                scene.remove(mainBoxGroup);
                mainBoxGroup.traverse(c => { if(c.isMesh){ c.geometry.dispose(); if(Array.isArray(c.material)) c.material.forEach(m=>m.dispose()); else c.material.dispose();} });
            }

            mainBoxGroup = new THREE.Group(); animatedParts = [];

            const L = parseFloat(document.getElementById('dim-l').value) || 15;
            const W = parseFloat(document.getElementById('dim-w').value) || 10;
            const D = parseFloat(document.getElementById('dim-d').value) || 5;
            const T = 0.1;

            if (currentType === 'mailer') {
                const bot = createHingedPanel(L, W, T, 0,0,0, 'bottom', 'inside', 0).mesh; mainBoxGroup.add(bot);
                const back = createHingedPanel(L, D, T, 0, D/2, 0, 'back', null, 0); back.hinge.position.set(0, W/2, 0); mainBoxGroup.add(back.hinge);
                const front = createHingedPanel(L, D, T, 0, -D/2, 0, 'front', null, Math.PI); front.hinge.position.set(0, -W/2, 0); mainBoxGroup.add(front.hinge);
                const left = createHingedPanel(D, W-T*2, T, -D/2, 0, 0, 'left', null, Math.PI/2); left.hinge.position.set(-L/2, 0, 0); mainBoxGroup.add(left.hinge);
                const right = createHingedPanel(D, W-T*2, T, D/2, 0, 0, 'right', null, -Math.PI/2); right.hinge.position.set(L/2, 0, 0); mainBoxGroup.add(right.hinge);
                const top = createHingedPanel(L, W, T, 0, W/2, 0, 'top', 'inside', Math.PI); top.hinge.position.set(0, D, 0); back.mesh.add(top.hinge);
                const flap = createHingedPanel(L-0.6, D*0.8, T, 0, D*0.4, 0, null, 'inside', 0); flap.hinge.position.set(0, W - T * 1.5, -T); top.mesh.add(flap.hinge);

                back.hinge.rotation.x = Math.PI/2; front.hinge.rotation.x = -Math.PI/2; left.hinge.rotation.y = Math.PI/2; right.hinge.rotation.y = -Math.PI/2;

                animatedParts.push({ obj: top.hinge, closedRot: { x: Math.PI/2 }, openRot: { x: 0 } });
                animatedParts.push({ obj: flap.hinge, closedRot: { x: Math.PI/2 + 0.05 }, openRot: { x: 0.1 } });

                if(isBoxOpen) { top.hinge.rotation.x = 0; flap.hinge.rotation.x = 0.1; }
                else { top.hinge.rotation.x = Math.PI/2; flap.hinge.rotation.x = Math.PI/2 + 0.05; }

                mainBoxGroup.rotation.x = -Math.PI/2; mainBoxGroup.position.y = -D/2;
            }
            else if (currentType === 'rigid') {
                const matSettings = getCurrentMaterialSettings();
                const val = document.getElementById('box-material').value;
                const isKraft = val.includes('kraft');

                const rgh = matSettings.isGlossy ? 0.1 : (isKraft ? 0.9 : 0.8);
                const mtl = matSettings.isGlossy ? 0.3 : 0.0;

                const getMat = (faceId) => {
                    if(!faceId) return new THREE.MeshStandardMaterial({ color: isKraft ? 0xa8835a : 0xe2e8f0, roughness: 0.9, metalness: 0 });

                    if(textures[faceId]) {
                        textures[faceId].center.set(0.5, 0.5);
                        if (faceId === 'top') textures[faceId].rotation = Math.PI;
                        return new THREE.MeshStandardMaterial({map: textures[faceId], roughness: rgh, metalness: mtl, color: 0xffffff});
                    }
                    const colorStr = isKraft ? (faceId === 'inside' ? 0xa8835a : 0xc29b70) : (faceId === 'inside' ? '#f1f5f9' : matSettings.color);
                    return new THREE.MeshStandardMaterial({color: colorStr, roughness: rgh, metalness: mtl});
                };

                const edgeMat = getMat(null);

                const createSolidBox = (w, h, d, isLid) => {
                    const grp = new THREE.Group();
                    const mY = isLid ? new THREE.Mesh(new THREE.BoxGeometry(w, T, d), [edgeMat, edgeMat, getMat('top'), getMat('inside'), edgeMat, edgeMat])
                             : new THREE.Mesh(new THREE.BoxGeometry(w, T, d), [edgeMat, edgeMat, getMat('inside'), getMat('bottom'), edgeMat, edgeMat]);
                    mY.position.y = isLid ? h/2 - T/2 : -h/2 + T/2; grp.add(mY);

                    const mB = new THREE.Mesh(new THREE.BoxGeometry(w, h, T), [edgeMat, edgeMat, edgeMat, edgeMat, getMat('inside'), isLid ? getMat('back') : edgeMat]);
                    mB.position.z = -d/2 + T/2; grp.add(mB);

                    const mF = new THREE.Mesh(new THREE.BoxGeometry(w, h, T), [edgeMat, edgeMat, edgeMat, edgeMat, isLid ? getMat('front') : edgeMat, getMat('inside')]);
                    mF.position.z = d/2 - T/2; grp.add(mF);

                    const mL = new THREE.Mesh(new THREE.BoxGeometry(T, h, d-T*2), [getMat('inside'), isLid ? getMat('left') : edgeMat, edgeMat, edgeMat, edgeMat, edgeMat]);
                    mL.position.x = -w/2 + T/2; grp.add(mL);

                    const mR = new THREE.Mesh(new THREE.BoxGeometry(T, h, d-T*2), [isLid ? getMat('right') : edgeMat, getMat('inside'), edgeMat, edgeMat, edgeMat, edgeMat]);
                    mR.position.x = w/2 - T/2; grp.add(mR);

                    grp.children.forEach(c => {
                        const edges = new THREE.LineSegments(new THREE.EdgesGeometry(c.geometry), new THREE.LineBasicMaterial({ color: 0x000000, transparent:true, opacity: 0.05 }));
                        c.add(edges);
                    });
                    return grp;
                };

                const baseGrp = createSolidBox(L, D, W, false); mainBoxGroup.add(baseGrp);
                const lidD = D * 0.75; const lidGrp = createSolidBox(L + T*2.5, lidD, W + T*2.5, true);
                lidGrp.position.y = D/2 - lidD/2 + T; mainBoxGroup.add(lidGrp);

                animatedParts.push({ obj: lidGrp, closedPos: { x:0, y: D/2 - lidD/2 + T, z: 0 }, openPos: { x:0, y: D * 1.5, z: W/1.2 }, closedRot: { x: 0 }, openRot: { x: -Math.PI/6 } });

                if(isBoxOpen) { lidGrp.position.set(0, D*1.5, W/1.2); lidGrp.rotation.x = -Math.PI/6; }
            }
            else if (currentType === 'folding' || currentType === 'shipping') {
                const matSettings = getCurrentMaterialSettings();
                const val = document.getElementById('box-material').value;
                const isKraft = val.includes('kraft');

                const rgh = matSettings.isGlossy ? 0.1 : (isKraft ? 0.9 : 0.8);
                const mtl = matSettings.isGlossy ? 0.3 : 0.0;

                const getMat = (faceId) => {
                    if(!textures[faceId]) {
                        const c = isKraft ? (faceId === 'inside' ? '#a8835a' : '#c29b70') : (faceId === 'inside' ? '#f1f5f9' : matSettings.color);
                        return new THREE.MeshStandardMaterial({color: c, roughness: rgh, metalness: mtl});
                    }

                    textures[faceId].center.set(0.5, 0.5);
                    if(faceId === 'top') textures[faceId].rotation = Math.PI/2;
                    if(faceId === 'bottom') textures[faceId].rotation = -Math.PI/2;
                    return new THREE.MeshStandardMaterial({map: textures[faceId], roughness: rgh, metalness: mtl, color: 0xffffff});
                };

                const b = new THREE.Mesh(new THREE.BoxGeometry(L, D, W), [ getMat('right'), getMat('left'), getMat('top'), getMat('bottom'), getMat('front'), getMat('back') ]);
                const edges = new THREE.LineSegments(new THREE.EdgesGeometry(b.geometry), new THREE.LineBasicMaterial({color:0x000000, opacity:0.1, transparent:true}));
                b.add(edges);

                if (currentType === 'folding') {
                    const slitTop = new THREE.Mesh(new THREE.PlaneGeometry(L - 0.04, 0.04), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.15, transparent:true}));
                    slitTop.rotation.x = -Math.PI/2; slitTop.position.set(0, D/2 + 0.001, W/2 - 0.06); b.add(slitTop);
                    const slitTopL = new THREE.Mesh(new THREE.PlaneGeometry(0.04, W/2.5), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.15, transparent:true}));
                    slitTopL.rotation.x = -Math.PI/2; slitTopL.position.set(-L/2 + 0.04, D/2 + 0.001, W/2 - W/5 - 0.02); b.add(slitTopL);
                    const slitTopR = new THREE.Mesh(new THREE.PlaneGeometry(0.04, W/2.5), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.15, transparent:true}));
                    slitTopR.rotation.x = -Math.PI/2; slitTopR.position.set(L/2 - 0.04, D/2 + 0.001, W/2 - W/5 - 0.02); b.add(slitTopR);
                    const slitBot = new THREE.Mesh(new THREE.PlaneGeometry(L - 0.04, 0.04), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.15, transparent:true}));
                    slitBot.rotation.x = Math.PI/2; slitBot.position.set(0, -D/2 - 0.001, -W/2 + 0.06); b.add(slitBot);
                    const slitBotL = new THREE.Mesh(new THREE.PlaneGeometry(0.04, W/2.5), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.15, transparent:true}));
                    slitBotL.rotation.x = Math.PI/2; slitBotL.position.set(-L/2 + 0.04, -D/2 - 0.001, -W/2 + W/5 + 0.02); b.add(slitBotL);
                    const slitBotR = new THREE.Mesh(new THREE.PlaneGeometry(0.04, W/2.5), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.15, transparent:true}));
                    slitBotR.rotation.x = Math.PI/2; slitBotR.position.set(L/2 - 0.04, -D/2 - 0.001, -W/2 + W/5 + 0.02); b.add(slitBotR);
                } else {
                    const slitTop = new THREE.Mesh(new THREE.PlaneGeometry(L, 0.05), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.2, transparent:true}));
                    slitTop.rotation.x = -Math.PI/2; slitTop.position.set(0, D/2 + 0.001, 0); b.add(slitTop);
                    const slitBot = new THREE.Mesh(new THREE.PlaneGeometry(L, 0.05), new THREE.MeshBasicMaterial({color:0x000000, opacity:0.2, transparent:true}));
                    slitBot.rotation.x = Math.PI/2; slitBot.position.set(0, -D/2 - 0.001, 0); b.add(slitBot);
                }
                mainBoxGroup.add(b);
            }

            const box3 = new THREE.Box3().setFromObject(mainBoxGroup);
            const center = box3.getCenter(new THREE.Vector3());
            mainBoxGroup.position.sub(center);
            scene.add(mainBoxGroup);
        }

        function toggle3DAnimation() {
            if(animatedParts.length === 0) { return; }
            isBoxOpen = !isBoxOpen;
            const btn = document.getElementById('btn-anim-toggle');
            if(btn) { btn.innerHTML = isBoxOpen ? `<i class="fas fa-box"></i> <span>إغلاق</span>` : `<i class="fas fa-box-open"></i> <span>فتح</span>`; }

            animatedParts.forEach((part, idx) => {
                const tr = isBoxOpen ? part.openRot : part.closedRot;
                const tp = isBoxOpen ? part.openPos : part.closedPos;
                const dly = idx * 100;
                if(tr) new TWEEN.Tween(part.obj.rotation).to(tr, 800).delay(dly).easing(TWEEN.Easing.Quadratic.InOut).start();
                if(tp) new TWEEN.Tween(part.obj.position).to(tp, 800).delay(dly).easing(TWEEN.Easing.Quadratic.InOut).start();
            });
        }

        function calculatePrice() {
            const l = parseFloat(document.getElementById('dim-l').value) || 15;
            const w = parseFloat(document.getElementById('dim-w').value) || 10;
            const d = parseFloat(document.getElementById('dim-d').value) || 5;
            const areaCm2 = 2 * ((l * w) + (l * d) + (w * d));

            const matSelect = document.getElementById('box-material');
            const selectedOpt = matSelect.options[matSelect.selectedIndex];
            const costPerCm2 = parseFloat(selectedOpt.getAttribute('data-cost')) || 0.015;

            let baseUnitPrice = (areaCm2 * costPerCm2) + BASE_PRINT_COST;
            const qty = parseInt(document.getElementById('box-qty').value) || 100;

            let currentDiscount = 0;
            for (let i = 0; i < DISCOUNT_TIERS.length; i++) {
                if (qty >= DISCOUNT_TIERS[i].min) { currentDiscount = DISCOUNT_TIERS[i].discount; break; }
            }

            let unitPrice = baseUnitPrice * (1 - currentDiscount);
            document.getElementById('unit-price').innerText = `${unitPrice.toFixed(2)} ر.س`;

            const list = document.getElementById('price-table-list');
            if(list) {
                list.innerHTML = '';
                const packages = [100, 250, 500, 1000, 1500, 2000, 3000];
                packages.forEach(q => {
                    let d = 0;
                    for (let i = 0; i < DISCOUNT_TIERS.length; i++) {
                        if (q >= DISCOUNT_TIERS[i].min) { d = DISCOUNT_TIERS[i].discount; break; }
                    }
                    let p = baseUnitPrice * (1 - d);
                    let li = document.createElement('li');
                    li.onclick = () => selectPackage(q);
                    li.innerHTML = `<span>${q} وحدة</span><span>${p.toFixed(2)} ر.س</span>`;
                    list.appendChild(li);
                });
            }
        }

        function togglePriceTable() {
            const list = document.getElementById('price-table-list');
            const caret = document.getElementById('pt-caret');
            list.classList.toggle('show');
            if(list.classList.contains('show')) { caret.classList.replace('fa-caret-up', 'fa-caret-down'); }
            else { caret.classList.replace('fa-caret-down', 'fa-caret-up'); }
        }

        function selectPackage(q) {
            document.getElementById('box-qty').value = q;
            document.getElementById('qty-slider').value = q;
            calculatePrice(); togglePriceTable();
        }

        document.addEventListener('click', function(e) {
            if (!e.target.closest('.price-table-wrapper')) {
                const list = document.getElementById('price-table-list');
                const caret = document.getElementById('pt-caret');
                if (list && list.classList.contains('show')) { list.classList.remove('show'); caret.classList.replace('fa-caret-down', 'fa-caret-up'); }
            }
        });

        async function saveDesignData() {
            const overlay = document.getElementById('loading-overlay');
            overlay.style.display = 'flex';

            let designJsonData = {};
            ALL_POSSIBLE_FACES.forEach(face => {
                if (canvases[face]) {
                    canvases[face].discardActiveObject();
                    designJsonData[face] = canvases[face].toJSON();
                }
            });

            if (isBoxOpen) toggle3DAnimation();

            setTimeout(async () => {
                renderer.render(scene, camera);
                const previewImg = renderer.domElement.toDataURL("image/png", 0.9);

                const boxTypeStr = document.getElementById('box-type').options[document.getElementById('box-type').selectedIndex].text;
                const matSelect = document.getElementById('box-material');
                const matStr = matSelect.options[matSelect.selectedIndex].text;
                const matInternalValue = matSelect.value;

                const L = parseFloat(document.getElementById('dim-l').value) || 15;
                const W = parseFloat(document.getElementById('dim-w').value) || 10;
                const D = parseFloat(document.getElementById('dim-d').value) || 5;
                const qty = parseInt(document.getElementById('box-qty').value) || 100;
                const unitPrice = parseFloat(document.getElementById('unit-price').innerText.replace(/[^\d.]/g, ''));
                const totalPrice = unitPrice * qty;

                const payload = {
                    ProductType: boxTypeStr,
                    Length: L, Width: W, Height: D,
                    ColorHex: matInternalValue,
                    CanvasJsonData: JSON.stringify(designJsonData),
                    PreviewImageBase64: previewImg,
                    Price: totalPrice
                };

                const cartItem = {
                    id: Date.now().toString(),
                    name: `علبة مخصصة - ${boxTypeStr}`,
                    price: unitPrice,
                    img: previewImg,
                    quantity: qty,
                    details: {
                        Sides: `${L} × ${W} × ${D} سم`,
                        PaperType: matStr,
                        Design: "جاري الحفظ...",
                        Cover: previewImg,
                        Corners: ""
                    },
                    SelectedOptionsJson: JSON.stringify({ "المقاس": `${L} × ${W} × ${D} سم`, "الخامة": matStr })
                };

                try {
                    const r = await fetch('/Studio/SaveDesign', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                    const res = await r.json();

                    if(res.success) {
                        let opt = JSON.parse(cartItem.SelectedOptionsJson);
                        opt["معرف التصميم"] = `#${res.designId}`;
                        cartItem.SelectedOptionsJson = JSON.stringify(opt);
                    }
                } catch (e) {
                    console.log('Saved Locally', e);
                } finally {
                    let cart = JSON.parse(localStorage.getItem('printnesCart')) || [];
                    cart.push(cartItem);
                    localStorage.setItem('printnesCart', JSON.stringify(cart));
                    window.location.href = '/Cart';
                }
            }, 1000);
        }

    </script>
</body>
</html>