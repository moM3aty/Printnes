        <aside class="panel panel-settings" id="panel-settings">
            <div class="panel-header">المواصفات والتسعير</div>
            <div class="panel-content">

                <select id="box-type" class="custom-select" onchange="changeBoxType()">
                    <option value="mailer">علبة بريدية</option>
