                <select id="box-material" class="custom-select" onchange="onMaterialChange()">
                    @if (settings != null && settings.Materials != null && settings.Materials.Count > 0)
                    {
                        foreach (var mat in settings.Materials)
                        {
                            <option value="@mat.InternalValue" data-color="@mat.ColorHex" data-glossy="@(mat.IsGlossy ? "true" : "false")" data-cost="@mat.CostPerCm2">@mat.Name</option>
                        }
                    }
                    else
                    {
                        <option value="white" data-color="#ffffff" data-glossy="false" data-cost="0.015">ورق مقوى أبيض</option>
                        <option value="kraft" data-color="#c29b70" data-glossy="false" data-cost="0.010">ورق كرافت بني</option>
                        <option value="supergloss" data-color="#ffffff" data-glossy="true" data-cost="0.020">ورق لامع (سوبر جلوس)</option>
                    }
                </select>

                <div class="qty-container">
                    <div class="qty-label">الكمية المطلوبة <i class="fas fa-boxes" style="color:var(--primary); margin-right: 5px;"></i></div>
                    <div class="qty-row">
                        <input type="range" class="qty-slider" id="qty-slider" min="50" max="5000" step="50" value="100" oninput="syncQty('slider')">
                        <input type="number" class="qty-input" id="box-qty" value="100" min="50" step="50" onchange="syncQty('input')">
