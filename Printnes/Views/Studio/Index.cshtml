                    <button class="btn-upload" onclick="document.getElementById('img-upload').click()"><i class="fas fa-cloud-upload-alt"></i> إضافة صورة/تصميم</button>
                    <input type="file" id="img-upload" hidden accept="image/*" onchange="uploadImage(event)">

                    <select class="custom-select" id="text-dropdown" onchange="if(this.value==='text'){addText(); this.value='';}">
                        <option value="">إضافة نص...</option>
                        <option value="text">نص جديد</option>
