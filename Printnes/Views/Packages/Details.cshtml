<!-- الملف: Views/Packages/Details.cshtml -->
@model Printnes.Models.Product
@using Printnes.Helpers
@{
    ViewData["Title"] = Model != null ? Model.NameAr : "تفاصيل البكج";
    Layout = "_Layout";

    // جلب الإعدادات ديناميكياً
    var siteSettings = SiteSettingsManager.LoadSettings();
    string waNumber = siteSettings.WhatsappNumber?.Replace("+", "") ?? "";
}

<main class="container py-5">
    <nav class="breadcrumb">
        <a href="/">الرئيسية</a> &gt;
        <a href="/Packages" style="color: var(--orange); text-decoration: none;">عروض البكجات</a> &gt;
        <span id="breadcrumb-name">@(Model != null ? Model.NameAr : "اسم البكج")</span>
    </nav>

    <div class="product-details-wrapper">
        <div class="product-image-side">
            <div class="main-img-holder">
                <img id="main-product-img" src="@(Model != null ? Model.CoverImageUrl : "")" alt="@(Model?.NameAr)">
            </div>
        </div>

        <div class="product-info-side">
            <div style="display: inline-block; background: var(--navy); color: #fff; padding: 5px 15px; border-radius: 20px; font-size: 12px; font-weight: bold; margin-bottom: 10px;">
                عرض خاص
            </div>
            <h1 id="product-title">@(Model != null ? Model.NameAr : "اسم البكج")</h1>

            <div class="short-desc" id="product-short-desc">
                @(Model != null && !string.IsNullOrEmpty(Model.DescriptionAr) ? Model.DescriptionAr : "تفاصيل هذا البكج ومميزاته تظهر هنا.")
            </div>

            <div class="tabby-box">
                <img src="https://img.icons8.com/color/48/tabby.png" width="30" alt="Tabby">
                <p>قسم مشترياتك على 4 دفعات بدون فوائد بقيمة <span id="tabby-price" style="font-weight: bold; color: var(--navy);">0</span> @siteSettings.Currency</p>
            </div>

            <div class="options-container">
                <div class="options-tabs">
                    <button class="tab-btn active">خيارات البكج</button>
                </div>
                <div class="options-body">

                    @if (ViewBag.PaperOptions != null && Enumerable.Count(ViewBag.PaperOptions) > 0)
                    {
                        <div class="form-group">
                            <label>نوع الورق *</label>
                            <select id="opt-paper" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;" onchange="calculateDynamicPrice()">
                                <option value="">-- اختر --</option>
                                @foreach (var opt in ViewBag.PaperOptions)
                                {
                                    <option value="@opt.Id">@opt.NameAr</option>
                                }
                            </select>
                        </div>
                    }

                    <!-- قائمة المقاسات مدمج معها خيار المقاس المخصص -->
                    @if (ViewBag.SizeOptions != null && Enumerable.Count(ViewBag.SizeOptions) > 0)
                    {
                        <div class="form-group">
                            <label>المقاس *</label>
                            <select id="opt-size" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;" onchange="handleSizeChange()">
                                <option value="">-- اختر --</option>
                                @foreach (var opt in ViewBag.SizeOptions)
                                {
                                    <option value="@opt.Id">@opt.NameAr</option>
                                }
                                <!-- الخيار الإضافي الذكي -->
                                @if (Model != null && Model.AllowCustomSize)
                                {
                                    <option value="custom" style="color: var(--orange); font-weight: bold;">✨ تفصيل مقاس خاص</option>
                                }
                            </select>
                        </div>

                        <!-- الحقول المخفية التي تظهر عند اختيار المقاس الخاص -->
                        <div id="custom-size-inputs" style="display: none; background: #fff5f2; border: 1px dashed var(--orange); border-radius: 8px; padding: 15px; margin-top: -10px; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
                            <div style="width: 100%; margin-bottom: 5px;">
                                <strong style="color: var(--orange); font-size: 13px;"><i class="fas fa-ruler-combined"></i> أدخل أبعادك المخصصة بالسنتيمتر (سم)</strong>
                            </div>
                            <div style="flex: 1; min-width: 80px;">
                                <label style="font-size: 12px; color: var(--navy); font-weight: bold;">الطول *</label>
                                <input type="number" id="custom-length" class="form-control" placeholder="مثال: 20" min="1" style="padding: 8px;" />
                            </div>
                            <div style="flex: 1; min-width: 80px;">
                                <label style="font-size: 12px; color: var(--navy); font-weight: bold;">العرض *</label>
                                <input type="number" id="custom-width" class="form-control" placeholder="مثال: 15" min="1" style="padding: 8px;" />
                            </div>
                            <div style="flex: 1; min-width: 80px;">
                                <label style="font-size: 12px; color: var(--navy); font-weight: bold;">الارتفاع</label>
                                <input type="number" id="custom-height" class="form-control" placeholder="للعلب" min="0" style="padding: 8px;" />
                            </div>
                            <div style="width: 100%; margin-top: 5px;">
                                <span style="font-size: 11px; color: #dc2626;"><i class="fas fa-info-circle"></i> المقاسات المخصصة يتم تحديد سعرها من قبل الإدارة بعد إرسال الطلب.</span>
                            </div>
                        </div>
                    }

                    @if (ViewBag.SidesOptions != null && Enumerable.Count(ViewBag.SidesOptions) > 0)
                    {
                        <div class="form-group">
                            <label>عدد أوجه الطباعة *</label>
                            <select id="opt-sides" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;" onchange="calculateDynamicPrice()">
                                <option value="">-- اختر --</option>
                                @foreach (var opt in ViewBag.SidesOptions)
                                {
                                    <option value="@opt.Id">@opt.NameAr</option>
                                }
                            </select>
                        </div>
                    }

                    @if (Model != null && Model.ProductExtras != null && Model.ProductExtras.Any())
                    {
                        <div class="form-group" style="margin-top: 20px; background: #fdfdfd; padding: 15px; border-radius: 8px; border: 1px solid #eee;">
                            <label style="color: var(--navy); font-weight: 800; margin-bottom: 10px; display: block;">إضافات اختيارية للبكج</label>
                            @foreach (var extra in Model.ProductExtras)
                            {
                                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; margin-bottom: 8px; font-size: 14px;">
                                    <input type="checkbox" class="extra-checkbox" value="@extra.Id" onchange="calculateDynamicPrice()" style="width: 18px; height: 18px; accent-color: var(--orange);" />
                                    @extra.NameAr <strong style="color: var(--success); margin-right: 5px;">(+@extra.Price.ToString("0.00") @siteSettings.Currency)</strong>
                                </label>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="help-center-card">
                <div class="help-content-wrap">
                    <div class="help-text">
                        <h3>تحتاج مساعدة في اتمام طلبك ؟ <i class="fab fa-whatsapp"></i></h3>
                        <p>ما عرفت تكمل طلبك أو واجهت أي مشكلة تواصل معنا على الواتس اب</p>
                        <!-- رابط الواتساب الديناميكي -->
                        <a href="https://wa.me/@waNumber" target="_blank" class="btn-click-here">اضغط هنا</a>
                    </div>
                </div>
                <img src="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" class="bg-logo-fade" alt="">
            </div>
        </div>
    </div>
</main>

<div class="sticky-footer-bar">
    <div class="container bar-content">
        <div class="price-side">
            <span class="final-price" id="sticky-price" style="font-size: 22px; color: var(--primary-color);">حدد الخيارات</span>
            <small>السعر شامل الضريبة</small>
        </div>
        <div class="action-side">
            <div class="quantity-picker">
                <button type="button" onclick="changeQty(-10)">-</button>
                <input type="number" id="prod-qty" value="@(Model != null ? Model.MinQuantity : 100)" min="@(Model != null ? Model.MinQuantity : 1)" onchange="calculateDynamicPrice()">
                <button type="button" onclick="changeQty(10)">+</button>
            </div>
            <button class="btn-add-main" onclick="addToCartFromDetails()">إضافة البكج للسلة</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currency = '@siteSettings.Currency';

        document.addEventListener("DOMContentLoaded", function() {
            calculateDynamicPrice();
        });

        // دالة لإظهار/إخفاء حقول المقاس المخصص
        function handleSizeChange() {
            const sizeSelect = document.getElementById('opt-size');
            const customInputs = document.getElementById('custom-size-inputs');

            if (sizeSelect && sizeSelect.value === 'custom') {
                customInputs.style.display = 'flex';
            } else if (customInputs) {
                customInputs.style.display = 'none';
            }
            
            calculateDynamicPrice();
        }

        function changeQty(val) {
            const input = document.getElementById('prod-qty');
            if (!input) return;
            let current = parseInt(input.value);
            let min = parseInt(input.getAttribute('min')) || 1;

            if (current + val >= min) {
                input.value = current + val;
            } else {
                input.value = min;
            }
            calculateDynamicPrice();
        }

        async function calculateDynamicPrice() {
            const productId = @(Model != null ? Model.Id : 0);

            const paperEl = document.getElementById('opt-paper');
            const sizeEl = document.getElementById('opt-size');
            const sidesEl = document.getElementById('opt-sides');
            const qtyEl = document.getElementById('prod-qty');

            if(!paperEl || !sizeEl || !sidesEl) {
                document.getElementById('sticky-price').innerText = 'البكج غير مهيأ حالياً';
                return;
            }

            const paperId = paperEl.value;
            const sizeId = sizeEl.value;
            const sidesId = sidesEl.value;
            const qty = parseInt(qtyEl.value) || 1;

            if (!paperId || !sizeId || !sidesId) {
                document.getElementById('sticky-price').innerText = 'حدد الخيارات لعرض السعر';
                document.getElementById('tabby-price').innerText = '0.00';
                return;
            }

            // إذا كان المقاس مخصص، نوقف حساب السعر التلقائي ونعرض رسالة للعميل
            if (sizeId === 'custom') {
                document.getElementById('sticky-price').innerHTML = '<span style="font-size: 16px;">يحدد بعد المراجعة</span>';
                document.getElementById('tabby-price').innerText = '0.00';
                return;
            }

            const extraCheckboxes = document.querySelectorAll('.extra-checkbox:checked');
            const extraIds = Array.from(extraCheckboxes).map(cb => parseInt(cb.value));

            document.getElementById('sticky-price').innerHTML = '<i class="fas fa-spinner fa-spin" style="font-size:18px;"></i> حساب...';

            const result = await ApiClient.calculatePrice(productId, paperId, sizeId, sidesId, qty, extraIds);

            if (result && result.success) {
                document.getElementById('sticky-price').innerText = result.total.toFixed(2) + ' ' + currency;
                document.getElementById('tabby-price').innerText = (result.total / 4).toFixed(2);
            } else {
                document.getElementById('sticky-price').innerText = 'غير متاح بهذه المواصفات';
                document.getElementById('tabby-price').innerText = '0.00';
            }
        }

        function addToCartFromDetails() {
            const titleEl = document.getElementById('product-title');
            const imgEl = document.getElementById('main-product-img');
            const priceEl = document.getElementById('sticky-price');
            const qtyEl = document.getElementById('prod-qty');

            if (priceEl.innerText.includes('حدد الخيارات') || priceEl.innerText.includes('غير متاح') || priceEl.innerText.includes('حساب')) {
                alert('الرجاء تحديد كافة الخيارات المطلوبة للبكج أولاً.');
                return;
            }

            const paperText = document.getElementById('opt-paper') ? document.getElementById('opt-paper').options[document.getElementById('opt-paper').selectedIndex].text : '';
            const sidesText = document.getElementById('opt-sides') ? document.getElementById('opt-sides').options[document.getElementById('opt-sides').selectedIndex].text : '';
            
            // معالجة نص المقاس
            let sizeText = '';
            const sizeSelect = document.getElementById('opt-size');
            let itemPrice = 0;

            if (sizeSelect.value === 'custom') {
                const l = document.getElementById('custom-length').value;
                const w = document.getElementById('custom-width').value;
                const h = document.getElementById('custom-height').value;

                if (!l || !w) {
                    alert('الرجاء إدخال الطول والعرض على الأقل لتفصيل المقاس الخاص.');
                    return;
                }
                sizeText = `مقاس مخصص: الطول ${l}سم، العرض ${w}سم` + (h ? `، الارتفاع ${h}سم` : '');
                itemPrice = 0; // السعر المبدئي للمقاس المخصص
            } else {
                sizeText = sizeSelect.options[sizeSelect.selectedIndex].text;
                itemPrice = parseFloat(priceEl.innerText.replace(currency, '').replace('يحدد بعد المراجعة', '0').trim());
            }

            const item = {
                id: @(Model != null ? Model.Id : 0),
                name: titleEl.innerText + ' (بكج)',
                price: itemPrice || 0,
                img: imgEl ? imgEl.src : '',
                quantity: parseInt(qtyEl.value) || 1,
                details: { paperType: paperText, sides: sidesText, design: sizeText }
            };

            let cart = JSON.parse(localStorage.getItem('printnesCart')) || [];
            cart.push(item);
            localStorage.setItem('printnesCart', JSON.stringify(cart));

            if (typeof updateBadges === "function") updateBadges();
            if (typeof showToastMessage === "function") showToastMessage('تمت الإضافة إلى سلة التسوق', item.name, item.img, true);
        }
    </script>
}