<!-- الملف: Areas/Admin/Views/Users/Edit.cshtml -->
@model Printnes.Models.ApplicationUser
@{
    ViewData["Title"] = "تعديل بيانات المستخدم";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-user-edit"></i> تعديل بيانات: @Model.FullName</h1>
    <a href="/Admin/Users" class="btn-outline"><i class="fas fa-arrow-right"></i> العودة للمستخدمين</a>
</div>

<div class="premium-card" style="max-width: 700px;">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="All" class="validation-summary-errors"></div>

        <input type="hidden" asp-for="Id" />

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="FullName" class="form-label">الاسم الكامل *</label>
                <input asp-for="FullName" class="form-control" required />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber" class="form-label">رقم الجوال</label>
                <input asp-for="PhoneNumber" class="form-control" dir="ltr" style="text-align: right;" />
                <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">البريد الإلكتروني (للعرض فقط)</label>
            <input value="@Model.Email" class="form-control" disabled style="background-color: var(--border-light); color: var(--text-muted);" />
        </div>

        <div class="form-group" style="margin-top: 20px;">
            <label class="form-check">
                <input type="checkbox" asp-for="IsActive" style="width: 18px; height: 18px; accent-color: var(--success);" />
                <label asp-for="IsActive">الحساب نشط (يمكنه تسجيل الدخول)</label>
            </label>
        </div>

        <hr style="border: none; border-top: 1px solid var(--border-color); margin: 30px 0;">

        <button type="submit" class="btn-premium"><i class="fas fa-save"></i> حفظ التعديلات</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}