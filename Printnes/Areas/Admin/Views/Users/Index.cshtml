@model IEnumerable<Printnes.Models.ApplicationUser>
@{
    ViewData["Title"] = "العملاء والموظفين";
    Layout = "_AdminLayout";
}

<div class="erp-page-header">
    <h1 class="erp-page-title"><i class="fas fa-users"></i> إدارة العملاء والموظفين</h1>
</div>

<div class="erp-card" style="padding: 0; overflow: hidden;">
    <div style="padding: 20px 30px; border-bottom: 1px solid var(--erp-border); background: #fafbfc; display: flex; justify-content: space-between;">
        <div style="position: relative;">
            <i class="fas fa-search" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: var(--erp-text-light);"></i>
            <input type="text" placeholder="ابحث بالاسم أو الإيميل..." class="erp-form-control" style="width: 350px; padding: 10px 40px 10px 15px;" />
        </div>
    </div>

    <table class="erp-table">
        <thead>
            <tr>
                <th>الاسم الكامل</th>
                <th>البريد الإلكتروني</th>
                <th>رقم الجوال</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(user.FullName ?? "User")&background=f1f5f9&color=334155" alt="Avatar" style="width: 40px; height: 40px; border-radius: 50%;">
                                <strong style="color: var(--erp-dark);">@user.FullName</strong>
                            </div>
                        </td>
                        <td style="color: var(--erp-text-light);">@user.Email</td>
                        <td dir="ltr" style="text-align: right;">@user.PhoneNumber</td>
                        <td>
                            @(user.IsActive? Html.Raw("<span class='status-badge status-success'><i class='fas fa-user-check'></i> مفعل</span>") : Html.Raw("<span class='status-badge status-danger'><i class='fas fa-user-lock'></i> محظور</span>"))
                        </td>
                        <td>
                            <form asp-action="ToggleStatus" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@user.Id" />
                                @if (user.IsActive)
                                {
                                    <button type="submit" class="btn-erp-outline" style="border: none; background: none; color: #ef4444; cursor: pointer; font-weight: bold; padding: 5px 10px; border-radius: 6px; transition: 0.3s;" onmouseover="this.style.background='#fee2e2'" onmouseout="this.style.background='none'">
                                        <i class="fas fa-ban"></i> حظر
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn-erp-outline" style="border: none; background: none; color: #10b981; cursor: pointer; font-weight: bold; padding: 5px 10px; border-radius: 6px; transition: 0.3s;" onmouseover="this.style.background='#dcfce7'" onmouseout="this.style.background='none'">
                                        <i class="fas fa-check"></i> تفعيل
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" style="padding: 40px; text-align: center; color: var(--erp-text-light);">
                        <i class="fas fa-users-slash" style="font-size: 40px; margin-bottom: 15px; opacity: 0.5;"></i>
                        <p>لا يوجد مستخدمين مسجلين في النظام.</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>