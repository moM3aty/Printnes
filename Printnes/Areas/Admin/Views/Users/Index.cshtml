<!-- الملف: Areas/Admin/Views/Users/Index.cshtml -->
@model IEnumerable<Printnes.Models.ApplicationUser>
@{
    ViewData["Title"] = "العملاء والموظفين";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-users"></i> إدارة العملاء والموظفين</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle"></i>
        @TempData["ErrorMessage"]
    </div>
}

<!-- كروت إحصائية للمستخدمين -->
<div class="stats-grid" style="margin-bottom: 24px;">
    <div class="stat-card blue">
        <div class="stat-info">
            <div class="stat-info-title">إجمالي المستخدمين</div>
            <div class="stat-info-value">@(ViewBag.TotalUsers ?? 0)</div>
        </div>
        <div class="stat-icon-box blue"><i class="fas fa-users"></i></div>
    </div>
    <div class="stat-card green">
        <div class="stat-info">
            <div class="stat-info-title">حسابات نشطة</div>
            <div class="stat-info-value">@(ViewBag.ActiveUsers ?? 0)</div>
        </div>
        <div class="stat-icon-box green"><i class="fas fa-user-check"></i></div>
    </div>
    <div class="stat-card orange">
        <div class="stat-info">
            <div class="stat-info-title">حسابات محظورة</div>
            <div class="stat-info-value">@(ViewBag.InactiveUsers ?? 0)</div>
        </div>
        <div class="stat-icon-box orange"><i class="fas fa-user-lock"></i></div>
    </div>
    <div class="stat-card purple">
        <div class="stat-info">
            <div class="stat-info-title">طاقم الإدارة</div>
            <div class="stat-info-value">@(ViewBag.AdminCount ?? 0)</div>
        </div>
        <div class="stat-icon-box purple"><i class="fas fa-user-shield"></i></div>
    </div>
</div>

<div class="premium-card" style="padding: 18px 24px;">
    <form asp-action="Index" method="get">
        <div class="filter-bar">
            <div style="position: relative; flex: 1; min-width: 220px;">
                <i class="fas fa-search" style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" name="searchQuery" value="@ViewBag.SearchQuery"
                       class="filter-input" style="padding-right: 40px;"
                       placeholder="ابحث بالاسم، الإيميل أو رقم الجوال..." />
            </div>

            <select name="roleFilter" class="filter-select" style="min-width: 150px;">
                <option value="">كل الصلاحيات</option>
                @if (ViewBag.Roles != null)
                {
                    foreach (var role in ViewBag.Roles)
                    {
                        <option value="@role.Value" selected="@(ViewBag.RoleFilter?.ToString() == role.Value)">@role.Text</option>
                    }
                }
            </select>

            <select name="statusFilter" class="filter-select" style="min-width: 150px;">
                <option value="">كل الحالات</option>
                <option value="1" selected="@(ViewBag.StatusFilter?.ToString() == "1")">نشط</option>
                <option value="0" selected="@(ViewBag.StatusFilter?.ToString() == "0")">محظور</option>
            </select>

            <button type="submit" class="btn-premium btn-sm"><i class="fas fa-filter"></i> تصفية</button>
            <a href="/Admin/Users" class="btn-outline btn-sm"><i class="fas fa-redo"></i> إعادة تعيين</a>
        </div>
    </form>
</div>

<div class="table-container">
    <div class="table-responsive">
        <table class="premium-table">
            <thead>
                <tr>
                    <th>الاسم الكامل</th>
                    <th>البريد الإلكتروني</th>
                    <th>رقم الجوال</th>
                    <th>الصلاحيات</th>
                    <th>الحالة</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--primary-light); color: var(--primary-color); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 14px; flex-shrink: 0;">
                                        @(string.IsNullOrEmpty(user.FullName) ? "U" : user.FullName.Substring(0, 1))
                                    </div>
                                    <strong style="color: var(--text-main);">@user.FullName</strong>
                                </div>
                            </td>
                            <td style="color: var(--text-secondary);">@user.Email</td>
                            <td dir="ltr" style="text-align: right;">@(user.PhoneNumber ?? "—")</td>
                            <td>
                                @if (ViewBag.UserRoles != null && ViewBag.UserRoles.ContainsKey(user.Id))
                                {
                                    var roles = ViewBag.UserRoles[user.Id] as IList<string>;
                                    if (roles != null && roles.Any())
                                    {
                                        foreach (var role in roles)
                                        {
                                            string roleClass = role switch
                                            {
                                                "SuperAdmin" => "badge-danger",
                                                "Admin" => "badge-purple",
                                                "Customer" => "badge-neutral",
                                                _ => "badge-info"
                                            };
                                            <span class="badge @roleClass" style="margin-left: 2px;">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge badge-neutral">بدون صلاحية</span>
                                    }
                                }
                            </td>
                            <td>
                                @(user.IsActive? Html.Raw("<span class='badge badge-success'><i class='fas fa-user-check'></i> نشط</span>") : Html.Raw("<span class='badge badge-danger'><i class='fas fa-user-lock'></i> محظور</span>"))
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <form asp-action="ToggleStatus" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        @if (user.IsActive)
                                        {
                                            <button type="submit" class="btn-outline btn-icon" title="حظر المستخدم" style="color: var(--danger);">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn-outline btn-icon" title="تفعيل المستخدم" style="color: var(--success);">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        }
                                    </form>

                                    <!-- تم إصلاح الرابط هنا ليوجه لكنترولر المستخدمين بدلاً من الأدوار -->
                                    <a href="/Admin/Users/ManageRoles/@user.Id" class="btn-outline btn-icon" title="تعديل الصلاحيات" style="color: var(--purple);">
                                        <i class="fas fa-user-shield"></i>
                                    </a>

                                    <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذا المستخدم نهائياً؟');">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn-outline btn-icon" title="حذف" style="color: var(--danger);">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="padding: 40px; text-align: center; color: var(--text-muted);">
                            <i class="fas fa-users-slash" style="font-size: 40px; margin-bottom: 15px; opacity: 0.5;"></i>
                            <p>لا يوجد مستخدمين مسجلين يطابقون بحثك.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>