<!-- الملف: Areas/Admin/Views/Users/ManageRoles.cshtml -->
@model List<Printnes.Areas.Admin.Controllers.ManageUserRolesViewModel>
@{
    ViewData["Title"] = "تعديل صلاحيات المستخدم";
    Layout = "_AdminLayout";
}

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; margin-bottom: 30px;">
    <h1 class="page-title" style="font-size: 24px; font-weight: 800; color: var(--text-main); display: flex; align-items: center; gap: 12px;">
        <div style="width: 45px; height: 45px; background: #fdf4ff; color: var(--purple); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
            <i class="fas fa-user-shield"></i>
        </div>
        إدارة أدوار المستخدم
    </h1>
    <a href="/Admin/Users" class="btn-outline" style="display: inline-flex; align-items: center; gap: 8px;">
        <i class="fas fa-arrow-right"></i> العودة لقائمة المستخدمين
    </a>
</div>

<div class="premium-card" style="max-width: 800px; margin: 0 auto; padding: 35px; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid rgba(0,0,0,0.05); background: #fff;">

    <div style="text-align: center; margin-bottom: 30px;">
        <div style="width: 70px; height: 70px; border-radius: 50%; background: var(--primary-light); color: var(--primary-color); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 28px; margin: 0 auto 15px;">
            <i class="far fa-user"></i>
        </div>
        <h2 style="margin: 0; color: var(--navy); font-weight: 800;">@ViewBag.UserName</h2>
        <p style="color: var(--text-muted); margin-top: 5px;">قم بتحديد الصلاحيات والأدوار التي ترغب بمنحها لهذا المستخدم.</p>
    </div>

    <form method="post">
        <input type="hidden" name="userId" value="@ViewBag.UserId" />

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px;">
            @for (int i = 0; i < Model.Count; i++)
            {
                <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 15px 20px; transition: 0.2s;" onmouseover="this.style.borderColor='var(--purple)'" onmouseout="this.style.borderColor='#e2e8f0'">
                    <input type="hidden" asp-for="@Model[i].RoleId" />
                    <input type="hidden" asp-for="@Model[i].RoleName" />

                    <label style="display: flex; align-items: center; gap: 12px; cursor: pointer; margin: 0; width: 100%;">
                        <input asp-for="@Model[i].IsSelected" style="width: 22px; height: 22px; accent-color: var(--purple); cursor: pointer;" />
                        <div>
                            <strong style="color: var(--navy); font-size: 16px; display: block;">@Model[i].RoleName</strong>
                            <small style="color: #94a3b8;">منح هذه الصلاحية</small>
                        </div>
                    </label>
                </div>
            }
        </div>

        <hr style="border: none; border-top: 1px dashed var(--border-color); margin: 30px 0;">

        <div style="display: flex; gap: 15px; align-items: center; justify-content: center;">
            <button type="submit" class="btn-premium" style="background: var(--purple); color: #fff; border: none; padding: 14px 40px; border-radius: 10px; font-weight: 800; font-size: 16px; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: 0.3s;"
                    onmouseover="this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.transform='none'">
                <i class="fas fa-check-double"></i> حفظ الصلاحيات المحددة
            </button>
            <a href="/Admin/Users" class="btn-outline" style="color: var(--text-secondary); padding: 14px 30px; border-radius: 10px; font-weight: 700; text-decoration: none; border: 1px solid var(--border-color); transition: 0.3s;"
               onmouseover="this.style.background='var(--border-light)'" onmouseout="this.style.background='transparent'">
                إلغاء والتراجع
            </a>
        </div>
    </form>
</div>