<!-- الملف: Areas/Admin/Views/Orders/Details.cshtml -->
@using System.Text.Json
@model Printnes.Models.Order
@{
    ViewData["Title"] = "تفاصيل الطلب " + Model.OrderNumber;
}

<div class="page-header">
    <h1 class="page-title">
        <i class="fas fa-file-invoice"></i>
        طلب رقم: <span style="color: var(--primary-color);">@Model.OrderNumber</span>
    </h1>
    <a href="/Admin/Orders" class="btn-outline"><i class="fas fa-arrow-right"></i> العودة للطلبات</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

<!-- إعادة توجيه للواتساب إذا تم طلبه -->
@if (TempData["WhatsAppUrl"] != null)
{
    <script>
        window.open('@Html.Raw(TempData["WhatsAppUrl"])', '_blank');
    </script>
}

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 28px;">
    <!-- الجانب الأيمن: عناصر الطلب والتاريخ -->
    <div style="display: flex; flex-direction: column; gap: 28px;">

        <!-- كروت ملخص سريع -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
            <div class="stat-card orange" style="padding: 18px;">
                <div class="stat-info">
                    <div class="stat-info-title" style="font-size: 11px;">الإجمالي</div>
                    <div class="stat-info-value" style="font-size: 22px;">@Model.TotalAmount.ToString("N2") <small>ر.س</small></div>
                </div>
            </div>
            <div class="stat-card blue" style="padding: 18px;">
                <div class="stat-info">
                    <div class="stat-info-title" style="font-size: 11px;">عناصر الطلب</div>
                    <div class="stat-info-value" style="font-size: 22px;">@(Model.OrderItems?.Count ?? 0)</div>
                </div>
            </div>
            <div class="stat-card green" style="padding: 18px;">
                <div class="stat-info">
                    <div class="stat-info-title" style="font-size: 11px;">تاريخ الطلب</div>
                    <div class="stat-info-value" style="font-size: 16px;">@Model.CreatedAt.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>

        <!-- عناصر الطلب -->
        <div class="table-container">
            <div class="table-header">
                <h3>
                    <i class="fas fa-box-open" style="color: var(--primary-color);"></i>
                    عناصر الطلب
                </h3>
                <form asp-action="SendToWhatsApp" asp-route-id="@Model.Id" method="post" style="display: inline;">
                    <button type="submit" class="btn-outline btn-sm" style="color: #25d366; border-color: #25d366;">
                        <i class="fab fa-whatsapp"></i> إرسال للواتساب
                    </button>
                </form>
            </div>
            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>المنتج</th>
                            <th style="min-width: 250px;">الخيارات والمقاسات</th>
                            <th>الكمية</th>
                            <th>سعر الوحدة</th>
                            <th>الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.OrderItems != null)
                        {
                            int idx = 1;
                            foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td style="color: var(--text-muted);">@idx</td>
                                    <td>
                                        <strong style="color: var(--text-main); font-size: 14px;">@item.ProductName</strong>
                                        @if (item.Product != null)
                                        {
                                            <br>
                                            <small style="color: var(--text-muted); background: #f8fafc; padding: 2px 6px; border-radius: 4px; font-family: monospace;">SKU: @item.Product.Slug</small>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.SelectedOptionsJson))
                                        {
                                            try
                                            {
                                                // تحويل الـ JSON إلى Dictionary لعرضه بشكل أنيق
                                                var details = JsonSerializer.Deserialize<Dictionary<string, string>>(item.SelectedOptionsJson);
                                                if (details != null && details.Count > 0)
                                                {
                                                    <div style="display: flex; flex-direction: column; gap: 6px; font-size: 13px;">
                                                        @foreach (var kvp in details)
                                                        {
                                                            if (string.IsNullOrWhiteSpace(kvp.Value)) continue;

                                                            // ترجمة المفاتيح الإنجليزية إلى مسميات عربية للوحة التحكم
                                                            string labelName = kvp.Key switch
                                                            {
                                                                "paperType" => "الورق",
                                                                "sides" => "الأوجه",
                                                                "design" => "المقاس",
                                                                "cover" => "التشطيب",
                                                                _ => kvp.Key
                                                            };

                                                            <div style="background: #f8fafc; padding: 6px 10px; border-radius: 6px; border: 1px solid #e2e8f0; line-height: 1.5;">
                                                                <strong style="color: var(--orange);">@labelName:</strong>
                                                                <span style="color: var(--navy); font-weight: 600;">@kvp.Value</span>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            }
                                            catch
                                            {
                                                // في حال فشل التحويل (Fallback)
                                                <span style="font-size: 12px; color: var(--text-secondary);">@item.SelectedOptionsJson</span>
                                            }
                                        }
                                        else
                                        {
                                            <span style="color: var(--text-muted); font-size: 13px; background: #f1f5f9; padding: 4px 8px; border-radius: 4px;">بدون خيارات إضافية</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-neutral" style="font-size: 14px;">@item.Quantity</span>
                                    </td>
                                    <td style="color: var(--text-secondary);">@item.CalculatedUnitPrice.ToString("N2") ر.س</td>
                                    <td style="font-weight: 900; color: var(--primary-color); font-size: 15px;">@item.ItemTotal.ToString("N2") ر.س</td>
                                </tr>
                                idx++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- تفاصيل المالية -->
        <div class="premium-card" style="padding: 24px;">
            <h3 style="margin: 0 0 20px; font-size: 16px; font-weight: 800; color: var(--text-main);">
                <i class="fas fa-receipt" style="color: var(--primary-color); margin-left: 8px;"></i>
                الملخص المالي
            </h3>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border-light);">
                    <span style="color: var(--text-secondary);">المجموع الفرعي</span>
                    <strong>@Model.SubTotal.ToString("N2") ر.س</strong>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border-light);">
                    <span style="color: var(--text-secondary);">تكلفة الشحن</span>
                    <strong>@Model.ShippingCost.ToString("N2") ر.س</strong>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border-light);">
                    <span style="color: var(--text-secondary);">الضريبة المضافة</span>
                    <strong>@Model.TaxAmount.ToString("N2") ر.س</strong>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 16px; background: var(--primary-light); border-radius: var(--radius-sm); border: 1px dashed var(--primary-color);">
                    <span style="font-weight: 900; color: var(--primary-color); font-size: 16px;">الإجمالي النهائي</span>
                    <strong style="color: var(--primary-color); font-size: 22px;">@Model.TotalAmount.ToString("N2") <small style="font-size: 14px;">ر.س</small></strong>
                </div>
            </div>
        </div>

        <!-- سجل حالة الطلب -->
        <div class="table-container">
            <div class="table-header">
                <h3>
                    <i class="fas fa-history" style="color: var(--purple);"></i>
                    سجل تحديثات الحالة
                </h3>
            </div>
            @if (Model.OrderStatusHistories != null && Model.OrderStatusHistories.Any())
            {
                <div style="padding: 20px;">
                    @foreach (var hist in Model.OrderStatusHistories.OrderByDescending(h => h.CreatedAt))
                    {
                        <div style="display: flex; gap: 16px; margin-bottom: 20px; position: relative;">
                            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--info-bg); color: var(--info); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 14px;">
                                <i class="fas fa-exchange-alt"></i>
                            </div>
                            <div style="flex: 1; padding-bottom: 16px; border-bottom: 1px solid var(--border-light);">
                                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                                    <span style="font-weight: 700; color: var(--text-main); font-size: 14px;">
                                        تم التغيير بواسطة: @hist.ChangedBy
                                    </span>
                                    <span style="font-size: 12px; color: var(--text-muted); background: #f1f5f9; padding: 4px 8px; border-radius: 4px;">
                                        @hist.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")
                                    </span>
                                </div>
                                @if (!string.IsNullOrEmpty(hist.Note))
                                {
                                    <p style="margin: 8px 0 0; font-size: 13px; color: var(--text-secondary); background: #f8fafc; padding: 10px 14px; border-radius: 8px; border-right: 3px solid var(--info);">
                                        @hist.Note
                                    </p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="padding: 40px; text-align: center; color: var(--text-muted);">
                    <i class="fas fa-history" style="font-size: 32px; margin-bottom: 10px; opacity: 0.3;"></i>
                    <p>لا توجد تحديثات مسجلة حتى الآن</p>
                </div>
            }
        </div>
    </div>

    <!-- الجانب الأيسر: معلومات العميل وتحديث الحالة -->
    <div style="display: flex; flex-direction: column; gap: 28px;">
        <!-- معلومات العميل -->
        <div class="premium-card" style="padding: 24px;">
            <h3 style="margin: 0 0 20px; font-size: 16px; font-weight: 800; color: var(--text-main); display: flex; align-items: center; gap: 10px;">
                <div style="width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--primary-light); color: var(--primary-color); display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-user-circle"></i>
                </div>
                معلومات العميل
            </h3>

            <div style="display: flex; flex-direction: column; gap: 14px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="color: var(--text-muted); font-size: 13px;"><i class="fas fa-user" style="margin-left: 6px;"></i> الاسم</span>
                    <strong style="color: var(--text-main);">@Model.CustomerName</strong>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="color: var(--text-muted); font-size: 13px;"><i class="fas fa-phone" style="margin-left: 6px;"></i> الجوال</span>
                    <a href="tel:@Model.CustomerPhone" style="color: var(--info); font-weight: 700;" dir="ltr">@Model.CustomerPhone</a>
                </div>
                @if (!string.IsNullOrEmpty(Model.CustomerEmail))
                {
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="color: var(--text-muted); font-size: 13px;"><i class="fas fa-envelope" style="margin-left: 6px;"></i> الإيميل</span>
                        <a href="mailto:@Model.CustomerEmail" style="color: var(--info); font-weight: 700; font-size: 13px;">@Model.CustomerEmail</a>
                    </div>
                }
                <div style="background: #f8fafc; padding: 15px; border-radius: 8px; margin-top: 8px; border: 1px solid #e2e8f0;">
                    <div style="font-size: 12px; color: var(--orange); margin-bottom: 8px; font-weight: bold;"><i class="fas fa-map-marker-alt" style="margin-left: 6px;"></i> عنوان التوصيل</div>
                    <div style="font-size: 14px; color: var(--navy); line-height: 1.8; font-weight: 600;">
                        @Model.City - @Model.District<br>
                        <span style="color: var(--text-secondary); font-weight: normal;">@Model.Address</span>
                    </div>
                </div>

                <a href="https://wa.me/@(Model.CustomerPhone?.Replace(" ", "").Replace("+", ""))" target="_blank"
                   class="btn-premium btn-sm" style="width: 100%; justify-content: center; background: #25d366; color: #fff; border: none; margin-top: 8px;">
                    <i class="fab fa-whatsapp" style="font-size: 16px;"></i> تواصل عبر الواتساب
                </a>
            </div>
        </div>

        <!-- تحديث الحالة -->
        <div class="premium-card" style="padding: 24px;">
            <h3 style="margin: 0 0 20px; font-size: 16px; font-weight: 800; color: var(--text-main); display: flex; align-items: center; gap: 10px;">
                <div style="width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--warning-bg); color: var(--warning); display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-sync-alt"></i>
                </div>
                تحديث الحالة
            </h3>

            <form asp-action="UpdateStatus" method="post" style="display: flex; flex-direction: column; gap: 16px;">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="form-group" style="margin: 0;">
                    <label class="form-label">الحالة الحالية / الجديدة</label>
                    <select name="newStatus" class="form-control" style="font-weight: bold; color: var(--navy);">
                        <option value="1" selected="@(Model.OrderStatus == 1)">📋 بانتظار المراجعة (جديد)</option>
                        <option value="2" selected="@(Model.OrderStatus == 2)">🔍 قيد المراجعة والتصميم</option>
                        <option value="3" selected="@(Model.OrderStatus == 3)">🖨️ جاري الطباعة والتجهيز</option>
                        <option value="4" selected="@(Model.OrderStatus == 4)">🚚 تم الشحن / التوصيل</option>
                        <option value="5" selected="@(Model.OrderStatus == 5)">✅ مكتمل تماماً</option>
                    </select>
                </div>

                <div class="form-group" style="margin: 0;">
                    <label class="form-label">ملاحظة (للإدارة أو للعميل)</label>
                    <textarea name="note" rows="3" class="form-control" placeholder="اكتب ملاحظة حول سبب التحديث..." style="resize: vertical;"></textarea>
                </div>

                <label class="form-check" style="padding: 12px; background: #ecfdf5; border-radius: var(--radius-sm); border: 1px solid #a7f3d0; cursor: pointer;">
                    <input type="checkbox" name="sendWhatsApp" value="true" style="accent-color: #10b981; width: 18px; height: 18px;" />
                    <span style="font-weight: 700; color: #065f46; font-size: 13px;">
                        <i class="fab fa-whatsapp" style="margin-left: 6px; color: #25d366;"></i>
                        إرسال إشعار آلي للعميل عبر الواتساب
                    </span>
                </label>

                <button type="submit" class="btn-premium" style="width: 100%; justify-content: center; font-size: 15px; padding: 14px;">
                    <i class="fas fa-save"></i> حفظ وتحديث الحالة
                </button>
            </form>
        </div>

        <!-- ملاحظات إضافية من العميل -->
        <div class="premium-card" style="padding: 24px;">
            <h3 style="margin: 0 0 15px; font-size: 16px; font-weight: 800; color: var(--text-main);">
                <i class="fas fa-sticky-note" style="color: var(--warning); margin-left: 8px;"></i>
                ملاحظات من العميل للطباعة
            </h3>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div style="font-size: 14px; color: var(--navy); line-height: 1.8; background: #fffbeb; padding: 16px; border-radius: 8px; border-right: 4px solid var(--warning); font-weight: 600;">
                    @Model.Notes
                </div>
            }
            else
            {
                <div style="color: var(--text-muted); font-size: 14px; text-align: center; padding: 20px; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e1;">
                    لا توجد ملاحظات مرفقة مع الطلب
                </div>
            }
        </div>
    </div>
</div>