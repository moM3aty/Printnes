<!-- الملف: Areas/Admin/Views/Pricing/Create.cshtml -->
@model Printnes.Models.PricingMatrix
@{
    ViewData["Title"] = "إضافة تسعيرة تقاطع";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-calculator"></i> إضافة تسعيرة (تقاطع خيارات)</h1>
    <a href="/Admin/Pricing" class="btn-premium" style="background: transparent; color: var(--text-main); border: 1px solid var(--border-color);"><i class="fas fa-arrow-right"></i> عودة للمصفوفة</a>
</div>

<div class="premium-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors" style="display: block;"></div>

        <div class="form-group" style="border-bottom: 1px solid var(--border-color); padding-bottom: 20px;">
            <label class="form-label">اختر المنتج المستهدف بالتسعير *</label>
            <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-control" style="max-width: 500px;" required>
                <option value="">-- حدد المنتج --</option>
            </select>
            <span asp-validation-for="ProductId" class="field-validation-error"></span>
        </div>

        <h3 style="font-size: 16px; margin: 20px 0; color: var(--primary-color); font-weight: 800;"><i class="fas fa-sliders-h"></i> تقاطع الخيارات (المواصفات)</h3>

        <div class="form-grid" style="grid-template-columns: repeat(3, 1fr);">
            <div class="form-group">
                <label class="form-label">نوع الورق *</label>
                <select asp-for="PaperOptionId" asp-items="ViewBag.PaperOptionId" class="form-control" required>
                    <option value="">-- اختر --</option>
                </select>
                <span asp-validation-for="PaperOptionId" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label class="form-label">المقاس *</label>
                <select asp-for="SizeOptionId" asp-items="ViewBag.SizeOptionId" class="form-control" required>
                    <option value="">-- اختر --</option>
                </select>
                <span asp-validation-for="SizeOptionId" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label class="form-label">عدد الأوجه *</label>
                <select asp-for="SidesOptionId" asp-items="ViewBag.SidesOptionId" class="form-control" required>
                    <option value="">-- اختر --</option>
                </select>
                <span asp-validation-for="SidesOptionId" class="field-validation-error"></span>
            </div>
        </div>

        <h3 style="font-size: 16px; margin: 20px 0; color: var(--primary-color); font-weight: 800;"><i class="fas fa-money-bill-wave"></i> تفاصيل التكلفة والتسعير</h3>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">تكلفة التجهيز الثابتة (Base Price) *</label>
                <div style="position: relative;">
                    <input asp-for="BasePrice" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                    <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-weight: bold;">ر.س</span>
                </div>
                <small class="form-hint">تُضاف مرة واحدة على الطلب (تجهيز مكائن، زنكات..)</small>
                <span asp-validation-for="BasePrice" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label">سعر الحبة الواحدة (Unit Price) *</label>
                <div style="position: relative;">
                    <input asp-for="UnitPrice" type="number" step="0.0001" class="form-control" placeholder="0.00" required />
                    <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-weight: bold;">ر.س</span>
                </div>
                <small class="form-hint">سعر النسخة الواحدة من هذا التقاطع (يُضرب في الكمية)</small>
                <span asp-validation-for="UnitPrice" class="field-validation-error"></span>
            </div>
        </div>

        <hr style="border: none; border-top: 1px solid var(--border-color); margin: 20px 0;">

        <button type="submit" class="btn-premium"><i class="fas fa-save"></i> حفظ التسعيرة في المصفوفة</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}