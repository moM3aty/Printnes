<!-- الملف: Areas/Admin/Views/Pricing/Index.cshtml -->
@model IEnumerable<Printnes.Models.PricingMatrix>
@{
    ViewData["Title"] = "مصفوفة الأسعار";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-calculator"></i> إدارة مصفوفة التسعير</h1>
    <a href="/Admin/Pricing/Create" class="btn-premium"><i class="fas fa-plus"></i> إضافة تسعيرة تقاطع جديدة</a>
</div>

<div class="premium-card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="premium-table">
            <thead>
                <tr>
                    <th>المنتج</th>
                    <th>نوع الورق</th>
                    <th>المقاس</th>
                    <th>الأوجه</th>
                    <th>تكلفة التجهيز</th>
                    <th>سعر الحبة</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="font-weight: 900; color: var(--text-main);">@item.Product.NameAr</td>
                            <td><span class="badge badge-info">@item.PaperOption.NameAr</span></td>
                            <td><span class="badge badge-purple">@item.SizeOption.NameAr</span></td>
                            <td><span class="badge badge-warning">@item.SidesOption.NameAr</span></td>
                            <td style="color: var(--text-muted);">@item.BasePrice.ToString("0.00") ر.س</td>
                            <td style="font-weight: 800; color: var(--success);">@item.UnitPrice.ToString("0.000") ر.س</td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="/Admin/Pricing/Edit/@item.Id" class="btn-outline btn-icon" title="تعديل"><i class="fas fa-edit"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذه التسعيرة؟');">
                                        <button type="submit" class="btn-outline btn-icon btn-delete-confirm" title="حذف" style="color: var(--danger);">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="padding: 40px; text-align: center; color: var(--text-muted);">
                            <i class="fas fa-table" style="font-size: 40px; margin-bottom: 15px; opacity: 0.5;"></i>
                            <p>لم يتم إدراج أي تسعيرة في المصفوفة حتى الآن.</p>
                            <a href="/Admin/Pricing/Create" style="color: var(--primary-color); font-weight: 700; text-decoration: none;">ابدأ بإضافة أول تسعيرة</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>