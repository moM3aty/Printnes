<!-- الملف: Areas/Admin/Views/Shared/_AdminLayout.cshtml -->
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] | Printnes ERP</title>

    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin-style.css" />

    <!-- إصلاحات قوية للـ Sidebar لضمان الفتح والإغلاق السلس على جميع الشاشات -->
    <style>
        /* التجاوب والحركات العامة */
        html, body {
            overflow-x: hidden;
        }

        .sidebar {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
            width: 280px;
            z-index: 1000;
        }

        .main-content {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
            margin-right: 280px;
        }

        /* حالة الطي للشاشات الكبيرة */
        .sidebar.collapsed {
            width: 80px !important;
        }

            .sidebar.collapsed ~ .main-content {
                margin-right: 80px !important;
            }

            .sidebar.collapsed .menu-item span,
            .sidebar.collapsed .menu-label,
            .sidebar.collapsed .sidebar-badge {
                display: none !important;
            }

            .sidebar.collapsed .sidebar-header img {
                max-width: 45px !important;
            }

            .sidebar.collapsed .menu-item {
                justify-content: center;
                padding: 15px 0;
            }

                .sidebar.collapsed .menu-item i {
                    margin: 0;
                    font-size: 20px;
                }

        /* الشاشات الصغيرة (الجوال والتابلت) */
        @@media (max-width: 992px) {
            .sidebar

        {
            transform: translateX(100%) !important;
            position: fixed !important;
            right: 0 !important;
            top: 0 !important;
            bottom: 0 !important;
            width: 280px !important;
        }

        .sidebar.active {
            transform: translateX(0) !important;
            box-shadow: -5px 0 25px rgba(0,0,0,0.3);
        }

        .main-content {
            margin-right: 0 !important;
            width: 100% !important;
        }

        .sidebar.collapsed ~ .main-content {
            margin-right: 0 !important;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(3px);
            z-index: 999;
        }

            .sidebar-overlay.active {
                display: block;
            }

        /* إخفاء عناصر بالشريط العلوي في الجوال لتوفير مساحة */
        .topbar {
            padding: 0 15px;
        }

        .btn-visit-store span {
            display: none;
        }

        .admin-profile-info {
            display: none;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
            margin-bottom: 20px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .filter-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-select, .filter-input {
            width: 100%;
        }

        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- التظليل الخلفي للجوال -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- القائمة الجانبية -->
    <aside class="sidebar" id="erp-sidebar">
        <div class="sidebar-header" style="position: relative;">
            <a href="/Admin/Dashboard">
                <img src="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" alt="Printnes ERP" style="transition: all 0.3s ease;">
            </a>
        </div>

        <nav class="sidebar-menu">
            <div class="menu-label">العمليات</div>
            <a href="/Admin/Dashboard" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fas fa-chart-pie"></i>
                <span>لوحة القيادة</span>
            </a>
            <a href="/Admin/Orders" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" ? "active" : "")">
                <i class="fas fa-file-invoice-dollar"></i>
                <span>إدارة الطلبات</span>
            </a>
            <a href="/Admin/Banners" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Banners" ? "active" : "")">
                <i class="fas fa-images"></i>
                <span>البانرات الإعلانية</span>
            </a>

            <div class="menu-label">إدارة المتجر</div>
            <a href="/Admin/Products" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")">
                <i class="fas fa-box-open"></i>
                <span>المنتجات</span>
            </a>
            <a href="/Admin/Categories" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active" : "")">
                <i class="fas fa-layer-group"></i>
                <span>الأقسام الرئيسية</span>
            </a>
            <a href="/Admin/Pricing" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Pricing" ? "active" : "")">
                <i class="fas fa-calculator"></i>
                <span>مصفوفة التسعير</span>
            </a>
            <a href="/Admin/ProductOptions" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductOptions" ? "active" : "")">
                <i class="fas fa-sliders-h"></i>
                <span>خيارات الطباعة</span>
            </a>
            <a href="/Admin/ProductExtras" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductExtras" ? "active" : "")">
                <i class="fas fa-puzzle-piece"></i>
                <span>الإضافات والاختيارات</span>
            </a>
            <a href="/Admin/QuantityTiers" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "QuantityTiers" ? "active" : "")">
                <i class="fas fa-percent"></i>
                <span>شرائح الكميات</span>
            </a>

            <div class="menu-label">إدارة النظام</div>
            <a href="/Admin/Users" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                <i class="fas fa-users-cog"></i>
                <span>العملاء والموظفين</span>
            </a>
            <a href="/Admin/Roles" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Roles" ? "active" : "")">
                <i class="fas fa-user-shield"></i>
                <span>إدارة الصلاحيات</span>
            </a>
            <a href="/Admin/Reviews" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reviews" ? "active" : "")">
                <i class="fas fa-star"></i>
                <span>تقييمات العملاء</span>
            </a>
            <a href="/Admin/Settings" class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")">
                <i class="fas fa-cog"></i>
                <span>إعدادات النظام</span>
            </a>
        </nav>
    </aside>

    <!-- المحتوى الرئيسي -->
    <div class="main-content">
        <!-- الشريط العلوي -->
        <header class="topbar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <!-- تغيير الـ ID لتفادي التعارض مع admin-script.js -->
                <button class="toggle-btn" id="btn-sidebar-toggle">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="topbar-date">
                    <i class="far fa-calendar-alt" style="margin-left: 6px; color: var(--primary-color);"></i>
                    @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ar-SA"))
                </span>
            </div>

            <div class="topbar-right">
                <a href="/" target="_blank" class="btn-visit-store" style="border-color: var(--primary-light); background: var(--primary-light); color: var(--primary-color);">
                    <i class="fas fa-external-link-alt"></i>
                    <span>عرض المتجر</span>
                </a>

                <div class="admin-profile">
                    <img src="https://ui-avatars.com/api/?name=@(User.Identity.IsAuthenticated? Uri.EscapeDataString(User.Identity.Name ?? "Admin") : "Admin")&background=f26a2e&color=fff&bold=true&size=40" alt="Admin">
                    <div class="admin-profile-info">
                        <span class="admin-profile-name">@(User.Identity.IsAuthenticated? User.Identity.Name : "مدير النظام")</span>
                        <span class="admin-profile-role">إدارة عليا</span>
                    </div>
                </div>

                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" style="display: inline;">
                    <button type="submit" class="btn-logout" title="تسجيل الخروج">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </form>
            </div>
        </header>

        <!-- منطقة العمل -->
        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <!-- السكربتات -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/admin-script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('btn-sidebar-toggle');
            const sidebar = document.getElementById('erp-sidebar');
            const overlay = document.getElementById('sidebarOverlay');

            // التحكم في فتح وإغلاق القائمة
            if(toggleBtn) {
                toggleBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    if (window.innerWidth <= 992) {
                        // للشاشات الصغيرة
                        sidebar.classList.toggle('active');
                        overlay.classList.toggle('active');
                        document.body.style.overflow = sidebar.classList.contains('active') ? 'hidden' : '';
                    } else {
                        // للشاشات الكبيرة
                        sidebar.classList.toggle('collapsed');
                    }
                });
            }

            // إغلاق القائمة عند النقر على التظليل الأسود (في الجوال)
            if(overlay) {
                overlay.addEventListener('click', function() {
                    sidebar.classList.remove('active');
                    overlay.classList.remove('active');
                    document.body.style.overflow = '';
                });
            }

            // إغلاق القائمة المنسدلة للموبايل عند تكبير الشاشة لتفادي الأخطاء البصرية
            window.addEventListener('resize', function() {
                if (window.innerWidth > 992) {
                    sidebar.classList.remove('active');
                    overlay.classList.remove('active');
                    document.body.style.overflow = '';
                }
            });
        });
    </script>
</body>
</html>