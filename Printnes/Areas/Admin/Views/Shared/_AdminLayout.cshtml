<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Printnes ERP</title>

    <!-- الخطوط والأيقونات -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- ملف الستايل الخاص بالـ Admin فقط لضمان Premium Look -->
    <link rel="stylesheet" href="~/css/admin-style.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">

    <!-- القائمة الجانبية (Sidebar) -->
    <aside class="erp-sidebar" id="erp-sidebar">
        <div class="erp-sidebar-header">
            <a href="/Admin/Dashboard">
                <img src="https://cdn.salla.sa/rDvVQ/cOd3EfWfrDP0n64aE7wrEEXzWprxjvx6kvvsO0aR.png" alt="Printnes ERP" style="filter: brightness(0) invert(1);">
            </a>
            <div class="erp-badge">ERP SYSTEM V2.0</div>
        </div>

        <ul class="erp-nav">
            <div class="erp-nav-title">العمليات اليومية</div>
            <li><a href="/Admin/Dashboard" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")"><i class="fas fa-chart-pie"></i> لوحة القيادة</a></li>
            <li><a href="/Admin/Orders" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" ? "active" : "")"><i class="fas fa-file-invoice-dollar"></i> إدارة الطلبات</a></li>

            <div class="erp-nav-title" style="margin-top: 20px;">المتجر والتسعير</div>
            <li><a href="/Admin/Products" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")"><i class="fas fa-box-open"></i> المنتجات</a></li>
            <li><a href="/Admin/Categories" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active" : "")"><i class="fas fa-layer-group"></i> الأقسام</a></li>
            <li><a href="/Admin/Pricing" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Pricing" ? "active" : "")"><i class="fas fa-calculator"></i> مصفوفة الأسعار</a></li>
            <li><a href="/Admin/ProductOptions" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductOptions" ? "active" : "")"><i class="fas fa-sliders-h"></i> خيارات الطباعة</a></li>
            <li><a href="/Admin/ProductExtras" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductExtras" ? "active" : "")"><i class="fas fa-puzzle-piece"></i> إضافات المنتجات</a></li>
            <li><a href="/Admin/QuantityTiers" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "QuantityTiers" ? "active" : "")"><i class="fas fa-percent"></i> شرائح الكميات</a></li>

            <div class="erp-nav-title" style="margin-top: 20px;">الإدارة والصلاحيات</div>
            <li><a href="/Admin/Users" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")"><i class="fas fa-users-cog"></i> الموظفين والعملاء</a></li>
            <li><a href="/Admin/Roles" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Roles" ? "active" : "")"><i class="fas fa-user-shield"></i> الصلاحيات</a></li>
            <li><a href="/Admin/Settings" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")"><i class="fas fa-cog"></i> إعدادات النظام</a></li>
        </ul>
    </aside>

    <!-- المحتوى الرئيسي -->
    <div class="erp-main">

        <!-- الشريط العلوي (Topbar) -->
        <header class="erp-topbar">
            <div class="erp-topbar-left">
                <button id="toggle-sidebar" class="toggle-sidebar-btn">
                    <i class="fas fa-bars"></i>
                </button>
                <div style="font-weight: 700; color: var(--erp-text-light); margin-right: 15px;">
                    @DateTime.Now.ToString("dd MMMM yyyy")
                </div>
            </div>

            <div class="erp-topbar-right">
                <a href="/" target="_blank" class="btn-erp btn-erp-outline" style="padding: 8px 15px;" title="زيارة المتجر">
                    <i class="fas fa-external-link-alt"></i> المتجر
                </a>

                <div class="erp-profile">
                    <div class="erp-profile-info">
                        <span class="erp-profile-name">@(User.Identity.IsAuthenticated? User.Identity.Name : "مدير النظام")</span>
                        <span class="erp-profile-role">إدارة عليا</span>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=Admin&background=f26a2e&color=fff&bold=true" alt="Admin">
                </div>

                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    <button type="submit" style="background:none; border:none; color: #ef4444; font-size: 20px; cursor: pointer;" title="تسجيل الخروج">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </form>
            </div>
        </header>

        <!-- منطقة العمل (Content) -->
        <div class="erp-content">
            @RenderBody()
        </div>
    </div>

    <!-- سكربتات لوحة التحكم -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/admin-script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>