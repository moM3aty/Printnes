@model Printnes.Models.QuantityTier
@{
    ViewData["Title"] = "إضافة شريحة خصم";
}

<div class="erp-page-header">
    <h1 class="erp-page-title"><i class="fas fa-plus-circle"></i> إضافة شريحة خصم جديدة</h1>
    <a href="/Admin/QuantityTiers" style="color: var(--erp-primary); text-decoration: none; font-weight:bold;"><i class="fas fa-arrow-right"></i> عودة للشرائح</a>
</div>

<div class="erp-card" style="max-width: 800px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" style="color: #ef4444; margin-bottom: 15px;"></div>

        <div style="margin-bottom: 20px;">
            <label style="display:block; margin-bottom:8px; font-weight:700; color:var(--erp-text);">المنتج المستهدف بالخصم *</label>
            <select asp-for="ProductId" asp-items="ViewBag.ProductId" style="width: 100%; padding: 12px; border: 1px solid var(--erp-border); border-radius: 8px; background: var(--erp-bg); font-family: inherit;">
                <option value="">-- حدد المنتج --</option>
            </select>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div>
                <label style="display:block; margin-bottom:8px; font-weight:700; color:var(--erp-text);">الحد الأدنى للكمية *</label>
                <input asp-for="MinQuantity" type="number" style="width: 100%; padding: 12px; border: 1px solid var(--erp-border); border-radius: 8px; background: var(--erp-bg); font-family: inherit;" placeholder="مثال: 500" required />
            </div>
            <div>
                <label style="display:block; margin-bottom:8px; font-weight:700; color:var(--erp-text);">الحد الأقصى للكمية *</label>
                <input asp-for="MaxQuantity" type="number" style="width: 100%; padding: 12px; border: 1px solid var(--erp-border); border-radius: 8px; background: var(--erp-bg); font-family: inherit;" placeholder="مثال: 1000" required />
            </div>
        </div>

        <div style="margin-bottom: 30px;">
            <label style="display:block; margin-bottom:8px; font-weight:700; color:var(--erp-text);">نسبة الخصم المئوية (%) *</label>
            <input asp-for="DiscountPercent" type="number" step="0.01" style="width: 100%; padding: 12px; border: 1px solid var(--erp-border); border-radius: 8px; background: var(--erp-bg); font-family: inherit;" placeholder="مثال: 15.50" required />
            <small style="color: var(--erp-text-light); margin-top: 5px; display: block;">النسبة المئوية التي سيتم خصمها من الإجمالي إذا طابقت الكمية هذه الشريحة.</small>
        </div>

        <button type="submit" class="btn-erp" style="padding: 12px 35px; font-size: 16px;"><i class="fas fa-save"></i> حفظ شريحة الخصم</button>
    </form>
</div>