<!-- الملف: Areas/Admin/Views/QuantityTiers/Create.cshtml -->
@model Printnes.Models.QuantityTier
@{
    ViewData["Title"] = "إضافة شريحة خصم";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-plus-circle"></i> إضافة شريحة خصم جديدة</h1>
    <a href="/Admin/QuantityTiers" class="btn-outline"><i class="fas fa-arrow-right"></i> عودة للشرائح</a>
</div>

<div class="premium-card" style="max-width: 800px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="validation-summary-errors"></div>

        <div class="form-group">
            <label class="form-label">المنتج المستهدف بالخصم *</label>
            <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-control" required>
                <option value="">-- حدد المنتج --</option>
            </select>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">الحد الأدنى للكمية *</label>
                <input asp-for="MinQuantity" type="number" class="form-control" placeholder="مثال: 500" required />
            </div>
            <div class="form-group">
                <label class="form-label">الحد الأقصى للكمية *</label>
                <input asp-for="MaxQuantity" type="number" class="form-control" placeholder="مثال: 1000" required />
            </div>
        </div>

        <div class="form-group" style="max-width: 50%;">
            <label class="form-label">نسبة الخصم المئوية (%) *</label>
            <div style="position: relative;">
                <input asp-for="DiscountPercent" type="number" step="0.01" class="form-control" placeholder="مثال: 15.50" required />
                <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-weight: bold;">%</span>
            </div>
            <span class="form-hint">النسبة المئوية التي سيتم خصمها من الإجمالي إذا طابقت الكمية هذه الشريحة.</span>
        </div>

        <hr style="border: none; border-top: 1px solid var(--border-color); margin: 30px 0;">

        <button type="submit" class="btn-premium"><i class="fas fa-save"></i> حفظ شريحة الخصم</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}