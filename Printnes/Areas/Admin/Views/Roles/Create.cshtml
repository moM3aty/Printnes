<!-- الملف: Areas/Admin/Views/Roles/Create.cshtml -->
@{
    ViewData["Title"] = "إضافة صلاحية جديدة";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-user-shield"></i> إضافة صلاحية جديدة</h1>
    <a href="/Admin/Roles" class="btn-outline"><i class="fas fa-arrow-right"></i> العودة للصلاحيات</a>
</div>

<div class="premium-card" style="max-width: 600px;">
    <form asp-action="Create" method="post">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary-errors">
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }

        <div class="form-group">
            <label class="form-label">اسم الصلاحية (باللغة الإنجليزية) *</label>
            <input type="text" name="roleName" class="form-control" placeholder="مثال: Accountant أو Designer" required />
            <span class="form-hint" style="margin-top: 8px;">يُفضل كتابة اسم الصلاحية باللغة الإنجليزية لسهولة استخدامها في الكود (مثال: Roles="Accountant").</span>
        </div>

        <hr style="border: none; border-top: 1px solid var(--border-color); margin: 30px 0;">

        <button type="submit" class="btn-premium"><i class="fas fa-plus-circle"></i> إنشاء الصلاحية</button>
    </form>
</div>