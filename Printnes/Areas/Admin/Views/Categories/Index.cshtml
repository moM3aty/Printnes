<!-- الملف: Areas/Admin/Views/Categories/Index.cshtml -->
@model IEnumerable<Printnes.Models.Category>
@{
    ViewData["Title"] = "إدارة الأقسام";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-layer-group"></i> إدارة الأقسام</h1>
    <a href="/Admin/Categories/Create" class="btn-premium"><i class="fas fa-plus"></i> إضافة قسم جديد</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle"></i>
        @TempData["ErrorMessage"]
    </div>
}

<!-- شريط الفلترة -->
<div class="premium-card" style="padding: 18px 24px;">
    <form asp-action="Index" method="get">
        <div class="filter-bar">
            <div style="position: relative; flex: 1; min-width: 220px;">
                <i class="fas fa-search" style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" name="searchQuery" value="@ViewBag.SearchQuery"
                       class="filter-input" style="padding-right: 40px;"
                       placeholder="ابحث بالاسم أو الرابط..." />
            </div>

            <select name="parentFilter" class="filter-select" style="min-width: 220px;">
                @if (ViewBag.ParentMenus != null)
                {
                    foreach (var pm in ViewBag.ParentMenus)
                    {
                        <option value="@pm.Value" selected="@(ViewBag.ParentFilter?.ToString() == pm.Value)">@pm.Text</option>
                    }
                }
            </select>

            <select name="status" class="filter-select" style="min-width: 150px;">
                <option value="">كل الحالات</option>
                <option value="1" selected="@(ViewBag.Status?.ToString() == "1")">نشط</option>
                <option value="0" selected="@(ViewBag.Status?.ToString() == "0")">غير نشط</option>
            </select>

            <select name="sortBy" class="filter-select" style="min-width: 160px;">
                <option value="sortOrder" selected="@(ViewBag.SortBy == "sortOrder")">الترتيب</option>
                <option value="name_asc" selected="@(ViewBag.SortBy == "name_asc")">الاسم (أ-ي)</option>
                <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc")">الاسم (ي-أ)</option>
                <option value="newest" selected="@(ViewBag.SortBy == "newest")">الأحدث أولاً</option>
            </select>

            <button type="submit" class="btn-premium btn-sm"><i class="fas fa-filter"></i> تصفية</button>
            <a href="/Admin/Categories" class="btn-outline btn-sm"><i class="fas fa-redo"></i> إعادة تعيين</a>
        </div>
    </form>
</div>

<!-- جدول الأقسام -->
<div class="table-container">
    <div class="table-header">
        <h3>
            <i class="fas fa-th-list" style="color: var(--primary-color);"></i>
            هيكلة الأقسام
            <span class="badge badge-neutral" style="font-size: 11px;">@(Model?.Count() ?? 0) قسم</span>
        </h3>
    </div>

    <div class="table-responsive">
        <table class="premium-table">
            <thead>
                <tr>
                    <th style="width: 80px; text-align: center;">الأيقونة</th>
                    <th>الصورة</th>
                    <th>اسم القسم</th>
                    <th>النوع / التبعية</th>
                    <th>الرابط (Slug)</th>
                    <th style="text-align: center;">الترتيب</th>
                    <th>الحالة</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align: center;">
                                @if (!string.IsNullOrEmpty(item.IconClass))
                                {
                                    string iconClass = item.IconClass;
                                    if (!iconClass.StartsWith("fas ") && !iconClass.StartsWith("fab ") && !iconClass.StartsWith("far "))
                                    {
                                        iconClass = "fas " + iconClass;
                                    }
                                    <div style="width: 44px; height: 44px; border-radius: var(--radius-sm); background: var(--primary-light); display: flex; align-items: center; justify-content: center; margin: 0 auto; color: var(--primary-color); font-size: 18px;">
                                        <i class="@iconClass"></i>
                                    </div>
                                }
                                else
                                {
                                    <div style="width: 44px; height: 44px; border-radius: var(--radius-sm); background: var(--border-light); display: flex; align-items: center; justify-content: center; margin: 0 auto; color: var(--text-muted); font-size: 18px;">
                                        <i class="fas fa-icons"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" style="width: 50px; height: 50px; object-fit: cover; border-radius: var(--radius-sm); border: 2px solid var(--border-light);" alt="@item.NameAr">
                                }
                                else
                                {
                                    <div style="width: 50px; height: 50px; background: var(--border-light); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                                        <i class="fas fa-image" style="font-size: 16px;"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <strong style="color: var(--text-main); display: block; font-size: 14px;">@item.NameAr</strong>
                                <small style="color: var(--text-muted);">@item.NameEn</small>
                            </td>
                            <td>
                                @if (string.IsNullOrEmpty(item.ParentMenu))
                                {
                                    <span class="badge" style="background: #fef3c7; color: #d97706; padding: 6px 12px; font-weight: 800;">
                                        <i class="fas fa-star" style="margin-left: 4px;"></i> قسم رئيسي
                                    </span>
                                }
                                else
                                {
                                    // البحث عن اسم القسم الأب من الموديل الحالي
                                    var parentCategory = Model.FirstOrDefault(c => c.Slug == item.ParentMenu);
                                    string parentName = parentCategory != null ? parentCategory.NameAr : item.ParentMenu;

                                    <div style="display: flex; flex-direction: column; gap: 6px;">
                                        <span class="badge" style="background: #f0fdf4; color: #16a34a; width: fit-content; padding: 4px 10px; font-size: 11px;">
                                            <i class="fas fa-code-branch" style="margin-left: 4px;"></i> قسم فرعي
                                        </span>
                                        <span style="font-size: 11px; color: var(--text-muted); font-weight: 700;">
                                            تابع لـ: <strong style="color: var(--navy);">@parentName</strong>
                                        </span>
                                    </div>
                                }
                            </td>
                            <td>
                                <code style="background: var(--border-light); padding: 5px 10px; border-radius: var(--radius-xs); font-size: 12px; color: var(--text-secondary); font-weight: bold;">
                                    @item.Slug
                                </code>
                            </td>
                            <td style="text-align: center;">
                                <span class="badge badge-neutral" style="font-size: 13px; font-weight: 800;">@item.SortOrder</span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success" style="padding: 6px 10px;"><i class="fas fa-check-circle"></i> نشط</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger" style="padding: 6px 10px;"><i class="fas fa-times-circle"></i> معطل</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="/Admin/Categories/Edit/@item.Id" class="btn-outline btn-icon" title="تعديل" style="color: var(--info); border-color: var(--info);">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display: inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذا القسم؟');">
                                        <button type="submit" class="btn-outline btn-icon btn-delete-confirm" title="حذف" style="color: var(--danger); border-color: var(--danger);">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="fas fa-folder-open"></i>
                                <h3>لا توجد أقسام</h3>
                                <p>لم يتم العثور على أقسام تطابق معايير البحث</p>
                                <a href="/Admin/Categories/Create" class="btn-premium btn-sm">
                                    <i class="fas fa-plus"></i> إضافة أول قسم
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>