<!-- الملف: Areas/Admin/Views/ProductOptions/Index.cshtml -->
@model IEnumerable<Printnes.Models.ProductOption>
@{
    ViewData["Title"] = "خيارات المنتجات";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-sliders-h"></i> إدارة خيارات المنتجات</h1>
    <a href="/Admin/ProductOptions/Create" class="btn-premium"><i class="fas fa-plus"></i> إضافة خيار جديد</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle"></i>
        @TempData["ErrorMessage"]
    </div>
}

<div class="premium-card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="premium-table">
            <thead>
                <tr>
                    <th>المنتج المرتبط</th>
                    <th>نوع الخيار</th>
                    <th>الاسم (عربي)</th>
                    <th>الترتيب</th>
                    <th>الحالة</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="font-weight: 800; color: var(--text-main);">@item.Product?.NameAr</td>
                            <td>
                                @{
                                    string typeBadgeClass = "badge-neutral";
                                    string typeText = "";

                                    switch (item.OptionType)
                                    {
                                        case 1: typeText = "ورق"; typeBadgeClass = "badge-info"; break;
                                        case 2: typeText = "مقاس"; typeBadgeClass = "badge-purple"; break;
                                        case 3: typeText = "أوجه"; typeBadgeClass = "badge-warning"; break;
                                        default: typeText = "تشطيب/حماية"; typeBadgeClass = "badge-success"; break;
                                    }
                                }
                                <span class="badge @typeBadgeClass" style="font-size: 12px;">@typeText</span>
                            </td>
                            <td><strong style="color: var(--text-secondary);">@item.NameAr</strong></td>
                            <td><span class="badge badge-neutral">@item.SortOrder</span></td>
                            <td>
                                @(item.IsActive? Html.Raw("<span class='badge badge-success'><i class='fas fa-check-circle'></i> نشط</span>") : Html.Raw("<span class='badge badge-danger'><i class='fas fa-times-circle'></i> معطل</span>"))
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="/Admin/ProductOptions/Edit/@item.Id" class="btn-outline btn-icon" title="تعديل"><i class="fas fa-edit"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذا الخيار؟');">
                                        <button type="submit" class="btn-outline btn-icon btn-delete-confirm" title="حذف" style="color: var(--danger);">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="padding: 40px; text-align: center; color: var(--text-muted);">
                            <i class="fas fa-stream" style="font-size: 40px; margin-bottom: 15px; opacity: 0.5;"></i>
                            <p>لا توجد خيارات مضافة. قم بإضافة خيارات لربطها بمصفوفة الأسعار.</p>
                            <a href="/Admin/ProductOptions/Create" style="color: var(--primary-color); font-weight: 700; text-decoration: none;">إضافة خيار الآن</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>