<!-- الملف: Areas/Admin/Views/ProductOptions/Index.cshtml -->
@model IEnumerable<Printnes.Models.ProductOption>
@{
    ViewData["Title"] = "خيارات المنتجات";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-sliders-h"></i> إدارة خيارات المنتجات</h1>
    <a href="/Admin/ProductOptions/Create" class="btn-premium"><i class="fas fa-plus"></i> إضافة خيار جديد</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle"></i>
        @TempData["ErrorMessage"]
    </div>
}

<!-- شريط الفلترة المتقدم (مربوط بالكنترولر) -->
<div class="premium-card" style="padding: 18px 24px;">
    <form asp-action="Index" method="get">
        <div class="filter-bar">
            <div style="position: relative; flex: 1; min-width: 200px;">
                <i class="fas fa-search" style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" name="searchQuery" value="@ViewBag.SearchQuery"
                       class="filter-input" style="padding-right: 40px;"
                       placeholder="ابحث باسم الخيار..." />
            </div>

            <select name="productIdFilter" class="filter-select" asp-items="ViewBag.Products" style="min-width: 180px;">
                <option value="">كل المنتجات</option>
            </select>

            <select name="optionTypeFilter" class="filter-select" style="min-width: 150px;">
                <option value="">كل الأنواع</option>
                <option value="1" selected="@(ViewBag.OptionTypeFilter?.ToString() == "1")">خامة / ورق</option>
                <option value="2" selected="@(ViewBag.OptionTypeFilter?.ToString() == "2")">المقاس</option>
                <option value="3" selected="@(ViewBag.OptionTypeFilter?.ToString() == "3")">الأوجه</option>
                <option value="4" selected="@(ViewBag.OptionTypeFilter?.ToString() == "4")">التشطيب</option>
            </select>

            <select name="statusFilter" class="filter-select" style="min-width: 130px;">
                <option value="">كل الحالات</option>
                <option value="1" selected="@(ViewBag.StatusFilter?.ToString() == "1")">نشط</option>
                <option value="0" selected="@(ViewBag.StatusFilter?.ToString() == "0")">معطل</option>
            </select>

            <select name="sortBy" class="filter-select" style="min-width: 150px;">
                <option value="product" selected="@(ViewBag.SortBy == "product")">حسب المنتج</option>
                <option value="type" selected="@(ViewBag.SortBy == "type")">حسب النوع</option>
                <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc")">الاسم (ي-أ)</option>
            </select>

            <button type="submit" class="btn-premium btn-sm"><i class="fas fa-filter"></i> تصفية</button>
            <a href="/Admin/ProductOptions" class="btn-outline btn-sm"><i class="fas fa-redo"></i> إعادة</a>
        </div>
    </form>
</div>

<div class="table-container">
    <div class="table-header">
        <h3>
            <i class="fas fa-list-ul" style="color: var(--primary-color);"></i>
            الخيارات المضافة
            <span class="badge badge-neutral" style="font-size: 11px;">@(Model?.Count() ?? 0) خيار</span>
        </h3>
    </div>

    <div class="table-responsive">
        <table class="premium-table">
            <thead>
                <tr>
                    <th>المنتج المرتبط</th>
                    <th>نوع الخيار</th>
                    <th>الاسم (عربي/إنجليزي)</th>
                    <th>الترتيب</th>
                    <th>الحالة</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong style="color: var(--navy); font-size: 14px;">@item.Product?.NameAr</strong>
                            </td>
                            <td>
                                @{
                                    string typeBadgeClass = "badge-neutral";
                                    string typeText = "";
                                    string typeIcon = "";

                                    switch (item.OptionType)
                                    {
                                        case 1: typeText = "ورق / خامة"; typeBadgeClass = "badge-info"; typeIcon = "fa-scroll"; break;
                                        case 2: typeText = "المقاس"; typeBadgeClass = "badge-purple"; typeIcon = "fa-ruler-combined"; break;
                                        case 3: typeText = "الأوجه"; typeBadgeClass = "badge-warning"; typeIcon = "fa-copy"; break;
                                        default: typeText = "تشطيب/حماية"; typeBadgeClass = "badge-success"; typeIcon = "fa-magic"; break;
                                    }
                                }
                                <span class="badge @typeBadgeClass" style="font-size: 12px; display: inline-flex; align-items: center; gap: 5px;">
                                    <i class="fas @typeIcon"></i> @typeText
                                </span>
                            </td>
                            <td>
                                <strong style="color: var(--text-main); display: block; font-size: 14px;">@item.NameAr</strong>
                                @if (!string.IsNullOrEmpty(item.NameEn))
                                {
                                    <small style="color: var(--text-muted); font-family: monospace;">@item.NameEn</small>
                                }
                            </td>
                            <td><span class="badge badge-neutral" style="font-weight: 800;">@item.SortOrder</span></td>
                            <td>
                                @(item.IsActive? Html.Raw("<span class='badge badge-success'><i class='fas fa-check-circle'></i> نشط</span>") : Html.Raw("<span class='badge badge-danger'><i class='fas fa-times-circle'></i> معطل</span>"))
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <!-- زر الإيقاف/التفعيل السريع -->
                                    <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @if (item.IsActive)
                                        {
                                            <button type="submit" class="btn-outline btn-icon" title="تعطيل الخيار" style="color: var(--warning); border-color: var(--warning);">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn-outline btn-icon" title="تفعيل الخيار" style="color: var(--success); border-color: var(--success);">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        }
                                    </form>

                                    <a href="/Admin/ProductOptions/Edit/@item.Id" class="btn-outline btn-icon" title="تعديل الخيار">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذا الخيار؟');">
                                        <button type="submit" class="btn-outline btn-icon btn-delete-confirm" title="حذف نهائي" style="color: var(--danger);">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="padding: 50px 20px; text-align: center; color: var(--text-muted);">
                            <div class="empty-state">
                                <i class="fas fa-sliders-h" style="font-size: 45px; margin-bottom: 15px; color: #cbd5e1;"></i>
                                <h3 style="color: var(--navy); font-weight: 800; margin-bottom: 5px;">لا توجد خيارات مضافة</h3>
                                <p style="margin-bottom: 15px;">لم يتم العثور على خيارات طباعة مطابقة لعملية البحث أو لم يتم إضافتها بعد.</p>
                                <a href="/Admin/ProductOptions/Create" class="btn-premium btn-sm" style="margin: 0 auto;">
                                    <i class="fas fa-plus"></i> إضافة خيار الآن
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>