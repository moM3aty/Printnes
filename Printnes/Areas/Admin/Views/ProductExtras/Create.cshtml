<!-- الملف: Areas/Admin/Views/ProductExtras/Create.cshtml -->
@model Printnes.Models.ProductExtra
@{
    ViewData["Title"] = "إضافة خيار إضافي للمنتج";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-plus-circle"></i> إضافة خيار إضافي جديد</h1>
    <a href="/Admin/ProductExtras" class="btn-premium" style="background: transparent; color: var(--text-main); border: 1px solid var(--border-color);"><i class="fas fa-arrow-right"></i> عودة للإضافات</a>
</div>

<div class="premium-card" style="max-width: 800px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="validation-summary-errors" style="margin-bottom: 20px; display: block; border-radius: 8px; padding: 15px;"></div>

        <div class="form-group">
            <label class="form-label">المنتج المرتبط بالخيار الإضافي *</label>
            <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-control" required>
                <option value="">-- حدد المنتج --</option>
            </select>
            <span asp-validation-for="ProductId" class="field-validation-error"></span>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">الاسم بالعربية *</label>
                <input asp-for="NameAr" class="form-control" placeholder="مثال: طلب تصميم خاص" required />
                <span asp-validation-for="NameAr" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label">الاسم بالإنجليزية *</label>
                <input asp-for="NameEn" class="form-control" placeholder="e.g: Custom Design Request" required />
                <span asp-validation-for="NameEn" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">سعر الإضافة الثابت (ر.س) *</label>
                <div style="position: relative;">
                    <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="مثال: 250.00" required />
                    <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-weight: bold;">ر.س</span>
                </div>
                <small class="form-hint">يُضاف هذا المبلغ مباشرة فوق إجمالي الطلب بغض النظر عن الكمية.</small>
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label">الترتيب في العرض</label>
                <input asp-for="SortOrder" type="number" class="form-control" value="0" />
            </div>
        </div>

        <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-top: 10px;">
            <input type="checkbox" asp-for="IsActive" checked style="width: 18px; height: 18px; accent-color: var(--primary-color);" />
            <label asp-for="IsActive" class="form-label" style="margin: 0; cursor: pointer;">تفعيل هذه الإضافة وإظهارها للعملاء</label>
        </div>

        <hr style="border: none; border-top: 1px solid var(--border-color); margin: 30px 0;">

        <button type="submit" class="btn-premium"><i class="fas fa-save"></i> حفظ الخيار الإضافي</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}