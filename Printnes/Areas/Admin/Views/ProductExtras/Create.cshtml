@model Printnes.Models.ProductExtra
@{
    ViewData["Title"] = "إضافة خيار إضافي للمنتج";
    Layout = "_AdminLayout";
}

<div class="erp-page-header">
    <h1 class="erp-page-title"><i class="fas fa-plus-circle"></i> إضافة خيار إضافي جديد</h1>
    <a href="/Admin/ProductExtras" class="btn-erp btn-erp-outline"><i class="fas fa-arrow-right"></i> عودة للإضافات</a>
</div>

<div class="erp-card" style="max-width: 800px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="status-danger" style="margin-bottom: 20px; display: block; border-radius: 8px; padding: 15px;"></div>

        <div class="erp-form-group">
            <label class="erp-form-label">المنتج المرتبط بالخيار الإضافي *</label>
            <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="erp-form-control" required>
                <option value="">-- حدد المنتج --</option>
            </select>
            <span asp-validation-for="ProductId" style="color: red; font-size: 12px;"></span>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div class="erp-form-group">
                <label class="erp-form-label">الاسم بالعربية *</label>
                <input asp-for="NameAr" class="erp-form-control" placeholder="مثال: طلب تصميم خاص" required />
                <span asp-validation-for="NameAr" style="color: red; font-size: 12px;"></span>
            </div>

            <div class="erp-form-group">
                <label class="erp-form-label">الاسم بالإنجليزية *</label>
                <input asp-for="NameEn" class="erp-form-control" placeholder="e.g: Custom Design Request" required />
                <span asp-validation-for="NameEn" style="color: red; font-size: 12px;"></span>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div class="erp-form-group">
                <label class="erp-form-label">سعر الإضافة الثابت (ر.س) *</label>
                <input asp-for="Price" type="number" step="0.01" class="erp-form-control" placeholder="مثال: 250.00" required />
                <small style="color: var(--erp-text-light);">يُضاف هذا المبلغ مباشرة فوق إجمالي الطلب بغض النظر عن الكمية.</small>
                <span asp-validation-for="Price" style="color: red; font-size: 12px;"></span>
            </div>

            <div class="erp-form-group">
                <label class="erp-form-label">الترتيب في العرض</label>
                <input asp-for="SortOrder" type="number" class="erp-form-control" value="0" />
            </div>
        </div>

        <div class="erp-form-group" style="display: flex; align-items: center; gap: 10px; margin-top: 10px;">
            <input type="checkbox" asp-for="IsActive" checked style="width: 18px; height: 18px; accent-color: var(--erp-orange);" />
            <label asp-for="IsActive" class="erp-form-label" style="margin: 0; cursor: pointer;">تفعيل هذه الإضافة وإظهارها للعملاء</label>
        </div>

        <hr style="border: none; border-top: 1px solid var(--erp-border); margin: 30px 0;">

        <button type="submit" class="btn-erp"><i class="fas fa-save"></i> حفظ الخيار الإضافي</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}