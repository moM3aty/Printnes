@model IEnumerable<Printnes.Models.Product>
@{
    ViewData["Title"] = "إدارة المنتجات";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-box-open"></i> إدارة المنتجات</h1>
    <a href="/Admin/Products/Create" class="btn-premium"><i class="fas fa-plus"></i> إضافة منتج جديد</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss" style="border-radius: 12px; font-weight: 700;">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-auto-dismiss" style="border-radius: 12px; font-weight: 700; background-color: #fef2f2; color: #ef4444; border: 1px solid #fecaca; padding: 15px; margin-bottom: 20px;">
        <i class="fas fa-exclamation-triangle"></i>
        @TempData["ErrorMessage"]
    </div>
}

<!-- شريط الفلترة -->
<div class="premium-card" style="padding: 18px 24px;">
    <form asp-action="Index" method="get" id="filterForm">
        <div class="filter-bar">
            <div style="position: relative; flex: 1; min-width: 220px;">
                <i class="fas fa-search" style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" name="searchQuery" value="@ViewBag.SearchQuery"
                       class="filter-input" style="padding-right: 40px;"
                       placeholder="ابحث بالاسم..." />
            </div>

            <select name="categoryId" class="filter-select" style="min-width: 180px;">
                <option value="">كل الأقسام</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Value" selected="@(ViewBag.CategoryId?.ToString() == cat.Value)">@cat.Text</option>
                    }
                }
            </select>

            <select name="status" class="filter-select" style="min-width: 150px;">
                <option value="">كل الحالات</option>
                <option value="1" selected="@(ViewBag.Status?.ToString() == "1")">نشط</option>
                <option value="0" selected="@(ViewBag.Status?.ToString() == "0")">غير نشط</option>
            </select>

            <select name="sortBy" class="filter-select" style="min-width: 160px;">
                <option value="newest" selected="@(ViewBag.SortBy == "newest")">الأحدث أولاً</option>
                <option value="oldest" selected="@(ViewBag.SortBy == "oldest")">الأقدم أولاً</option>
                <option value="name_asc" selected="@(ViewBag.SortBy == "name_asc")">الاسم (أ-ي)</option>
                <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc")">الاسم (ي-أ)</option>
            </select>

            <button type="submit" class="btn-premium btn-sm">
                <i class="fas fa-filter"></i> تصفية
            </button>

            <a href="/Admin/Products" class="btn-outline btn-sm">
                <i class="fas fa-redo"></i> إعادة تعيين
            </a>
        </div>
    </form>
</div>

<!-- جدول المنتجات -->
<div class="table-container">
    <div class="table-header">
        <h3>
            <i class="fas fa-list" style="color: var(--primary-color);"></i>
            المنتجات
            <span class="badge badge-neutral" style="font-size: 11px;">@(Model?.Count() ?? 0) منتج</span>
        </h3>
    </div>

    <div class="table-responsive">
        <table class="premium-table">
            <thead>
                <tr>
                    <th style="width: 80px;">الصورة</th>
                    <th>اسم المنتج</th>
                    <th>القسم</th>
                    <th>الرابط</th>
                    <th>الكمية المسموحة</th>
                    <th>الحالة</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                {
                                    <img src="@item.CoverImageUrl" class="td-image" alt="@item.NameAr">
                                }
                                else
                                {
                                    <div style="width: 55px; height: 55px; background: var(--border-light); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                                        <i class="fas fa-image"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <strong style="color: var(--text-main); display: block;">@item.NameAr</strong>
                                <small style="color: var(--text-muted);">@item.NameEn</small>
                            </td>
                            <td>
                                <span class="badge badge-info">
                                    @(item.Category?.NameAr ?? "غير محدد")
                                </span>
                            </td>
                            <td>
                                <code style="background: var(--border-light); padding: 4px 10px; border-radius: var(--radius-xs); font-size: 12px; color: var(--text-secondary);">
                                    @item.Slug
                                </code>
                            </td>
                            <td style="font-size: 13px; color: var(--text-secondary);">
                                <span style="color: var(--success); font-weight: 700;">@item.MinQuantity</span>
                                -
                                <span style="color: var(--info); font-weight: 700;">@item.MaxQuantity.ToString("N0")</span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success"><i class="fas fa-check-circle"></i> نشط</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger"><i class="fas fa-times-circle"></i> معطل</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="/Admin/Products/Edit/@item.Id" class="btn-outline btn-icon" title="تعديل">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/Products/Details/@item.Id" target="_blank" class="btn-outline btn-icon" title="عرض في المتجر" style="color: var(--info);">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                    <!-- 🟢 تعديل زر الحذف هنا 🟢 -->
                                    <form action="/Admin/Products/Delete/@item.Id" method="post" style="display: inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذا المنتج نهائياً؟');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-outline btn-icon btn-delete-confirm" title="حذف" style="color: #ef4444; border-color: #fecaca; background: #fef2f2;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-box-open"></i>
                                <h3>لا توجد منتجات</h3>
                                <p>لم يتم العثور على منتجات تطابق معايير البحث</p>
                                <a href="/Admin/Products/Create" class="btn-premium btn-sm">
                                    <i class="fas fa-plus"></i> إضافة أول منتج
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>