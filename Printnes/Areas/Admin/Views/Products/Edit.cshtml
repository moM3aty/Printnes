@model Printnes.Models.Product
@{
    ViewData["Title"] = "تعديل المنتج: " + Model.NameAr;
}

<style>
    /* Premium UI Styles */
    .glass-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        border: 1px solid #f1f5f9;
        padding: 30px;
        margin-top: 20px;
    }

    .modern-form-row {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .modern-form-group {
        flex: 1;
        min-width: 250px;
    }

    .modern-label {
        display: block;
        font-size: 13px;
        font-weight: 800;
        color: #64748b;
        margin-bottom: 8px;
    }

    .modern-input {
        width: 100%;
        padding: 14px 15px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-family: inherit;
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
        transition: 0.3s;
    }

        .modern-input:focus {
            background: #fff;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(15,98,254,0.1);
            outline: none;
        }

    .upload-area {
        border: 2px dashed #cbd5e1;
        border-radius: 16px;
        padding: 30px 20px;
        text-align: center;
        background: #f8fafc;
        cursor: pointer;
        transition: 0.3s;
        position: relative;
    }

        .upload-area:hover {
            border-color: var(--primary-color);
            background: #eff6ff;
        }

        .upload-area i {
            font-size: 30px;
            color: #94a3b8;
            margin-bottom: 10px;
            transition: 0.3s;
        }

        .upload-area:hover i {
            color: var(--primary-color);
        }

        .upload-area input[type="file"] {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    /* Toggle Switch */
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #cbd5e1;
        transition: .4s;
        border-radius: 34px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: #10b981;
    }

        input:checked + .slider:before {
            transform: translateX(20px);
        }
</style>

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-edit"></i> تعديل: @Model.NameAr</h1>
    <a href="/Admin/Products" class="btn-outline"><i class="fas fa-arrow-right"></i> العودة للمنتجات</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="glass-card" style="max-width: 1000px; margin: 0 auto;">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 20px; font-weight: bold;"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="CoverImageUrl" id="currentImageUrl" />

        <!-- الصورة الحالية مع إمكانية تغييرها -->
        <div class="modern-form-group" style="margin-bottom: 25px;">
            <label class="modern-label" style="font-size: 15px;">صورة المنتج الرئيسية</label>

            <div style="display: flex; gap: 25px; align-items: stretch; flex-wrap: wrap;">
                <!-- عرض الصورة القديمة -->
                <div id="currentImageBox" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 15px; text-align: center; width: 180px; flex-shrink: 0;">
                    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                    {
                        <img src="@Model.CoverImageUrl" id="currentImageDisplay" style="width: 100%; height: 110px; object-fit: cover; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);" alt="الصورة الحالية" />
                        <span style="display: block; font-size: 12px; color: #64748b; font-weight: 700; margin-top: 10px;"><i class="fas fa-image"></i> الصورة الحالية</span>
                    }
                    else
                    {
                        <div style="width: 100%; height: 110px; background: #e2e8f0; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
                            <i class="fas fa-image" style="font-size: 32px;"></i>
                        </div>
                    }
                </div>

                <!-- مساحة رفع الصورة الجديدة -->
                <div style="flex: 1; min-width: 250px; display: flex; flex-direction: column;">
                    <div class="upload-area" id="imageUploadWrapper" style="flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 20px;">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <strong style="color: var(--navy); font-size: 14px;">اضغط هنا لتغيير الصورة (اختياري)</strong>
                        <span class="file-name" id="fileName" style="font-weight: 800; color: var(--primary-color); margin-top: 8px;"></span>
                        <input type="file" name="coverImageFile" accept="image/*" id="coverImageFile" onchange="handleFileUpload(this)" />
                    </div>
                </div>
            </div>

            <!-- معاينة الصورة الجديدة قبل الحفظ -->
            <div class="img-preview-container" style="margin-top: 15px; display: none; text-align: center; background: #fdf4ff; border: 1px dashed #d946ef; padding: 20px; border-radius: 16px;" id="previewContainer">
                <strong style="color: #d946ef; display: block; margin-bottom: 10px;">✨ معاينة الصورة الجديدة:</strong>
                <img id="imagePreview" src="#" alt="معاينة الصورة الجديدة" style="max-width: 100%; max-height: 150px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); margin-bottom: 15px;" />
                <br>
                <button type="button" class="btn-outline btn-sm" onclick="removePreview()" style="color: #ef4444; border-color: #ef4444;">
                    <i class="fas fa-undo"></i> التراجع للصورة القديمة
                </button>
            </div>
        </div>

        <div class="modern-form-row">
            <div class="modern-form-group">
                <label asp-for="NameAr" class="modern-label">الاسم بالعربية <span class="required">*</span></label>
                <input asp-for="NameAr" class="modern-input" required />
                <span asp-validation-for="NameAr" class="text-danger"></span>
            </div>
            <div class="modern-form-group">
                <label asp-for="NameEn" class="modern-label">الاسم بالإنجليزية <span class="required">*</span></label>
                <input asp-for="NameEn" class="modern-input" required />
                <span asp-validation-for="NameEn" class="text-danger"></span>
            </div>
        </div>

        <div class="modern-form-row">
            <div class="modern-form-group">
                <label asp-for="Slug" class="modern-label">الرابط (Slug) <span class="required">*</span></label>
                <input asp-for="Slug" class="modern-input" required />
                <span asp-validation-for="Slug" class="text-danger"></span>
            </div>
            <div class="modern-form-group">
                <label asp-for="CategoryId" class="modern-label">القسم الرئيسي <span class="required">*</span></label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="modern-input" required>
                    <option value="">-- اختر القسم --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
        </div>

        <div class="modern-form-row">
            <div class="modern-form-group">
                <label asp-for="MinQuantity" class="modern-label">الحد الأدنى للكمية</label>
                <input asp-for="MinQuantity" type="number" class="modern-input" min="1" />
            </div>
            <div class="modern-form-group">
                <label asp-for="MaxQuantity" class="modern-label">الحد الأقصى للكمية</label>
                <input asp-for="MaxQuantity" type="number" class="modern-input" min="1" />
            </div>
        </div>

        <div class="modern-form-group" style="margin-bottom: 25px;">
            <label asp-for="DescriptionAr" class="modern-label">وصف المنتج (عربي)</label>
            <textarea asp-for="DescriptionAr" rows="4" class="modern-input"></textarea>
        </div>

        <!-- مفاتيح التحكم -->
        <div style="display: flex; flex-wrap: wrap; gap: 30px; margin-bottom: 30px; padding: 25px; background: #f8fafc; border-radius: 16px; border: 1px solid #e2e8f0;">
            <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 250px;">
                <label class="toggle-switch">
                    <input type="checkbox" asp-for="IsActive" />
                    <span class="slider"></span>
                </label>
                <div>
                    <strong style="display:block; color:var(--navy); font-size:14px;">المنتج نشط ويظهر في المتجر</strong>
                    <span style="color:#64748b; font-size:12px;">أغلق هذا الخيار إذا أردت إخفاءه مؤقتاً</span>
                </div>
            </div>

            <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 250px;">
                <label class="toggle-switch">
                    <input type="checkbox" asp-for="AllowCustomSize" />
                    <span class="slider"></span>
                </label>
                <div>
                    <strong style="display:block; color:var(--navy); font-size:14px;">السماح بمقاس مخصص</strong>
                    <span style="color:#64748b; font-size:12px;">يُظهر للعميل خيار إدخال أبعاد خاصة</span>
                </div>
            </div>

            <!-- 🟢 الخيار الجديد: إجبار المنتج كجاهز -->
            <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 250px;">
                <label class="toggle-switch">
                    <!-- تأكد من إضافة هذا الحقل إلى الـ Model -->
                    <input type="checkbox" asp-for="IsReadyProduct" />
                    <span class="slider"></span>
                </label>
                <div>
                    <strong style="display:block; color:var(--orange); font-size:14px;">إجبار كمنتج جاهز (بدون خيارات)</strong>
                    <span style="color:#64748b; font-size:12px;">يخفي جميع الخيارات في صفحة المتجر (إن وجدت)</span>
                </div>
            </div>
        </div>

        <hr style="border: none; border-top: 1px solid #e2e8f0; margin-bottom: 25px;">

        <div style="display: flex; justify-content: flex-end; gap: 12px;">
            <a href="/Admin/Products" class="btn-outline" style="padding: 14px 25px; border-radius: 12px; font-weight: 800;">إلغاء</a>
            <button type="submit" class="btn-premium" style="padding: 14px 35px; border-radius: 12px; border: none; font-size: 15px;">
                <i class="fas fa-save"></i> حفظ التعديلات
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function handleFileUpload(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];

                if (file.size > 5 * 1024 * 1024) {
                    alert('حجم الملف يتجاوز 5MB');
                    input.value = '';
                    return;
                }

                document.getElementById('fileName').textContent = file.name;
                document.getElementById('currentImageBox').style.opacity = '0.3';
                document.getElementById('imageUploadWrapper').style.display = 'none';

                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('previewContainer').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        }

        function removePreview() {
            document.getElementById('coverImageFile').value = '';
            document.getElementById('imagePreview').src = '#';
            document.getElementById('previewContainer').style.display = 'none';
            document.getElementById('imageUploadWrapper').style.display = 'flex';
            document.getElementById('fileName').textContent = '';
            document.getElementById('currentImageBox').style.opacity = '1';
        }
    </script>
}