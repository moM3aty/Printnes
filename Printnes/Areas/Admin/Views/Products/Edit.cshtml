<!-- الملف: Areas/Admin/Views/Products/Edit.cshtml -->
@model Printnes.Models.Product
@{
    ViewData["Title"] = "تعديل المنتج: " + Model.NameAr;
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-edit"></i> تعديل المنتج</h1>
    <a href="/Admin/Products" class="btn-outline"><i class="fas fa-arrow-right"></i> العودة للمنتجات</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

<div class="premium-card" style="max-width: 900px;">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="CoverImageUrl" id="currentImageUrl" />

        <!-- الصورة الحالية مع إمكانية تغييرها -->
        <div class="form-group">
            <label class="form-label">صورة المنتج</label>
            <div style="display: flex; gap: 20px; align-items: flex-start; flex-wrap: wrap;">
                <div id="currentImageBox" style="text-align: center;">
                    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                    {
                        <img src="@Model.CoverImageUrl" id="currentImageDisplay"
                             style="width: 150px; height: 100px; object-fit: cover; border-radius: var(--radius-sm); border: 2px solid var(--border-color);" alt="الصورة الحالية" />
                        <p style="font-size: 12px; color: var(--text-muted); margin-top: 8px;">الصورة الحالية</p>
                    }
                    else
                    {
                        <div style="width: 150px; height: 100px; background: var(--border-light); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                            <i class="fas fa-image" style="font-size: 32px;"></i>
                        </div>
                    }
                </div>
                <div style="flex: 1; min-width: 250px;">
                    <div class="file-upload-wrapper" id="imageUploadWrapper" style="height: 100px;">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <span>اضغط لاختيار صورة جديدة</span>
                        <span class="file-name" id="fileName"></span>
                        <input type="file" name="coverImageFile" accept="image/*" id="coverImageFile"
                               onchange="handleFileUpload(this)" />
                    </div>
                    <span class="form-hint">اتركه فارغاً إذا أردت الاحتفاظ بالصورة الحالية</span>
                </div>
            </div>
            <div class="img-preview-container">
                <img id="imagePreview" class="img-preview" src="#" alt="معاينة الصورة الجديدة" />
                <button type="button" id="removePreviewBtn" class="btn-remove-preview" onclick="removePreview()">
                    <i class="fas fa-trash"></i> إلغاء التغيير
                </button>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="NameAr" class="form-label">الاسم بالعربية <span class="required">*</span></label>
                <input asp-for="NameAr" class="form-control" required />
                <span asp-validation-for="NameAr" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="NameEn" class="form-label">الاسم بالإنجليزية <span class="required">*</span></label>
                <input asp-for="NameEn" class="form-control" required />
                <span asp-validation-for="NameEn" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Slug" class="form-label">الرابط (Slug) <span class="required">*</span></label>
                <input asp-for="Slug" class="form-control" required />
                <span asp-validation-for="Slug" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="CategoryId" class="form-label">القسم الرئيسي <span class="required">*</span></label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-control" required>
                    <option value="">-- اختر القسم --</option>
                </select>
                <span asp-validation-for="CategoryId" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="MinQuantity" class="form-label">الحد الأدنى للكمية</label>
                <input asp-for="MinQuantity" type="number" class="form-control" min="1" />
            </div>
            <div class="form-group">
                <label asp-for="MaxQuantity" class="form-label">الحد الأقصى للكمية</label>
                <input asp-for="MaxQuantity" type="number" class="form-control" min="1" />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="DescriptionAr" class="form-label">وصف المنتج (عربي)</label>
            <textarea asp-for="DescriptionAr" rows="4" class="form-control"></textarea>
        </div>

        <div style="display: flex; gap: 30px; margin-bottom: 28px; padding: 18px;
                    background: var(--border-light); border-radius: var(--radius-sm); border: 1px solid var(--border-color);">
            <label class="form-check">
                <input type="checkbox" asp-for="IsActive" />
                <label asp-for="IsActive">المنتج نشط ويظهر في المتجر</label>
            </label>
            <label class="form-check">
                <input type="checkbox" asp-for="AllowCustomSize" />
                <label asp-for="AllowCustomSize">السماح للعميل بإدخال مقاس مخصص</label>
            </label>
        </div>

        <hr style="border: none; border-top: 1px solid var(--border-color); margin: 25px 0;">

        <div style="display: flex; gap: 12px;">
            <button type="submit" class="btn-premium">
                <i class="fas fa-save"></i> حفظ التعديلات
            </button>
            <a href="/Admin/Products" class="btn-outline">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function handleFileUpload(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];

                if (file.size > 5 * 1024 * 1024) {
                    alert('حجم الملف يتجاوز 5MB');
                    input.value = '';
                    return;
                }

                document.getElementById('fileName').textContent = file.name;
                document.getElementById('imageUploadWrapper').classList.add('has-file');

                // إخفاء الصورة الحالية
                document.getElementById('currentImageBox').style.display = 'none';

                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById('imagePreview');
                    preview.src = e.target.result;
                    preview.classList.add('visible');
                    document.getElementById('removePreviewBtn').classList.add('visible');
                };
                reader.readAsDataURL(file);
            }
        }

        function removePreview() {
            const input = document.getElementById('coverImageFile');
            const preview = document.getElementById('imagePreview');
            const wrapper = document.getElementById('imageUploadWrapper');

            input.value = '';
            preview.src = '#';
            preview.classList.remove('visible');
            document.getElementById('removePreviewBtn').classList.remove('visible');
            document.getElementById('fileName').textContent = '';
            wrapper.classList.remove('has-file');

            // إظهار الصورة الحالية مجدداً
            document.getElementById('currentImageBox').style.display = 'block';
        }
    </script>
}