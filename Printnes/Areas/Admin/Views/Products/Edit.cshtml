@model Printnes.Models.Product
@{
    ViewData["Title"] = "تعديل منتج";
    Layout = "_AdminLayout";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1 class="page-title">تعديل المنتج: @Model.NameAr</h1>
    <a href="/Admin/Products" style="color: var(--admin-primary); text-decoration: none;"><i class="fas fa-arrow-right"></i> عودة للمنتجات</a>
</div>

<div class="erp-card" style="max-width: 800px;">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" style="color: red; margin-bottom: 15px;"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
            <div>
                <label style="display:block; margin-bottom:5px; font-weight:bold;">الاسم بالعربية *</label>
                <input asp-for="NameAr" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;" />
                <span asp-validation-for="NameAr" style="color: red; font-size: 12px;"></span>
            </div>
            <div>
                <label style="display:block; margin-bottom:5px; font-weight:bold;">الاسم بالإنجليزية *</label>
                <input asp-for="NameEn" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;" />
                <span asp-validation-for="NameEn" style="color: red; font-size: 12px;"></span>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
            <div>
                <label style="display:block; margin-bottom:5px; font-weight:bold;">الرابط (Slug) *</label>
                <input asp-for="Slug" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;" />
                <span asp-validation-for="Slug" style="color: red; font-size: 12px;"></span>
            </div>
            <div>
                <label style="display:block; margin-bottom:5px; font-weight:bold;">القسم *</label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;"></select>
                <span asp-validation-for="CategoryId" style="color: red; font-size: 12px;"></span>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
            <div>
                <label style="display:block; margin-bottom:5px; font-weight:bold;">أقل كمية</label>
                <input asp-for="MinQuantity" type="number" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;" />
            </div>
            <div>
                <label style="display:block; margin-bottom:5px; font-weight:bold;">أقصى كمية</label>
                <input asp-for="MaxQuantity" type="number" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;" />
            </div>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">رابط الصورة (URL) *</label>
            <input asp-for="CoverImageUrl" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;" />
            <span asp-validation-for="CoverImageUrl" style="color: red; font-size: 12px;"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">وصف المنتج</label>
            <textarea asp-for="DescriptionAr" rows="4" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;"></textarea>
        </div>

        <div style="display: flex; gap: 20px; margin-bottom: 20px;">
            <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; font-weight:bold;">
                <input type="checkbox" asp-for="IsActive" /> المنتج نشط
            </label>
            <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; font-weight:bold;">
                <input type="checkbox" asp-for="AllowCustomSize" /> يسمح بحجم مخصص
            </label>
        </div>

        <button type="submit" style="background: var(--admin-secondary); color: #fff; border: none; padding: 12px 30px; border-radius: 5px; font-weight: bold; cursor: pointer;">حفظ التعديلات</button>
    </form>
</div>