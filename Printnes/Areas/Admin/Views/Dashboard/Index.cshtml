<!-- الملف: Areas/Admin/Views/Dashboard/Index.cshtml -->
@model Printnes.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "لوحة القيادة";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-chart-pie"></i> نظرة عامة على نشاط المطبعة</h1>
    <div style="display: flex; gap: 10px;">
        <span style="font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 6px;">
            <i class="far fa-calendar-alt"></i>
            @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ar-SA"))
        </span>
    </div>
</div>

<!-- كروت الإحصائيات الرئيسية -->
<div class="stats-grid">
    <div class="stat-card orange">
        <div class="stat-info">
            <div class="stat-info-title">طلبات اليوم</div>
            <div class="stat-info-value">@Model.TodayOrdersCount</div>
            <div style="font-size: 12px; color: var(--success); font-weight: 700; margin-top: 4px;">
                <i class="fas fa-arrow-up"></i> مبيعات: @Model.TodaySales.ToString("N0") ر.س
            </div>
        </div>
        <div class="stat-icon-box orange"><i class="fas fa-shopping-bag"></i></div>
    </div>

    <div class="stat-card green">
        <div class="stat-info">
            <div class="stat-info-title">مبيعات الشهر</div>
            <div class="stat-info-value">@Model.MonthSales.ToString("N0") <small>ر.س</small></div>
            <div style="font-size: 12px; font-weight: 700; margin-top: 4px; color: @(Model.RevenueGrowthPercent >= 0 ? "var(--success)" : "var(--danger)");">
                <i class="fas fa-arrow-@(Model.RevenueGrowthPercent >= 0 ? "up" : "down")"></i>
                @Math.Abs(Model.RevenueGrowthPercent)% عن الشهر الماضي
            </div>
        </div>
        <div class="stat-icon-box green"><i class="fas fa-wallet"></i></div>
    </div>

    <div class="stat-card blue">
        <div class="stat-info">
            <div class="stat-info-title">جاري الطباعة</div>
            <div class="stat-info-value">@Model.PrintingOrders</div>
            <div style="font-size: 12px; color: var(--text-muted); font-weight: 600; margin-top: 4px;">
                @Model.ReviewingOrders مراجعة | @Model.ShippingOrders شحن
            </div>
        </div>
        <div class="stat-icon-box blue"><i class="fas fa-print"></i></div>
    </div>

    <div class="stat-card purple">
        <div class="stat-info">
            <div class="stat-info-title">إجمالي العملاء</div>
            <div class="stat-info-value">@Model.TotalCustomers</div>
            <div style="font-size: 12px; color: var(--text-muted); font-weight: 600; margin-top: 4px;">
                @Model.TotalProducts منتج | @Model.TotalCategories قسم
            </div>
        </div>
        <div class="stat-icon-box purple"><i class="fas fa-users"></i></div>
    </div>
</div>

<!-- شريط حالات الطلبات المرئي -->
<div class="premium-card" style="padding: 20px 24px; margin-bottom: 28px;">
    <h3 style="font-size: 14px; font-weight: 800; color: var(--text-main); margin-bottom: 16px;">
        <i class="fas fa-tasks" style="color: var(--primary-color); margin-left: 8px;"></i>
        توزيع حالات الطلبات (الكل: @Model.TotalOrders)
    </h3>
    <div style="display: flex; gap: 0; height: 32px; border-radius: var(--radius-sm); overflow: hidden;">
        @{
            int total = Model.TotalOrders > 0 ? Model.TotalOrders : 1;
            int pendingW = (int)((double)Model.PendingOrders / total * 100);
            int reviewW = (int)((double)Model.ReviewingOrders / total * 100);
            int printW = (int)((double)Model.PrintingOrders / total * 100);
            int shipW = (int)((double)Model.ShippingOrders / total * 100);
            int doneW = 100 - pendingW - reviewW - printW - shipW;
        }
        @if (Model.PendingOrders > 0)
        {
            <div style="width: @pendingW%; background: var(--info); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 11px; font-weight: 700; min-width: 30px;" title="جديد: @Model.PendingOrders">
                @Model.PendingOrders
            </div>
        }
        @if (Model.ReviewingOrders > 0)
        {
            <div style="width: @reviewW%; background: var(--warning); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 11px; font-weight: 700; min-width: 30px;" title="مراجعة: @Model.ReviewingOrders">
                @Model.ReviewingOrders
            </div>
        }
        @if (Model.PrintingOrders > 0)
        {
            <div style="width: @printW%; background: var(--purple); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 11px; font-weight: 700; min-width: 30px;" title="طباعة: @Model.PrintingOrders">
                @Model.PrintingOrders
            </div>
        }
        @if (Model.ShippingOrders > 0)
        {
            <div style="width: @shipW%; background: #f97316; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 11px; font-weight: 700; min-width: 30px;" title="شحن: @Model.ShippingOrders">
                @Model.ShippingOrders
            </div>
        }
        <div style="width: @doneW%; background: var(--success); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 11px; font-weight: 700; min-width: 30px;" title="مكتمل: @Model.CompletedOrders">
            @Model.CompletedOrders
        </div>
    </div>
    <div style="display: flex; gap: 20px; margin-top: 12px; flex-wrap: wrap;">
        <span style="font-size: 12px; display: flex; align-items: center; gap: 6px;"><span style="width: 12px; height: 12px; background: var(--info); border-radius: 3px;"></span> جديد (@Model.PendingOrders)</span>
        <span style="font-size: 12px; display: flex; align-items: center; gap: 6px;"><span style="width: 12px; height: 12px; background: var(--warning); border-radius: 3px;"></span> مراجعة (@Model.ReviewingOrders)</span>
        <span style="font-size: 12px; display: flex; align-items: center; gap: 6px;"><span style="width: 12px; height: 12px; background: var(--purple); border-radius: 3px;"></span> طباعة (@Model.PrintingOrders)</span>
        <span style="font-size: 12px; display: flex; align-items: center; gap: 6px;"><span style="width: 12px; height: 12px; background: #f97316; border-radius: 3px;"></span> شحن (@Model.ShippingOrders)</span>
        <span style="font-size: 12px; display: flex; align-items: center; gap: 6px;"><span style="width: 12px; height: 12px; background: var(--success); border-radius: 3px;"></span> مكتمل (@Model.CompletedOrders)</span>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 28px;">
    <!-- أحدث الطلبات -->
    <div class="table-container">
        <div class="table-header">
            <h3>
                <i class="fas fa-clock" style="color: var(--primary-color);"></i>
                أحدث الطلبات
            </h3>
            <a href="/Admin/Orders" class="btn-outline btn-sm">
                عرض الكل <i class="fas fa-arrow-left"></i>
            </a>
        </div>
        <div class="table-responsive">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>رقم الطلب</th>
                        <th>العميل</th>
                        <th>المبلغ</th>
                        <th>الحالة</th>
                        <th>إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentOrders != null && Model.RecentOrders.Any())
                    {
                        foreach (var order in Model.RecentOrders)
                        {
                            string statusClass = order.OrderStatus switch
                            {
                                1 => "badge-info",
                                2 => "badge-warning",
                                3 => "badge-purple",
                                4 => "badge-success",
                                5 => "badge-success",
                                _ => "badge-neutral"
                            };
                            string statusText = order.OrderStatus switch
                            {
                                1 => "جديد",
                                2 => "مراجعة",
                                3 => "طباعة",
                                4 => "شحن",
                                5 => "مكتمل",
                                _ => "—"
                            };

                            <tr>
                                <td><strong style="color: var(--primary-color); font-size: 13px;">@order.OrderNumber</strong></td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <div style="width: 30px; height: 30px; border-radius: 50%; background: var(--primary-light); color: var(--primary-color); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 12px; flex-shrink: 0;">
                                            @order.CustomerName.Substring(0, 1)
                                        </div>
                                        <span style="font-weight: 600; font-size: 13px;">@order.CustomerName</span>
                                    </div>
                                </td>
                                <td style="font-weight: 700; color: var(--text-main);">@order.TotalAmount.ToString("N2") ر.س</td>
                                <td><span class="badge @statusClass" style="font-size: 11px;">@statusText</span></td>
                                <td>
                                    <a href="/Admin/Orders/Details/@order.Id" class="btn-outline btn-icon" style="width: 32px; height: 32px;" title="عرض">
                                        <i class="fas fa-eye" style="font-size: 13px;"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                <i class="fas fa-inbox" style="font-size: 28px; margin-bottom: 10px; opacity: 0.3; display: block;"></i>
                                لا توجد طلبات حتى الآن
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- المنتجات الأكثر مبيعاً -->
    <div class="premium-card" style="padding: 24px;">
        <h3 style="font-size: 16px; font-weight: 800; color: var(--text-main); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            <div style="width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--warning-bg); color: var(--warning); display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-trophy"></i>
            </div>
            الأكثر مبيعاً
        </h3>

        @if (Model.TopProducts != null && Model.TopProducts.Any())
        {
            <div style="display: flex; flex-direction: column; gap: 16px;">
                @for (int i = 0; i < Model.TopProducts.Count; i++)
                {
                    var product = Model.TopProducts[i];
                    string medalColor = i switch
                    {
                        0 => "#f59e0b",
                        1 => "#94a3b8",
                        2 => "#cd7f32",
                        _ => "var(--border-color)"
                    };

                    <div style="display: flex; align-items: center; gap: 14px; padding: 12px; background: var(--border-light); border-radius: var(--radius-sm); border-right: 4px solid @medalColor;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: @medalColor; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 14px; flex-shrink: 0;">
                            @(i + 1)
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div style="font-weight: 700; color: var(--text-main); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@product.ProductName">
                                @product.ProductName
                            </div>
                            <div style="font-size: 11px; color: var(--text-muted);">
                                @product.TotalSold قطعة مباعة
                            </div>
                        </div>
                        <div style="text-align: left; flex-shrink: 0;">
                            <div style="font-weight: 800; color: var(--primary-color); font-size: 14px;">
                                @product.TotalRevenue.ToString("N0")
                            </div>
                            <div style="font-size: 10px; color: var(--text-muted);">ر.س</div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                <i class="fas fa-chart-bar" style="font-size: 28px; margin-bottom: 10px; opacity: 0.3; display: block;"></i>
                لا توجد بيانات مبيعات
            </div>
        }
    </div>
</div>